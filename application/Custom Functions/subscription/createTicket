			billing_url = "https://creatorapp.zohopublic.com/xmttechnologiessdnbhd1/xmt-billing-system/report-perma/All_Work_Order_Creations/VdbndsS1m3EHhRMdrSZhfhqgf48gsSOVkQ5v1pbMZVR2H6XfrXATWSwUP7B2xVaCBmtWaKXBYeKj8k5B79afguswAdx7HB4ezBvp?Subscription=" + recId.toString();
			cf = Map();
			cf.put("cf_customer_code",customer_code_display_value);
			cf.put("cf_contact",contact_name);
			cf.put("cf_ticket_type",ticketType);
			cf.put("cf_url_to_subscription_record_in_billing_system",billing_url);
