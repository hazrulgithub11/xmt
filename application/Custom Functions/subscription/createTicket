			{
				// Step 7: Update Work Order Record in Zoho Creator with Ticket ID and Ticket Number
				ticket_id = create_ticket_response.get("id");
				ticket_number = create_ticket_response.get("ticketNumber");
				info "Ticket created successfully. Ticket ID: " + ticket_id + ", Ticket Number: " + ticket_number;
