map subscription.createTicket(int recId, string ticketType)
{
	woList = Work_Order_Creation[Subscription == recId].ID.getAll();
	if(woList.size() == 0)
	{
		mess = Map();
		mess.put("code",403);
		mess.put("message","No work order for subscription. Use work_order_creation.updateTicketNumber.");
		return mess;
	}
	woId = woList.get(woList.size() - 1);
	return thisapp.subscription.createTicketForWorkOrder(recId,woId.toLong(),ticketType);
}
