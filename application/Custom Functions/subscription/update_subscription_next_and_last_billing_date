void subscription.update_subscription_next_and_last_billing_date(list:int subsListId, string billFor, int billingCycle, date actualBillingDate, date monthlyBillingDate, string billEvery)
{
	if(billingCycle == 1)
	{
		if(billFor.containsIgnoreCase("Current"))
		{
			for each  subId in subsListId
			{
				subInfo = Subscription[ID == subId];
				finalBillingDate = subInfo.Final_Billing_Date;
				contractStartDate = subInfo.Contract_Start_Date;
				newNextBillingDate = thisapp.tenancy.compute_next_billing_date(billingCycle,actualBillingDate,monthlyBillingDate,billEvery,contractStartDate);
				if(actualBillingDate == monthlyBillingDate && actualBillingDate != finalBillingDate)
				{
					subInfo.Next_Billing_Date=newNextBillingDate;
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
				else if(actualBillingDate == finalBillingDate)
				{
					subInfo.Next_Billing_Date=null;
					subInfo.Latest_Billing_Date=actualBillingDate;
					subInfo.Subscription_Status="Inactive";
				}
				else if(actualBillingDate != monthlyBillingDate)
				{
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
			}
		}
		else if(billFor.containsIgnoreCase("Previous"))
		{
			for each  subId in subsListId
			{
				subInfo = Subscription[ID == subId];
				finalBillingDate = subInfo.Final_Billing_Date;
				contractStartDate = subInfo.Contract_Start_Date;
				newNextBillingDate = thisapp.tenancy.compute_next_billing_date(billingCycle,actualBillingDate,monthlyBillingDate,billEvery,contractStartDate);
				if(actualBillingDate != monthlyBillingDate)
				{
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
				if(actualBillingDate == monthlyBillingDate && actualBillingDate != finalBillingDate)
				{
					subInfo.Next_Billing_Date=newNextBillingDate;
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
				else if(actualBillingDate == finalBillingDate)
				{
					subInfo.Next_Billing_Date=null;
					subInfo.Latest_Billing_Date=actualBillingDate;
					subInfo.Subscription_Status="Inactive";
				}
			}
		}
	}
	else
	{
		for each  subId in subsListId
		{
			subInfo = Subscription[ID == subId];
			finalBillingDate = subInfo.Final_Billing_Date;
			contractStartDate = subInfo.Contract_Start_Date;
			newNextBillingDate = thisapp.tenancy.compute_next_billing_date(billingCycle,actualBillingDate,monthlyBillingDate,billEvery,contractStartDate);
			if(billFor.containsIgnoreCase("Current"))
			{
				if(actualBillingDate == monthlyBillingDate && actualBillingDate != finalBillingDate)
				{
					subInfo.Next_Billing_Date=newNextBillingDate;
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
				else if(actualBillingDate == finalBillingDate)
				{
					subInfo.Next_Billing_Date=null;
					subInfo.Latest_Billing_Date=actualBillingDate;
					subInfo.Subscription_Status="Inactive";
				}
				else if(actualBillingDate != monthlyBillingDate)
				{
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
			}
			else if(billFor.containsIgnoreCase("Previous"))
			{
				if(actualBillingDate != monthlyBillingDate)
				{
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
				if(actualBillingDate == monthlyBillingDate && actualBillingDate != finalBillingDate)
				{
					subInfo.Next_Billing_Date=newNextBillingDate;
					subInfo.Latest_Billing_Date=actualBillingDate;
				}
				else if(actualBillingDate == finalBillingDate)
				{
					subInfo.Next_Billing_Date=null;
					subInfo.Latest_Billing_Date=actualBillingDate;
					subInfo.Subscription_Status="Inactive";
				}
			}
		}
	}
}