// Schedule entry (monthly): Handle_Creation_Of_Subscr1 — do not duplicate inline invoice routing in workflows.
void tenancy.fetch_subscription_and_tenancy_details(int tenantID)
{
	tenantInfo = Tenancy[ID == tenantID];
	actualBillingDate = tenantInfo.Next_Billing_Date;
	billFor = tenantInfo.Bill_For;
	billingCycle = tenantInfo.Billing_Cycle;
	billEvery = tenantInfo.Bill_Every;
	subsListId = Subscription[Customer_Code = tenantID && Next_Billing_Date = actualBillingDate && Subscription_Status == "Active"].ID.getAll();
	billCycleInt = thisapp.tenancy.convert_bill_cycle_to_int(billingCycle);
	if(subsListId.size() > 0)
	{
		monthlyBillingDate = thisapp.tenancy.get_monthly_billing_date_from_actual(billEvery,actualBillingDate);
		if(billFor == "Current Duration")
		{
			thisapp.invoice.create_invoice_current_monthly(subsListId,billCycleInt,tenantID,monthlyBillingDate,actualBillingDate,false,null,null,false);
		}
		else
		{
			thisapp.invoice.create_invoice_previous_monthly(subsListId,billCycleInt,tenantID,monthlyBillingDate,actualBillingDate,false,null,null,false);
		}
	}
}
