int tenancy.convert_bill_cycle_to_int(string billCycle)
{
	monthsToAdd = 1;
	if(billCycle == null || billCycle == "")
	{
		return monthsToAdd;
	}
	if(billCycle == "Monthly")
	{
		monthsToAdd = 1;
	}
	else if(billCycle == "Quarterly")
	{
		monthsToAdd = 3;
	}
	else if(billCycle == "Half Yearly")
	{
		monthsToAdd = 6;
	}
	else if(billCycle == "Yearly")
	{
		monthsToAdd = 12;
	}
	return monthsToAdd;
}
