void invoice.invoice_balance_updates(int invId)
{
getInvoice = Invoice[ID == invId];
if(getInvoice == null)
{
	return;
}
invoiceDate = getInvoice.Invoice_Date;
tenantID = getInvoice.Customer_Code;
previoustotalAmountDue = 0;
if(invoiceDate != null && tenantID != null)
{
	for each  inv in Invoice[Blueprint.Current_Stage in {"Sent","Overdue","Partially Paid"} && Invoice_Date < invoiceDate.toStartOfMonth() && Customer_Code == tenantID]
	{
		previoustotalAmountDue = previoustotalAmountDue + inv.Amount_Due;
	}
}
getInvoice.Previous_Balance=previoustotalAmountDue;
getInvoice.Total_Amount_Due=getInvoice.Grand_Total;

}
