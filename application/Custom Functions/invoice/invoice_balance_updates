map invoice.invoice_balance_updates(int invoice_id, date invoice_date, int customer_id, float amount_due)
{
invoice_date_to_use = invoice_date;
customer_id_to_use = customer_id;
current_amount_due = ifnull(amount_due,0);
persist_balance_to_db = true;
if(invoice_id != null && invoice_id != 0)
{
	get_invoice = Invoice[ID == invoice_id];
	if(get_invoice.ID == null || get_invoice.ID == 0)
	{
		result = Map();
		result.put("Previous_Balance",0);
		result.put("Total_Amount_Due",current_amount_due);
		return result;
	}
	if(invoice_date == null)
	{
		invoice_date_to_use = get_invoice.Invoice_Date;
	}
	else
	{
		persist_balance_to_db = false;
	}
	if(customer_id == null)
	{
		customer_id_to_use = get_invoice.Customer.ID;
	}
	if(amount_due == null)
	{
		current_amount_due = ifnull(get_invoice.Amount_Due,0);
	}
}
previous_balance_of_unpaid_invoices = 0;
if(invoice_date_to_use != null && customer_id_to_use != null)
{
	for each  curr_invoice in Invoice[Amount_Due > 0 && Blueprint.Current_Stage in {"Sent","Overdue","Partially Paid"} && Invoice_Date < invoice_date_to_use && Customer == customer_id_to_use && ID != invoice_id]
	{
		previous_balance_of_unpaid_invoices = previous_balance_of_unpaid_invoices + curr_invoice.Amount_Due;
	}
}
total_amount_due = current_amount_due + previous_balance_of_unpaid_invoices;
if(invoice_id != null && invoice_id != 0 && persist_balance_to_db == true)
{
	get_invoice = Invoice[ID == invoice_id];
	get_invoice.Previous_Balance=previous_balance_of_unpaid_invoices;
	get_invoice.Total_Amount_Due=total_amount_due;
}
result = Map();
result.put("Previous_Balance",previous_balance_of_unpaid_invoices);
result.put("Total_Amount_Due",total_amount_due);
return result;
}
