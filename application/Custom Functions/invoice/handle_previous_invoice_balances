map invoice.handle_previous_invoice_balances(date actualBillingDate, int billingCycle, int tenantID, float grandTotal)
{
	mp = Map();
	previousBalance = 0;
	if(actualBillingDate != null && tenantID != null)
	{
		tenantInfo = Tenancy[ID == tenantID];
		if(tenantInfo != null && tenantInfo.Customer_Name != null)
		{
			customer_id = tenantInfo.Customer_Name.ID;
			for each  curr_invoice in Invoice[Amount_Due > 0 && Blueprint.Current_Stage in {"Sent","Overdue","Partially Paid"} && Invoice_Date < actualBillingDate && Customer == customer_id]
			{
				previousBalance = previousBalance + curr_invoice.Amount_Due;
			}
		}
	}
	overdueCharges = previousBalance;
	totalAmountDue = ifnull(grandTotal,0) + previousBalance;
	mp.put("Previous_Balance",previousBalance);
	mp.put("Overdue_Charges",overdueCharges);
	mp.put("Total_Amount_Due",totalAmountDue);
	return mp;
}
