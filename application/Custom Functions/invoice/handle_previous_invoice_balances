map invoice.handle_previous_invoice_balances(date actualBillingDate, int billingCycle, int tenantID, float grandTotal)
{
mp = Map();
previoustotalAmountDue = 0;
if(actualBillingDate != null && tenantID != null)
{
	for each  inv in Invoice[Blueprint.Current_Stage in {"Sent","Overdue","Partially Paid"} && Invoice_Date < actualBillingDate.toStartOfMonth() && Customer_Code == tenantID]
	{
		previoustotalAmountDue = previoustotalAmountDue + inv.Amount_Due;
	}
}
previousBalance = previoustotalAmountDue;
overdueCharges = previoustotalAmountDue;
totalAmountDue = previoustotalAmountDue + grandTotal;
//info "overdueCharges:" + previoustotalAmountDue;
mp.put("Previous_Balance",previousBalance);
// 	mp.put("Payment_Received",paymentReceived);
mp.put("Overdue_Charges",overdueCharges);
mp.put("Total_Amount_Due",totalAmountDue);
//mp.put("Previous_Invoice",previousInvoice);
return mp;
}
