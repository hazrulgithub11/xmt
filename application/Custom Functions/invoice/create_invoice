void invoice.create_invoice(list:int subs_list_id, int billing_cycle, int tenant_id, date monthly_billing_date, date actual_billing_date)
{
	tenant_info = Tenancy[ID == tenant_id];
	tenant_final_billing_date = tenant_info.Final_Billing_Date;
	tenant_next_billing_date = tenant_info.Next_Billing_Date;
	customer = tenant_info.Customer_Name;
	customer_email_address = customer.Email_Address;
	customer_info = Customer_Profile[ID == customer];
	currency = customer_info.Currency;
	bill_for = tenant_info.Bill_For;
	bill_every = tenant_info.Bill_Every;
	enable_reminder = tenant_info.Enable_Reminder;
	due_date = actual_billing_date.addDay(tenant_info.Payment_Term.Days);
	sum_sub_total = 0;
	total_tax = 0;
	grand_total = 0;
	grand_total_myr = 0;
	total_deposit_amount = 0;
	sub_total_monthly_rental = 0;
	total_tax_monthly_rental = 0;
	grand_total_monthly_rental = 0;
	sub_total_internet_charges = 0;
	total_tax_internet_charges = 0;
	grand_total_internet_charges = 0;
	sub_total_call_charges = 0;
	total_tax_call_charges = 0;
	grand_total_call_charges = 0;
	payable_to = List();
	if(actual_billing_date < monthly_billing_date.toStartOfMonth())
	{
		actual_billing_date = today;
	}
	if(monthly_billing_date == actual_billing_date)
	{
		new_next_billing_date = actual_billing_date.addMonth(billing_cycle);
		if(bill_every != "Last Day Of Month")
		{
			bill_every_int = bill_every.toLong();
		}
		else
		{
			bill_every_int = new_next_billing_date.eomonth(0).getDay();
		}
		if(new_next_billing_date.getDay() != bill_every_int && new_next_billing_date.getMonth() != 2 && bill_every != "Last Day Of Month")
		{
			new_next_billing_date = toDate(bill_every + "-" + new_next_billing_date.getMonth() + "-" + new_next_billing_date.getYear(),"dd-MM-yyyy");
		}
	}
	else
	{
		new_next_billing_date = monthly_billing_date.addMonth(billing_cycle);
	}
	if(bill_every == "Last Day Of Month")
	{
		new_next_billing_date = new_next_billing_date.eomonth(0);
	}
	//Create Invoice Bill For Current Duration
	if(bill_for.containsIgnoreCase("Current"))
	{
		invoice_usage = thisapp.invoice.get_invoice_usage(actual_billing_date);
		for each  sub_id in subs_list_id
		{
			sub_info = Subscription[ID == sub_id];
			exchange_rate = sub_info.Exchange_Rate;
			pi_grand_total = Pro_Forma_Invoices[ID == sub_info.Pro_Forma_Invoices].Grand_Total;
			total_deposit_amount = total_deposit_amount + ifnull(pi_grand_total,0);
			final_billing_date = sub_info.Final_Billing_Date;
			last_billing_date = sub_info.Latest_Billing_Date;
			contract_start_date = sub_info.Contract_Start_Date;
			contract_end_date = sub_info.Contract_End_Date;
			contract_period = sub_info.Contract_Period;
			info "Customer PO No: " + sub_info.Customer_PO_No;
			info "contractEndDate: " + contract_end_date;
			info "actualBillingDate: " + actual_billing_date;
			info "monthlyBillingDate: " + monthly_billing_date;
			info "newNextBillingDate: " + new_next_billing_date;
			info "finalBillingDate: " + final_billing_date;
			info "billingCycle: " + billing_cycle;
			payable_to.addAll(sub_info.Payable_To1);
			/*Actual Billing Date Not Equal To Monthly Billing Date*/
			if(actual_billing_date != monthly_billing_date || (actual_billing_date == monthly_billing_date && last_billing_date == null && actual_billing_date != final_billing_date && contract_start_date.getDay() != actual_billing_date.getDay()))
			{
				info "prorate current startdate invoice of subscription";
				due_date = actual_billing_date.addDay(tenant_info.Payment_Term.Days);
				for each  monthly_rental_line_item in sub_info.Monthly_Rental
				{
					item = monthly_rental_line_item.Item_Monthly_Rental;
					item_code = monthly_rental_line_item.Item_Code_Monthly_Rental;
					description = monthly_rental_line_item.Description_Monthly_Rental;
					unit_price = monthly_rental_line_item.Unit_Price_Monthly_Rental;
					quantity = monthly_rental_line_item.Quantity_Monthly_Rental;
					tax = monthly_rental_line_item.Tax_Monthly_Rental;
					tax_pct = monthly_rental_line_item.Tax_Pct_Monthly_Rental;
					business_segment = monthly_rental_line_item.Business_Segment_Monthly_Rental;
					business_unit = monthly_rental_line_item.Business_Unit_Monthly_Rental;
					circuit_id = monthly_rental_line_item.Circuit_ID_Monthly_Rental;
					circuit_id_type = monthly_rental_line_item.Circuit_ID_Type_Monthly_Rental;
					sub_line_item_id = monthly_rental_line_item.ID;
					line_calc = thisapp.invoice.calc_line_subtotal("legacy_current_start",unit_price,quantity,billing_cycle,contract_start_date,contract_end_date,new_next_billing_date,contract_period,bill_every,sub_info.Next_Billing_Date,actual_billing_date);
					sub_total = line_calc.get("subTotal");
					billing_cycle_months_used = line_calc.get("billingCycleMonthsUsed");
					info "billingCycleMonthsUsed: " + billing_cycle_months_used;
					info "subTotal: " + sub_total;
					line_tax = thisapp.invoice.calc_line_tax(sub_total,tax_pct,false);
					tax_amount = line_tax.get("taxAmount");
					total = line_tax.get("total");
					total_myr = total * exchange_rate;
					sum_sub_total = sum_sub_total + sub_total;
					total_tax = total_tax + tax_amount;
					grand_total = grand_total + total;
					grand_total_myr = grand_total_myr + total_myr;
					sub_total_monthly_rental = sub_total_monthly_rental + sub_total;
					total_tax_monthly_rental = total_tax_monthly_rental + tax_amount;
					grand_total_monthly_rental = grand_total_monthly_rental + total;
				}
				for each  internet_charges_line_item in sub_info.Internet_Charges
				{
					item = internet_charges_line_item.Item_Internet_Charges;
					item_code = internet_charges_line_item.Item_Code_Internet_Charges;
					description = internet_charges_line_item.Description_Internet_Charges;
					unit_price = internet_charges_line_item.Unit_Price_Internet_Charges;
					quantity = internet_charges_line_item.Quantity_Internet_Charges;
					tax = internet_charges_line_item.Tax_Internet_Charges;
					tax_pct = internet_charges_line_item.Tax_Pct_Internet_Charges;
					business_segment = internet_charges_line_item.Business_Segment_Internet_Charges;
					business_unit = internet_charges_line_item.Business_Unit_Internet_Charges;
					circuit_id = internet_charges_line_item.Circuit_ID_Internet_Charges;
					circuit_id_type = internet_charges_line_item.Circuit_ID_Type_Internet_Charges;
					sub_line_item_id = internet_charges_line_item.ID;
					line_calc = thisapp.invoice.calc_line_subtotal("legacy_current_start",unit_price,quantity,billing_cycle,contract_start_date,contract_end_date,new_next_billing_date,contract_period,bill_every,sub_info.Next_Billing_Date,actual_billing_date);
					sub_total = line_calc.get("subTotal");
					billing_cycle_months_used = line_calc.get("billingCycleMonthsUsed");
					info "billingCycleMonthsUsed: " + billing_cycle_months_used;
					info "subTotal: " + sub_total;
					line_tax = thisapp.invoice.calc_line_tax(sub_total,tax_pct,false);
					tax_amount = line_tax.get("taxAmount");
					total = line_tax.get("total");
					total_myr = total * exchange_rate;
					sum_sub_total = sum_sub_total + sub_total;
					total_tax = total_tax + tax_amount;
					grand_total = grand_total + total;
					grand_total_myr = grand_total_myr + total_myr;
					sub_total_internet_charges = sub_total_internet_charges + sub_total;
					total_tax_internet_charges = total_tax_internet_charges + tax_amount;
					grand_total_internet_charges = grand_total_internet_charges + total;
				}
				for each  call_charges_line_item in sub_info.Call_Charges
				{
					item = call_charges_line_item.Item_Call_Charges;
					item_code = call_charges_line_item.Item_Code_Call_Charges;
					description = call_charges_line_item.Description_Call_Charges;
					unit_price = call_charges_line_item.Unit_Price_Call_Charges;
					quantity = call_charges_line_item.Quantity_Call_Charges;
					tax = call_charges_line_item.Tax_Call_Charges;
					tax_pct = call_charges_line_item.Tax_Pct_Call_Charges;
					business_segment = call_charges_line_item.Business_Segment_Call_Charges;
					business_unit = call_charges_line_item.Business_Unit_Call_Charges;
					circuit_id = call_charges_line_item.Circuit_ID_Call_Charges;
					circuit_id_type = call_charges_line_item.Circuit_ID_Type_Call_Charges;
					sub_line_item_id = call_charges_line_item.ID;
					line_calc = thisapp.invoice.calc_line_subtotal("legacy_current_start",unit_price,quantity,billing_cycle,contract_start_date,contract_end_date,new_next_billing_date,contract_period,bill_every,sub_info.Next_Billing_Date,actual_billing_date);
					sub_total = line_calc.get("subTotal");
					billing_cycle_months_used = line_calc.get("billingCycleMonthsUsed");
					info "billingCycleMonthsUsed: " + billing_cycle_months_used;
					info "subTotal: " + sub_total;
					line_tax = thisapp.invoice.calc_line_tax(sub_total,tax_pct,false);
					tax_amount = line_tax.get("taxAmount");
					total = line_tax.get("total");
					total_myr = total * exchange_rate;
					sum_sub_total = sum_sub_total + sub_total;
					total_tax = total_tax + tax_amount;
					grand_total = grand_total + total;
					grand_total_myr = grand_total_myr + total_myr;
					sub_total_call_charges = sub_total_call_charges + sub_total;
					total_tax_call_charges = total_tax_call_charges + tax_amount;
					grand_total_call_charges = grand_total_call_charges + total;
				}
			}
