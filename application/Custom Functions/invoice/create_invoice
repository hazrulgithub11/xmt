								prorate_unit_price = unit_price / 30;
								prorate_month = prorate_unit_price * (daysBetween(final_billing_date,contract_end_date) + 1);
								prorate_sub_total = prorate_month * quantity;
								info "days prorate:" + daysBetween(final_billing_date.addMonth(billing_cycle_months_used),contract_end_date) + 1;
								sub_total = unit_price * quantity * billing_cycle_months_used + prorate_sub_total;
							}
						}
						info "prorateUnitPrice:" + prorate_unit_price;
						info "prorateMonth:" + prorate_month;
						info "subTotal:" + sub_total;
						line_tax = thisapp.invoice.calc_line_tax(sub_total,tax_pct,false);
