						business_unit = monthly_rental_line_item.Business_Unit_Monthly_Rental;
						circuit_id = monthly_rental_line_item.Circuit_ID_Monthly_Rental;
						circuit_id_type = monthly_rental_line_item.Circuit_ID_Type_Monthly_Rental;
						sub_line_item_id = monthly_rental_line_item.ID;
						if(billing_cycle == 1)
						{
							prorate_unit_price = unit_price / actual_billing_date.eomonth(0).getDay();
							prorate_month = prorate_unit_price * contract_end_date.getDay();
							prorate_sub_total = prorate_month * quantity;
							sub_total = prorate_sub_total;
						}
						else
						{
							if(last_billing_date == null)
							{
								if(monthsBetween(contract_start_date,contract_end_date) <= contract_period && contract_start_date.getDay() == contract_end_date.getDay() && last_billing_date == null)
								{
									sub_total = unit_price * quantity * monthsBetween(contract_start_date,contract_end_date);
								}
								else
								{
									prorate_unit_price = unit_price / 30;
									days_used = daysBetween(contract_start_date,contract_end_date) + 1;
									sub_total = prorate_unit_price * quantity * days_used;
									info "daysUsed:" + days_used;
								}
							}
							else
							{
								billing_cycle_months_used = thisapp.invoice.get_billing_cycle_months_used_final_billing_date(actual_billing_date,contract_end_date,bill_every);
