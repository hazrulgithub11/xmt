map work_order_creation.updateTicketNumber(int recId, string ticketType)
{
	mess = Map();
	mess.put("code",403);
	if(ticketType == null || ticketType == "")
	{
		mess.put("message","No ticket created. Must choose a Ticket Type.");
		return mess;
	}
	subRec = Subscription[ID == recId];
	if(subRec == null)
	{
		mess.put("message","Subscription record not found.");
		return mess;
	}
	try 
	{
		createWo = insert into Work_Order_Creation
		[
			Added_User=zoho.loginuser
			Subscription=recId
			Customer_Name=subRec.Customer_Name
			Customer_Code=subRec.Customer_Code
			Work_Order_Type=ticketType
		];
		workOrderId = createWo;
		woUrl = thisapp.subscription.build_work_order_perma_url(workOrderId);
		createTicket = thisapp.subscription.createTicketUpdateWo(recId,workOrderId,ticketType,woUrl);
		if(createTicket.get("code") == 200)
		{
			mess.put("code",200);
			mess.put("message",createTicket.get("message"));
			mess.put("ticketId",createTicket.get("ticketId"));
			mess.put("ticketNumber",createTicket.get("ticketNumber"));
			mess.put("workOrderId",workOrderId);
		}
		else
		{
			mess.put("message",createTicket.get("message"));
		}
	}
	catch (e)
	{
		mess.put("code",500);
		mess.put("message","An error occurred: " + e.toString());
	}
	return mess;
}
