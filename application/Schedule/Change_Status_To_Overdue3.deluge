Change_Status_To_Overdue3 as "Change Status To Overdue"
{
	type =  schedule
	form = Pro_Forma_Invoices[Status == "Sent" || Status == "Partially Paid"]
	start = after 1 days from Due_Date at "09:00:00"
	time zone = "Asia/Singapore"
	on start
	{
		actions 
		{
		update Pro_Forma_Invoices[ID == input.ID]
		[
			Status = "Overdue"
		]
		}
	}
}

