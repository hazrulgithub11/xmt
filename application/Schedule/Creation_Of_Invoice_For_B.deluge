Creation_Of_Invoice_For_B as "Creation Of Invoice For Bill Every 10th"
{
	type =  schedule
		status = inactive
	start = "2024-09-10 09:00:00"
	frequency = monthly
	time zone = "Asia/Singapore"
	on start
	{
		actions 
		{
		on load
		(
			tenanciesId = Tenancy[Next_Billing_Date == zoho.currentdate].ID.getAll();
				for each  tenantID in tenanciesId
				{
					thisapp.tenancy.fetch_subscription_and_tenancy_details(tenantID);
				}
		)
		}
	}
}

