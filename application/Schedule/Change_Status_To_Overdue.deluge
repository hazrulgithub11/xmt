Change_Status_To_Overdue as "Change Status To Overdue"
{
	type =  schedule
	form = Invoice[Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Partially Paid"]
	start = after 1 days from Due_Date at "09:00:00"
	time zone = "Asia/Singapore"
	on start
	{
		actions 
		{
		on load
		(
			thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Overdue",input.ID);
		)
		}
	}
}

