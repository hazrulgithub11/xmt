//listEmail.add("test@aplikasi.us");
notifyTitle = "Invoice " + input.Invoice_No + " Approval Required";
notifyMessage = "Please review and approve Invoice " + input.Invoice_No + " to complete processing.";
urlReport = "https://creatorapp.zoho.com" + zoho.appuri + "#Report:All_Invoices?Status=Pending+Approval";
