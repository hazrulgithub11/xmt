<\/td>\n      <td\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\" face=\"arimo\">:<\/font><\/td>\n      <td\n            style=\"border: 0\"><font color=\"#000000\"\n            style=\"font-size: 10px\" face=\"arimo\"><font\n                style=\"\"> <span>${Customer_SST_Registration_Number}<\/span> <span\n          style=\"font-weight: 400; font-style: normal\">&nbsp;<\/span> <\/font> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n          width=\"25%\" style=\"border: 0\"><font\n            style=\"padding: 5px; font-size: 10px\" color=\"#000000\"\n          face=\"arimo\">Customer TIN<\/font><\/td>\n      <td width=\"1%\"\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\" face=\"arimo\">:<\/font><\/td>\n      <td\n          style=\"border: 0\" width=\"25%\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n              face=\"arimo\"> <span>${Customer_TIN}<\/span> <span\n          style=\"font-weight: 400; font-style: normal\">&nbsp;<\/span> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"border: 0\"><font\n            style=\"padding: 5px; font-size: 10px\" color=\"#000000\"\n          face=\"arimo\">Customer Name<\/font><\/td>\n      <td\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\" face=\"arimo\">:<\/font><\/td>\n      <td\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\" face=\"arimo\"><b><span><span\n                    style=\"font-weight: 700; font-style: normal\"><span>${Customer_Code.Display_Name}<\/span><span\n          style=\"color: rgb(0, 0, 0); font-family: Arimo; font-size: 10px; font-weight: 700; font-style: normal\">&nbsp;<\/span><\/span><\/span><\/b> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"border: 0\"><font\n            style=\"padding: 5px; font-size: 10px\" color=\"#000000\"\n          face=\"arimo\">Customer Registration No<\/font><\/td>\n      <td\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\" face=\"arimo\">:<\/font><\/td>\n      <td\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n              face=\"arimo\"> <span>${Customer.Customer_Registration_Number}<\/span> <span\n          style=\"font-weight: 400; font-style: normal\">&nbsp;<\/span> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"border: 0\"><font color=\"#000000\"\n            style=\"font-size: 10px\" face=\"arimo\"><font\n          style=\"padding: 5px\">Customer Address<\/font> <br /><\/font><\/td>\n      <td\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\" face=\"arimo\">:<\/font><\/td>\n      <td\n            style=\"border: 0\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"> <span>${Customer.Business_Street},<\/span> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n          style=\"border: 0\"><\/td>\n      <td\n          style=\"border: 0\"><\/td>\n      <td style=\"border: 0\"><font\n            style=\"font-size: 10px\" color=\"#000000\"\n              face=\"arimo\"> <span>${Customer_Code.Postcode}<\/span> <span\n          style=\"font-weight: 400; font-style: normal\">&nbsp; <span>${Customer_Code.City}<\/span>,<\/span> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n          style=\"border: 0\"><\/td>\n      <td\n          style=\"border: 0\"><\/td>\n      <td style=\"border: 0\"><font\n            style=\"font-size: 10px\" color=\"#000000\"\n          face=\"arimo\"> <span>${Customer_Code.Country}<\/span> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"border: 0\"><font\n            style=\"padding: 5px; font-size: 10px\" color=\"#000000\"\n          face=\"arimo\">Customer Contact No<\/font>