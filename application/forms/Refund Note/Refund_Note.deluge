				must have Item_Code_Call_Charges
				(
    				type = text
					displayname = "Item Code"
					width = medium
				)
				must have Classification_Codes_Call_Charges
				(
					type = list	
					displayname = "Classification Codes"
					values = {"Breastfeeding equipment","Child care centres and kindergartens fees","Computer, smartphone or tablet","Consolidated e-Invoice","Construction materials (as specified under Fourth Schedule of the Lembaga Pembangunan Industri)","Disbursement","Donation","e-Commerce - e-Invoice to buyer / purchaser","e-Commerce - Self-billed e-Invoice to seller, logistics, etc.","Education fees","Goods on consignment (Consignor)","Goods on consignment (Consignee)","Gym membership","Insurance - Education and medical benefits","Insurance - Takaful or life insurance","Interest and financing expenses","Internet subscription","Land and building","Medical examination for learning disabilities and early intervention or rehabilitation treatments","Medical examination or vaccination expenses","Medical expenses for serious diseases","Others","Petroleum operations (as defined in Petroleum (Income Tax) Act 1967)","Private retirement scheme or deferred annuity scheme","Motor vehicle","Subscription of books / journals / magazines / newspapers / other similar publications","Reimbursement","Rental of motor vehicle","EV charging facilities (Installation, rental, sale / purchase or subscription fees)","Repair and maintenance","Research and development","Foreign income","Self-billed - Betting and gaming","Self-billed - Importation of goods","Self-billed - Importation of services","Self-billed - Others","Self-billed - Monetary payment to agents, dealers or distributors","Sports equipment, rental / entry fees for sports facilities, registration in sports competition","Supporting equipment for disabled person","Voluntary contribution to approved provident fund","Dental examination or treatment","Fertility treatment","Treatment and home care nursing, daycare centres and residential care centers","Vouchers, gift cards, loyalty points, etc","Self-billed - Non-monetary payment to agents, dealers or distributors"}
					height = 60px
					width = medium
				)
				must have Description_Call_Charges
				(
    				type = textarea
					displayname = "Description"
					height = 100px
					width = medium
				)
				must have Quantity_Call_Charges
				(
					type = decimal
					displayname = "Quantity"
					initial value = 0
					width = medium
				)
				must have Unit_Price_Call_Charges
				(
					type = decimal
					displayname = "Unit Price"
					format = commadotwestern
					initial value = 0
					width = 100px
				)
				must have Sub_Total_Call_Charges
				(
					type = decimal
					displayname = "Sub Total"
					format = commadotwestern
					initial value = 0
					width = 100px
				)
				must have Tax_Call_Charges
				(
					type = picklist	
					displayname = "Tax"
					values  = Tax.ID
    				displayformat = [Tax_Name]
					sortorder = ascending
					width = medium
				)
				must have Tax_Type_Call_Charges
				(
					type = picklist
					displayname = "Tax Type"
					maxchar = 100
					values = {"Sales Tax","Service Tax","Tourism Tax","High-Value Goods Tax","Sales Tax on Low Value Goods","Not Applicable"}
					width = medium
				)
				must have Tax_Pct_Call_Charges
				(
					type = decimal
					displayname = "Tax Pct"
					format = commadotwestern
					initial value = 0
					width = 100px
				)
				must have Tax_Amount_Call_Charges
				(
					type = decimal
					displayname = "Tax Amount"
					format = commadotwestern
					initial value = 0
					width = medium
				)
				must have Total_Call_Charges
				(
					type = decimal
					displayname = "Total"
					format = commadotwestern
					initial value = 0
					width = medium
				)
				Customer_PO_No_Call_Charges
				(
					type = picklist	
					displayname = "Customer PO No."
					values  = Subscription.ID
    				displayformat = [Customer_PO_No]
					sortorder = ascending
					width = medium
				)
				must have Business_Segment_Call_Charges
				(
					type = picklist	
					displayname = "Business Segment"
					values  = Business_Segment.ID
    				displayformat = [Business]
					sortorder = ascending
					width = medium
				)
				must have Business_Unit_Call_Charges
				(
					type = picklist	
					displayname = "Business Unit"
					values  = Business_Unit.ID
    				displayformat = [Business_Unit]
					sortorder = ascending
					width = medium
				)
				must have Circuit_ID_Call_Charges
				(
					type = picklist	
					displayname = "Circuit ID"
					values  = Circuit_ID.ID
    				displayformat = [Circuit_ID]
					sortorder = ascending
					width = medium
				)
				must have Circuit_ID_Type_Call_Charges
				(
					type = picklist	
					displayname = "Circuit ID Type"
					values  = Circuit_ID_Type.ID
    				displayformat = [Circuit_ID_Type]
					sortorder = ascending
					width = medium
				)
				Sub_Line_Item_Call_Charges
				(
					type = picklist	
					displayname = "Sub Line Item"
					values  = Subscription_Line_Item.ID
    				displayformat = [ID]
					sortorder = ascending
					width = medium
				)
	 			row = 9
	 			column = 1   
				width = medium
			)
			Reject_Section
			(
				type = section
				displayname = "Reject Section"
	 			row = 10
	 			column = 0   
				width = medium
			)
			Sub_Total_Monthly_Rental
			(
				type = decimal
				displayname = "Sub Total Monthly Rental"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Total_Tax_Monthly_Rental
			(
				type = decimal
				displayname = "Total Tax Monthly Rental"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Grand_Total_Monthly_Rental
			(
				type = decimal
				displayname = "Grand Total Monthly Rental"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Sub_Total_Internet_Charges
			(
				type = decimal
				displayname = "Sub Total Internet Charges"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Total_Tax_Internet_Charges
			(
				type = decimal
				displayname = "Total Tax Internet Charges"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Grand_Total_Internet_Charges
			(
				type = decimal
				displayname = "Grand Total Internet Charges"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Sub_Total_Call_Charges
			(
				type = decimal
				displayname = "Sub Total Call Charges (Analog, Domestic & Overseas)"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Total_Tax_Call_Charges
			(
				type = decimal
				displayname = "Total Tax Call Charges (Analog, Domestic & Overseas)"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Grand_Total_Call_Charges
			(
				type = decimal
				displayname = "Grand Total Call Charges (Analog, Domestic & Overseas)"
				format = commadotwestern
				initial value = 0
	 			row = 10
	 			column = 1   
				width = medium
			)
			Sub_Total
			(
				type = decimal
				displayname = "Sub Total"
				initial value = 0
	 			row = 10
	 			column = 2   
				width = medium
			)
			Total_Tax
			(
				type = decimal
				displayname = "Total Tax"
				initial value = 0
	 			row = 10
	 			column = 2   
				width = medium
			)
			Grand_Total
			(
				type = decimal
				displayname = "Grand Total"
				initial value = 0
	 			row = 10
	 			column = 2   
				width = medium
			)
			Grand_Total_Base_Currency
			(
				type = decimal
				displayname = "Grand Total (Base Currency)"
				initial value = 0
	 			row = 10
	 			column = 2   
				width = medium
			)
			must have Reference_Credit_Note
			(
				type = picklist	
				displayname = "Reference Credit Note"
				values  = Credit_Note.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 10
	 			column = 2   
				width = medium
			)
			Invoice_Related_List
			(
				type = grid
				displayname = "Invoice Related List"
				USERNAME
				(
    				type = text
					width = medium
				)
				INVOICE_NUMBER
				(
    				type = text
					width = medium
				)
				Related_List_Date
				(
    				type = date
					displayname = "DATE"
					alloweddays = 0,1,2,3,4,5,6
					width = medium
				)
				Related_List_Time
				(
    				type = time
					displayname = "TIME"
					timedisplayoptions = "hh:mm:ss" 
					width = medium
				)
				SUBMISSION_ID
				(
    				type = text
					displayname = "SUBMISSION ID"
					width = medium
				)
				UUID
				(
    				type = url
					enable  linkname
					width = medium
				)
				PUBLIC_LINK
				(
    				type = url
					enable  linkname
					width = medium
				)
				STATUS
				(
    				type = text
					width = medium
				)
				MESSAGE
				(
    				type = textarea
					height = 100px
					width = medium
				)
	 			row = 11
	 			column = 1   
				width = medium
			)
			Decision_Section
			(
				type = section
				displayname = "Decision Section"
	 			row = 12
	 			column = 0   
				width = medium
			)
			User_Input_Trigger
			(
    			type = checkbox
				initial value = false
	 			row = 12
	 			column = 1   
				width = medium
			)
			Customer_Name_Trigger
			(
    			type = checkbox
				displayname = "Customer Name Trigger"
				initial value = false
	 			row = 12
	 			column = 1   
