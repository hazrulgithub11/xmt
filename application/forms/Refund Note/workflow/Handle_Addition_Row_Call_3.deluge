Handle_Addition_Row_Call_3 as "Handle Addition Row Call Charges"
{
	type =  form
	form = Refund_Note

	record event = on add or edit

	on add row of Call_Charges
	{
		actions 
		{
			custom deluge script
			(
					clear row.Business_Segment_Call_Charges;
				clear row.Business_Unit_Call_Charges;
				customerInfo = Customer_Profile[ID == input.Customer];
				if(customerInfo.ID != null && customerInfo.Business_Segment.size() > 0)
				{
					row.Business_Segment_Call_Charges:ui.add(customerInfo.Business_Segment);
				}
				else
				{
					clear row.Business_Segment_Call_Charges;
					clear row.Business_Unit_Call_Charges;
				}
			)
		}
		actions 
		{
			custom deluge script
			(
					input.User_Input_Trigger = !input.User_Input_Trigger;
			)
		}
	}

}

