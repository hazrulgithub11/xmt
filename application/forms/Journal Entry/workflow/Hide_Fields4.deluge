Hide_Fields4 as "Hide Fields"
{
	type =  form
	form = Journal_Entry

	record event = on add or edit
		status = inactive

	on load
	{
		actions 
		{
			custom deluge script
			(
					hide Invoice;
				hide Debit_Note;
				hide Credit_Note;
				hide Payment_Received;
				hide Deposits;
				hide Created_By_The_System;
			)
		}
	}

}

