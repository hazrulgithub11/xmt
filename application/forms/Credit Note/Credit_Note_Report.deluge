		Payable_To as "Payable To"
		Rejection_Reason as "Rejection Reason"
		Confirm_resubmission as "Confirm resubmission?"
		User_Input_Trigger
	)
	quickview
	(
		layout
		(
			datablock1
			(
				fields
				(
					Supplier
					Customer
					Supplier_Name as "Name"
					Supplier_ID_Type as "ID Type"
					Supplier_SST_Registration_Number as "SST Registration Number"
					Supplier_E_mail as "E-mail"
					Supplier_Street as "Street"
				)
			)
		)
		menu
    	(
    	 	header
    	 	(
    		 	Edit 
    		 	Duplicate 
    		 	Delete 
    	 	)
			record
			(
				Edit   	   
				Duplicate   	   
				Delete   	   
    		)
    	)
    	action
    	(
			on click
			(
				View Record   	   
    		)
			on right click
			(
				Edit   	   
				Delete   	   
				Duplicate   	   
				View Record   	   
    		)
     	)
	)
