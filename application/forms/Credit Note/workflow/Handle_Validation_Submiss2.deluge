Handle_Validation_Submiss2 as "Handle Validation Submission"
{
	type =  form
	form = Credit_Note

	record event = on add or edit

	on validate
	{
		actions 
		{
			custom deluge script
			(
					// Toggle User Input Trigger
				input.User_Input_Trigger = !input.User_Input_Trigger;
				// Validate Reference Invoice is set and LHDN-submitted
				if(input.Reference_Invoice != null)
				{
					ref_uuid = input.Reference_Invoice.Invoice_UUID;
					if(ref_uuid == null || ref_uuid == "")
					{
						alert "Reference Invoice does not have a valid LHDN UUID. Submit the invoice to LHDN first, then create the credit note.";
						cancel submit;
					}
				}
				else
				{
					alert "A Credit Note must be linked to a reference invoice. Please select a Reference_Invoice.";
					cancel submit;
				}
				cn_stage = input.Blueprint.Current_Stage;
				if(input.ID == null || cn_stage == "Draft" || cn_stage == "Rejected")
				{
					if(input.Credit_Mode == null || input.Credit_Mode == "")
					{
						alert "Credit Mode could not be determined. Please re-select the Reference Invoice.";
						cancel submit;
					}
				}
				// Count Total Line Items
				count_item = 0;
				for each  curr_monthly_rental in input.Monthly_Rental
				{
					count_item = count_item + 1;
				}
				for each  curr_internet_charge in input.Internet_Charges
				{
					count_item = count_item + 1;
				}
				for each  curr_call_charge in input.Call_Charges
				{
					count_item = count_item + 1;
				}
				if(count_item == 0)
				{
					alert "Add at least one item need to be added.";
					cancel submit;
				}
				// Validate Call Charges for Telephone Category
				charges_categories = input.Charge_Category;
				if(charges_categories.containsIgnoreCase("Telephone Charges"))
				{
					row_number = 0;
					for each  call_charges in input.Call_Charges
					{
						row_number = row_number + 1;
					}
					if(row_number == 0)
					{
						alert "Please fill Call Charges";
						cancel submit;
					}
				}
				// Validate lines do not exceed source invoice (reduce-only)
				ref_invoice = Invoice[ID == input.Reference_Invoice];
				for each  curr_monthly_rental in input.Monthly_Rental
				{
					item_code = curr_monthly_rental.Item_Code_Monthly_Rental;
					if(item_code == null || item_code == "")
					{
						item_code = curr_monthly_rental.Item_Monthly_Rental.Item_Code;
					}
					source_row_found = false;
					for each  invoice_mr in ref_invoice.Monthly_Rental
					{
						if(invoice_mr.Item_Monthly_Rental.Item_Code == item_code)
						{
							source_row_found = true;
							if(curr_monthly_rental.Quantity_Monthly_Rental > invoice_mr.Quantity_Monthly_Rental)
							{
								alert "Credit note qty for " + item_code + " exceeds original invoice qty. Reduce the quantity.";
								cancel submit;
							}
							if(curr_monthly_rental.Unit_Price_Monthly_Rental > invoice_mr.Unit_Price_Monthly_Rental)
							{
								alert "Credit note unit price for " + item_code + " exceeds original invoice unit price.";
								cancel submit;
							}
							break;
						}
					}
					if(source_row_found == false)
					{
						alert "Credit note line item " + item_code + " does not exist on the reference invoice.";
						cancel submit;
					}
				}
				for each  curr_internet_charges in input.Internet_Charges
				{
					item_code = curr_internet_charges.Item_Code_Internet_Charges;
					if(item_code == null || item_code == "")
					{
						item_code = curr_internet_charges.Item_Internet_Charges.Item_Code;
					}
					source_row_found = false;
					for each  invoice_ic in ref_invoice.Internet_Charges
					{
						if(invoice_ic.Item_Internet_Charges.Item_Code == item_code)
						{
							source_row_found = true;
							if(curr_internet_charges.Quantity_Internet_Charges > invoice_ic.Quantity_Internet_Charges)
							{
								alert "Credit note qty for " + item_code + " exceeds original invoice qty. Reduce the quantity.";
								cancel submit;
							}
							if(curr_internet_charges.Unit_Price_Internet_Charges > invoice_ic.Unit_Price_Internet_Charges)
							{
								alert "Credit note unit price for " + item_code + " exceeds original invoice unit price.";
								cancel submit;
							}
							break;
						}
					}
					if(source_row_found == false)
					{
						alert "Credit note line item " + item_code + " does not exist on the reference invoice.";
						cancel submit;
					}
				}
				for each  curr_call_charges in input.Call_Charges
				{
					item_code = curr_call_charges.Item_Code_Call_Charges;
					if(item_code == null || item_code == "")
					{
						item_code = curr_call_charges.Item_Call_Charges.Item_Code;
					}
					source_row_found = false;
					for each  invoice_cc in ref_invoice.Call_Charges
					{
						if(invoice_cc.Item_Call_Charges.Item_Code == item_code)
						{
							source_row_found = true;
							if(curr_call_charges.Quantity_Call_Charges > invoice_cc.Quantity_Call_Charges)
							{
								alert "Credit note qty for " + item_code + " exceeds original invoice qty. Reduce the quantity.";
								cancel submit;
							}
							if(curr_call_charges.Unit_Price_Call_Charges > invoice_cc.Unit_Price_Call_Charges)
							{
								alert "Credit note unit price for " + item_code + " exceeds original invoice unit price.";
								cancel submit;
							}
							break;
						}
					}
					if(source_row_found == false)
					{
						alert "Credit note line item " + item_code + " does not exist on the reference invoice.";
						cancel submit;
					}
				}
				// Validate Monthly Rental Quantity & Unit Price
				for each  curr_monthly_rental in input.Monthly_Rental
				{
					if(ifnull(curr_monthly_rental.Quantity_Monthly_Rental,0) <= 0)
					{
						alert "Please enter a quantity more than 0";
						cancel submit;
					}
					if(ifnull(curr_monthly_rental.Unit_Price_Monthly_Rental,0) <= 0)
					{
						alert "Please enter a unit price more than 0";
						cancel submit;
					}
				}
				// Validate Internet Charges Quantity & Unit Price
				for each  curr_internet_charges in input.Internet_Charges
				{
					if(ifnull(curr_internet_charges.Quantity_Internet_Charges,0) <= 0)
					{
						alert "Please enter a quantity more than 0";
						cancel submit;
					}
					if(ifnull(curr_internet_charges.Unit_Price_Internet_Charges,0) <= 0)
					{
						alert "Please enter a unit price more than 0";
						cancel submit;
					}
				}
				// Validate Call Charges Quantity & Unit Price
				for each  curr_call_charges in input.Call_Charges
				{
					if(ifnull(curr_call_charges.Quantity_Call_Charges,0) <= 0)
					{
						alert "Please enter a quantity more than 0";
						cancel submit;
					}
					if(ifnull(curr_call_charges.Unit_Price_Call_Charges,0) <= 0)
					{
						alert "Please enter a unit price more than 0";
						cancel submit;
					}
				}
				// Validate Applied Invoices Submitted to LHDN
				for each  curr_credit_applied_invoice in input.Credit_Applied_Invoices
				{
					curr_get_credit_applied_invoice = Invoice[ID = curr_credit_applied_invoice.CAI_Invoice_No];
					curr_get_credit_applied_invoice_uuid = curr_get_credit_applied_invoice.Invoice_UUID;
					if(curr_get_credit_applied_invoice_uuid == "")
					{
						alert "An applied invoice has not been submitted to LHDN.";
						cancel submit;
					}
				}
				// Validate Credits Remaining Not Negative
				if(input.Credits_Remaining < 0)
				{
					alert "Please ensure that the credit note amount is not less than the total credits already refunded to the customer.";
					cancel submit;
				}
				// Sync Deleted Refund History & Remove Orphaned Refund Notes
				refund_history_list = Credit_Note[ID = input.ID].Refund_History;
				input_refund_history_list = input.Refund_History;
				for each  curr_refund_history in refund_history_list
				{
					curr_refund_history_refund_note_id = curr_refund_history.Refund_History_Refund_Note;
					is_input_refund_note_existed = false;
					for each  curr_input_refund_history in input_refund_history_list
					{
						curr_input_refund_history_refund_note_id = curr_input_refund_history.Refund_History_Refund_Note;
						if(curr_input_refund_history_refund_note_id == curr_refund_history_refund_note_id)
						{
							is_input_refund_note_existed = true;
						}
					}
					if(is_input_refund_note_existed == false)
					{
						// Delete Refund_Note
						delete from Refund_Note[ID == curr_refund_history_refund_note_id];
					}
				}
				// Sync Deleted Credit Applied Invoices & Recalculate Invoice Credits
				credit_applied_invoices_list = Credit_Note[ID = input.ID].Credit_Applied_Invoices;
				input_credit_applied_invoices_list = input.Credit_Applied_Invoices;
				for each  curr_credit_applied_invoices in credit_applied_invoices_list
				{
					curr_cai_invoice_id = curr_credit_applied_invoices.CAI_Invoice_No;
					curr_cai_apply_credit_to_invoice_line_id = curr_credit_applied_invoices.CAI_Apply_Credit_To_Invoice_Line_ID;
					is_input_cai_apply_credit_to_invoice_line_id_existed = false;
					for each  curr_input_credit_applied_invoices in input_credit_applied_invoices_list
					{
						curr_input_cai_apply_credit_to_invoice_line_id = curr_input_credit_applied_invoices.CAI_Apply_Credit_To_Invoice_Line_ID;
						if(curr_input_cai_apply_credit_to_invoice_line_id == curr_cai_apply_credit_to_invoice_line_id)
						{
							is_input_cai_apply_credit_to_invoice_line_id_existed = true;
							break;
						}
					}
					if(is_input_cai_apply_credit_to_invoice_line_id_existed == false)
					{
						// Delete Apply_Credit_To_Invoice_Line
						delete from Apply_Credit_To_Invoice_Line[ID == curr_cai_apply_credit_to_invoice_line_id.toLong()];
						// Credits Applied Calculation (Invoice form)
						input_invoice = Invoice[ID = curr_cai_invoice_id];
						input_invoice.Credits_Applied=null;
						apply_credit_to_invoice_line_list = Apply_Credit_To_Invoice_Line[Invoice = curr_cai_invoice_id];
						credits_applied_total = 0;
						for each  curr_apply_credit_to_invoice_line in apply_credit_to_invoice_line_list
						{
							curr_new_credits_applied_row = Invoice.Credits_Applied();
							curr_new_credits_applied_row.CA_Apply_Credit_To_Invoice_Line_ID=curr_apply_credit_to_invoice_line.ID;
							curr_new_credits_applied_row.CA_Date=curr_apply_credit_to_invoice_line.Amount_Applied_Date;
							curr_new_credits_applied_row.CA_Credit_Note=curr_apply_credit_to_invoice_line.Credit_Note;
							curr_new_credits_applied_row.CA_Total=curr_apply_credit_to_invoice_line.Amount_Applied;
							credits_applied_total = credits_applied_total + curr_apply_credit_to_invoice_line.Amount_Applied;
							input_invoice.Credits_Applied.insert(curr_new_credits_applied_row);
						}
						input_invoice.Credits_Applied_Total=credits_applied_total;
						input_invoice.Amount_Due=input_invoice.Grand_Total - input_invoice.Amount_Paid - credits_applied_total;
					}
				}
			)
		}
	}

}

