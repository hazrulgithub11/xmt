prefill_message_and_image1 as "prefill message and image"
{
	type =  form
	form = Credit_Note

	record event = on add or edit

	on user input of Announcement
	{
		actions 
		{
			custom deluge script
			(
					// // Fetch the Announcement image based on the selected announcement
				getAnnouncement = Announcement[ID == input.Announcement];
				if(getAnnouncement != null)
				{
					input.Announcement_image = getAnnouncement.Announcement_Image;
				}
			)
		}
	}

}

