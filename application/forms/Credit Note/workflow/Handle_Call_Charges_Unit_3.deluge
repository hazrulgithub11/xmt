Handle_Call_Charges_Unit_3 as "Handle Call Charges Unit Price"
{
	type =  form
	form = Credit_Note

	record event = on add or edit

	on user input of Call_Charges.Unit_Price_Call_Charges
	{
		actions 
		{
			custom deluge script
			(
					if(ifnull(row.Unit_Price_Call_Charges,0) <= 0)
				{
					alert "Please enter a unit price more than 0";
					row.Unit_Price_Call_Charges=1;
					return;
				}
				input.User_Input_Trigger = !input.User_Input_Trigger;
			)
		}
	}

}

