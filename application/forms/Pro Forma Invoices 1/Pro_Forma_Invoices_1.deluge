	(
    	type = checkbox
		displayname = "Confirm resubmission?"
		initial value = false
	 	row = 10
	 	column = 1   
		width = medium
	)
	Invoice_Related_List
	(
		type = grid
		displayname = "Invoice Related List"
		USERNAME
		(
    		type = text
			width = medium
		)
		INVOICE_NUMBER
		(
    		type = text
			width = medium
		)
		Related_List_Date
		(
    		type = date
			displayname = "DATE"
			alloweddays = 0,1,2,3,4,5,6
			width = medium
		)
		Related_List_Time
		(
    		type = time
			displayname = "TIME"
			timedisplayoptions = "hh:mm:ss" 
			width = medium
		)
		SUBMISSION_ID
		(
    		type = text
			displayname = "SUBMISSION ID"
			width = medium
		)
		UUID
		(
    		type = url
			enable  linkname
			width = medium
		)
		PUBLIC_LINK
		(
    		type = url
			enable  linkname
			width = medium
		)
		STATUS
		(
    		type = text
			width = medium
		)
		MESSAGE
		(
    		type = textarea
			height = 100px
			width = medium
		)
	 	row = 11
	 	column = 1   
		width = medium
	)
	Decision_Section
	(
		type = section
		displayname = "Decision Section"
	 	row = 11
	 	column = 0   
		width = medium
	)
	Customer_Name_Trigger
	(
    	type = checkbox
		displayname = "Customer Name Trigger"
		initial value = false
	 	row = 12
	 	column = 1   
		width = medium
	)
	User_Input_Trigger
	(
    	type = checkbox
		initial value = false
	 	row = 12
	 	column = 1   
		width = medium
	)
	Is_Initialization
	(
    	type = checkbox
		initial value = false
	 	row = 12
	 	column = 1   
		width = medium
	)
	Credits_Applied_Trigger
	(
    	type = checkbox
		initial value = false
	 	row = 12
	 	column = 1   
		width = medium
	)
	Created_By_The_System
	(
    	type = checkbox
		displayname = "Created By The System"
		initial value = false
	 	row = 12
	 	column = 1   
		width = medium
	)
	Main_Section
	(
		type = section
		displayname = "Pro Forma Invoice Info"
	 	row = 12
	 	column = 0   
		width = medium
	)
	must have Payment_Method
	(
		type = picklist
		displayname = "Payment Method"
		maxchar = 100
		values = {"Cash","Cheque","IBFT","IBG","Foreign TT"}
	 	row = 13
	 	column = 1   
		width = medium
	)
	Status
	(
		type = picklist
		maxchar = 100
		values = {"Draft","Pending Approval","Approved","Sent","Rejected","Paid","Drawn","Resubmit","Overdue"}
		initial value = "Draft"
	 	row = 13
	 	column = 1   
		width = medium
	)
	SST_ID
	(
    	type = text
		displayname = "SST ID"
	 	row = 13
	 	column = 1   
		width = medium
	)
	
	actions
	{
		on add
		{
			submit
			(
   				type = submit
   				displayname = "Submit"
			)
			reset
			(
   				type = reset
   				displayname = "Reset"
			)
		}
		on edit
		{
			update
			(
   				type = submit
   				displayname = "Update"
			)
			cancel
			(
   				type = cancel
   				displayname = "Cancel"
			)
		}
	}
}
