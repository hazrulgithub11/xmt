form Pro_Forma_Invoices_1
{
	displayname = "Pro Forma Invoices 1"
	success message = "Pro Forma Invoice Added Successfully"
	Section
	(
		type = section
		displayname = "Supplier (From)"
		visibility = true
	 	row = 1
	 	column = 0   
		width = medium
	)
	must have Supplier
	(
		type = picklist	
		values  = Organization_Settings.ID
    	displayformat = [Organization_Name]
		sortorder = ascending
	 	row = 1
	 	column = 1   
		width = medium
	)
	must have Supplier_Business_Activity_Description
	(
    	type = text
		displayname = "Business Activity Description"
	 	row = 1
	 	column = 1   
		width = medium
	)
	must have Supplier_TIN
	(
    	type = text
		displayname = "Tax Identification Number(TIN)"
	 	row = 1
	 	column = 1   
		width = medium
	)
	must have Supplier_ID_Type
	(
    	type = text
		displayname = "ID Type"
	 	row = 1
	 	column = 1   
		width = medium
	)
	must have Supplier_Registration_Identification_Passport_Number
	(
    	type = text
		displayname = "Registration / Identification / Passport Number"
	 	row = 1
	 	column = 1   
		width = medium
	)
	must have Supplier_SST_Registration_Number
	(
    	type = text
		displayname = "SST Registration Number"
	 	row = 1
	 	column = 1   
		width = medium
	)
	must have Supplier_Telephone_Number
	(
    	type = phonenumber
		displayname = "Telephone Number"
	 	row = 1
	 	column = 1   
		width = medium
		personal data = true
	)
	Supplier_E_mail
	(
    	type = email
		displayname = "E-mail"
		maxchar = 80
	 	row = 1
	 	column = 1   
		width = medium
		personal data = true
	)
	must have Supplier_Name
	(
    	type = text
		displayname = "Name"
	 	row = 1
	 	column = 2   
		width = medium
	)
	must have Supplier_Street
	(
    	type = textarea
		displayname = "Street"
		height = 100px
	 	row = 1
	 	column = 2   
		width = medium
	)
	must have Supplier_Postcode
	(
    	type = text
		displayname = "Postcode"
	 	row = 1
	 	column = 2   
		width = medium
	)
	must have Supplier_City
	(
    	type = text
		displayname = "City"
	 	row = 1
	 	column = 2   
		width = medium
	)
	must have Supplier_State
	(
    	type = text
		displayname = "State"
	 	row = 1
	 	column = 2   
		width = medium
	)
	must have Supplier_Country
	(
    	type = text
		displayname = "Country"
	 	row = 1
	 	column = 2   
		width = medium
	)
	Buyer_To_Section
	(
		type = section
		displayname = "Buyer (To)"
		visibility = true
	 	row = 2
	 	column = 0   
		width = medium
	)
	must have Customer
	(
		type = picklist	
		displayname = "Customer Name"
		values  = Customer_Profile.ID
    	displayformat = [Customer_Name]
		sortorder = ascending
	 	row = 2
	 	column = 1   
		width = medium
	)
	must have Customer_Code
	(
		type = picklist	
		displayname = "Customer Code"
		values  = Tenancy[Customer_Name.ID == input.Customer].ID
    	displayformat = [Customer_Code]
		sortorder = ascending
	 	row = 2
	 	column = 1   
		width = medium
	)
	must have Customer_TIN
	(
    	type = text
		displayname = "Tax Identification Number(TIN)"
	 	row = 2
	 	column = 1   
		width = medium
	)
	must have Customer_ID_Type
	(
    	type = text
		displayname = "ID Type"
	 	row = 2
	 	column = 1   
		width = medium
	)
	must have Customer_Registration_Identification_Passport_Number
	(
    	type = text
		displayname = "Registration / Identification / Passport Number"
	 	row = 2
	 	column = 1   
		width = medium
	)
	must have Customer_SST_Registration_Number
	(
    	type = text
		displayname = "SST Registration Number"
	 	row = 2
	 	column = 1   
		width = medium
	)
	must have Customer_Telephone_Number
	(
    	type = phonenumber
		displayname = "Telephone Number"
	 	row = 2
	 	column = 1   
		width = medium
		personal data = true
	)
	must have Customer_E_mail
	(
    	type = email
		displayname = "E-mail"
		maxchar = 80
	 	row = 2
	 	column = 1   
		width = medium
		personal data = true
	)
	must have Customer_Name
	(
    	type = text
		displayname = "Name"
	 	row = 2
	 	column = 2   
		width = medium
	)
	must have Customer_Street
	(
    	type = textarea
		displayname = "Street"
		height = 100px
	 	row = 2
	 	column = 2   
		width = medium
	)
	must have Customer_Postcode
	(
    	type = text
		displayname = "Postcode"
	 	row = 2
	 	column = 2   
		width = medium
	)
	must have Customer_City
	(
    	type = text
		displayname = "City"
	 	row = 2
	 	column = 2   
		width = medium
	)
	must have Customer_State
	(
    	type = text
		displayname = "State"
	 	row = 2
	 	column = 2   
		width = medium
	)
	must have Customer_Country
	(
    	type = text
		displayname = "Country"
	 	row = 2
	 	column = 2   
		width = medium
	)
	Shipping_Information_Section
	(
		type = section
		displayname = "Shipping Information"
		visibility = true
	 	row = 3
	 	column = 0   
		width = medium
	)
	Delivery_Street
	(
    	type = textarea
		displayname = "Delivery Street"
		height = 100px
	 	row = 3
	 	column = 1   
		width = medium
	)
	Delivery_Postcode
	(
    	type = text
		displayname = "Delivery Postcode"
	 	row = 3
	 	column = 1   
		width = medium
	)
	Delivery_City
	(
    	type = text
		displayname = "Delivery City"
	 	row = 3
	 	column = 1   
