		width = medium
	)
	Pro_Forma_Invoice_Info
	(
		type = section
		displayname = "Pro Forma Invoice Info"
		visibility = true
	 	row = 4
	 	column = 0   
		width = medium
	)
	unique Pro_Forma_Invoice_No
	(
    	type = text
		displayname = "Pro Forma Invoice No."
    	description
    	[
    		type = tooltip
    	 	message = "Doc. No. will be generated after record is created"
    	]
	 	row = 4
	 	column = 1   
		width = medium
	)
	Invoice_UUID
	(
    	type = text
		displayname = "Invoice UUID"
	 	row = 4
	 	column = 1   
		width = medium
	)
	Invoice_UUID_Link
	(
    	type = url
		displayname = "Invoice UUID Link"
		enable  linkname
	 	row = 4
	 	column = 1   
		width = medium
	)
	Invoice_Public_Link
	(
    	type = url
		displayname = "Invoice Public Link"
		enable  linkname
	 	row = 4
	 	column = 1   
		width = medium
	)
	QR_Invoice_Public_Link
	(
		type = qrcode
		displayname = "QR Invoice Public Link"
		value = "${Invoice_Public_Link}"
	 	row = 4
	 	column = 1   
		width = medium
	)
	Subscriptions
	(
		type = list	
		values  = Subscription.ID
    	displayformat = [Customer_PO_No]
		sortorder = ascending
		height = 60px
	 	row = 4
	 	column = 2   
		width = medium
	)
	must have Pro_Forma_Invoice_Date
	(
    	type = date
		displayname = "Pro Forma Invoice Date"
		initial value = "${zoho.currentdate}"
		alloweddays = 0,1,2,3,4,5,6
	 	row = 4
	 	column = 2   
		width = medium
	)
	must have Invoice_For_Usage
	(
    	type = text
		displayname = "Invoice For Usage"
    	description
    	[
    		type = tooltip
    	 	message = "Billing Period"
    	]
	 	row = 4
	 	column = 2   
		width = medium
	)
	must have Payment_Term
	(
		type = picklist	
		displayname = "Payment Term"
		values  = Payment_Term.ID
    	displayformat = [Days]
		sortorder = ascending
	 	row = 4
	 	column = 2   
		width = medium
	)
	must have Due_Date
	(
    	type = date
		displayname = "Due Date"
		alloweddays = 0,1,2,3,4,5,6
	 	row = 4
	 	column = 2   
		width = medium
	)
	Enable_Reminder
	(
		type = picklist
		displayname = "Enable Reminder ?"
		maxchar = 100
		values = {"Yes","No"}
	 	row = 4
	 	column = 2   
		width = medium
	)
	must have Charge_Category
	(
		type = picklist
		displayname = "Charge Category"
		maxchar = 100
		values = {"Miscellaneous Charges","Fixed Charges","Telephone Charges"}
		initial value = "Miscellaneous Charges"
	 	row = 4
	 	column = 2   
		width = medium
	)
	Announcement
	(
		type = picklist	
		values  = Announcement.ID
    	displayformat = [Announcement_Message]
		sortorder = ascending
	 	row = 4
	 	column = 2   
		width = medium
	)
	Announcement_image
	(
    	type = plaintext
		value = "<div> <br /></div>"
	 	row = 4
	 	column = 2   
		width = medium
	)
	Attachment
	(
    	type = upload file
				browse = local_drive
	 	row = 4
	 	column = 2   
		width = medium
	)
	Send_Email
	(
    	type = checkbox
		displayname = "Send Email"
		initial value = false
	 	row = 4
	 	column = 2   
		width = medium
	)
	Transaction_Info
	(
		type = section
