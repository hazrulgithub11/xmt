Disable_Fields_During_Edi as "Disable Fields During Edit"
{
	type =  form
	form = Subscription

	record event = on edit

	on load
	{
		actions 
		{
			custom deluge script
			(
					disable Subcription_Line_Items.Circuit_ID;
				disable Subcription_Line_Items.Circuit_ID_Type;
				getInvoices = Invoice[Subscriptions.contains(input.ID)].ID.getAll();
				if(getInvoices.size() > 0)
				{
					disable Customer_Name;
					disable Customer_Code;
					disable Contract_Start_Date;
					disable Contract_End_Date;
					disable Contract_Period;
					disable Payment_Term;
					disable Pro_Forma_Invoices;
					disable Prorate;
					disable Subcription_Line_Items.Item;
					disable Subcription_Line_Items.Unit_Price;
					disable Subcription_Line_Items.Quantity;
					disable Subcription_Line_Items.Tax;
				}
			)
		}
		actions 
		{
			custom deluge script
			(
					if(!thisapp.permissions.isUserInProfile("Administrator"))
				{
					disable Customer_PO_No;
					disable Next_Billing_Date;
					disable Payable_To1;
					disable Contract_Start_Date;
					disable Contact;
					disable Customer_Code;
					disable Pro_Forma_Invoices;
					disable Latest_Billing_Date;
					disable Grand_Total;
					disable Contract_End_Date;
					disable Payment_Term;
					disable Final_Billing_Date;
					disable Currency;
					disable Work_Order_Type;
					disable Phone_Number;
					disable Attachment;
					disable Subscription_Status;
					disable Contract_Period;
					disable Create_Work_Order;
					disable Grand_Total_MYR;
					disable Technical_Email;
					disable Customer_Name;
					disable Subcription_Line_Items.Unit_Price;
					disable Subcription_Line_Items.Business_Unit;
					disable Subcription_Line_Items.Total;
					disable Subcription_Line_Items.Contract_Start_Date;
					disable Subcription_Line_Items.Circuit_ID_Type;
					disable Subcription_Line_Items.Circuit_ID;
					disable Subcription_Line_Items.Sub_Total;
					disable Subcription_Line_Items.Quantity;
					disable Subcription_Line_Items.Item_Code;
					disable Subcription_Line_Items.Contract_End_Date;
					disable Subcription_Line_Items.Subscription;
					disable Subcription_Line_Items.Tenant_Code;
					disable Subcription_Line_Items.Tax_Pct;
					disable Subcription_Line_Items.Item;
					disable Subcription_Line_Items.Tax_Amount;
					disable Subcription_Line_Items.Business_Segment;
					disable Subcription_Line_Items.Tax;
					disable Subcription_Line_Items.Total_MYR;
					disable Subcription_Line_Items.Customer;
					disable Subcription_Line_Items.Description;
					/* 		otherParams = Map();
				 				 						otherParamsList = List();
				 				 						otherParamsList.add("all");
				 				 						otherParams.put("skip_workflow",otherParamsList);
				 				 						updateMp = Map();
				 				 						updateMp.put("Public_User",true);
				 				 						info zoho.creator.updateRecord(zoho.adminuser,zoho.appname,"All_Subscriptions",input.ID,updateMp,otherParams,"zcreator");
				 				 						if ( input.Public_User == false ) 
				 				 					    {
				 				 							reload;
				 				 					    } */
					//input.Public_User = false;
				}
				// reload;
				// input.Public_User = true;
				//input.Public_User = false;
				/* otherParams = Map();
				 				 				otherParamsList = List();
				 				 				otherParamsList.add("all");
				 				 				otherParams.put("skip_workflow",otherParamsList);
				 				 				updateMp = Map();
				 				 				updateMp.put("Public_User",true);
				 				 				info updateMp;
				 				 				info otherParams;
				 				 				info zoho.creator.updateRecord(zoho.adminuser,zoho.appname,"All_Subscriptions",input.ID,updateMp,otherParams,"zcreator");
				 				 				resp = invokeUrl
				 				 				[
				 				 					url: "https://creator.zoho.com/api/v2"+zoho.appuri+"report/All_Subscriptions/"+input.ID
				 				 					type: GET
				 				 					connection: "zcreator"
				 				 				];
				 				 				info resp; */
			)
		}
	}

}

