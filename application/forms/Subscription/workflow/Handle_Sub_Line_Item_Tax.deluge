Handle_Sub_Line_Item_Tax as "Handle Subscription Line Item - Tax"
{
	type =  form
	form = Subscription

	record event = on add or edit

	on user input of Subscription_Line_Items.Tax_Subscription
	{
		actions 
		{
			custom deluge script
			(
							row.Tax_Type_Subscription=row.Tax_Subscription.Tax_Type;
						row.Tax_Pct_Subscription=row.Tax_Subscription.Tax_Percentage;
						input.User_Input_Trigger = !input.User_Input_Trigger;
			)
		}
	}

}

