prefill_subscription_stat1 as "prefill subscription status"
{
	type =  form
	form = Subscription

	record event = on add

	on load
	{
		actions 
		{
			custom deluge script
			(
					getOrganization = Organization_Settings[ID != null];
				input.Subscription_Status = "Active";
				input.Base_Currency = ifnull(getOrganization.Base_Currency,"MYR");
			)
		}
	}

}
