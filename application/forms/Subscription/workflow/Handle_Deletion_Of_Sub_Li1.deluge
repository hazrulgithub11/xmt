Handle_Deletion_Of_Sub_Li1 as "Handle Deletion Of Sub Line Items"
{
	type =  form
	form = Subscription

	record event = on add or edit

	on delete row of Subcription_Line_Items
	{
		actions 
		{
			custom deluge script
			(
					input.Grand_Total = ifnull(input.Grand_Total,0) - ifnull(row.Total,0);
				input.Grand_Total_MYR = ifnull(input.Grand_Total_MYR,0) - ifnull(row.Total_MYR,0);
			)
		}
	}

}

