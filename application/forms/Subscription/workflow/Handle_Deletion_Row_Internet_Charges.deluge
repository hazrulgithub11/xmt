Handle_Deletion_Row_Internet_Charges as "Handle Deletion Row Internet Charges"
{
	type =  form
	form = Subscription

	record event = on add or edit

	on delete row of Internet_Charges
	{
		actions 
		{
			custom deluge script
			(
				input.User_Input_Trigger = !input.User_Input_Trigger;
			)
		}
	}

}
