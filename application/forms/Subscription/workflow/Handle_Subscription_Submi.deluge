		actions  (Customer_Code.Bill_For == "Previous Duration" && Customer_Code.Billing_Cycle != "Monthly")
		{
			custom deluge script
			(
					getInvoices = Invoice[Subscriptions.contains(input.ID)].ID.getAll();
				if(getInvoices.size() == 0)
				{
					tenancyInfo = Tenancy[ID == input.Customer_Code];
					tenantNextBilligDate = tenancyInfo.Next_Billing_Date;
					tenantLastBillingDate = tenancyInfo.Latest_Billing_Date;
					tenantFinalBillingDate = tenancyInfo.Final_Billing_Date;
					billFor = tenancyInfo.Bill_For;
					billCycle = tenancyInfo.Billing_Cycle;
					contractStartDate = input.Contract_Start_Date;
					contractEndDate = input.Contract_End_Date;
					contractPeriod = input.Contract_Period;
					billCycleInt = thisapp.tenancy.convert_bill_cycle_to_int(billCycle);
					//info "billCycleInt:" + billCycleInt;
					//Determine The Current Billing Date
					currentBillingEveryDate = toDate(contractStartDate.getDay() + "-" + today.getMonth() + "-" + today.getYear(),"dd-MM-yyyy");
					/*Determine Next Billing And Final Billing Date */
					if(contractStartDate < today.toStartOfMonth())
					{
						//info "contract start date before today date";
						//periodBetweenStartDateAndCurrentDate = monthsBetween(contractStartDate,currentBillingEveryDate);
						//info "currentBillingEveryDate:" + currentBillingEveryDate;
						//info "periodBetweenStartDateAndCurrentDate:" + periodBetweenStartDateAndCurrentDate;
						//addMonthValue = billCycleInt * (1 + (periodBetweenStartDateAndCurrentDate / billCycleInt).toNumber());
						//info 1 + (periodBetweenStartDateAndCurrentDate / billCycleInt).toNumber();
						//info "addMonthValue:" + addMonthValue;
						addValue = ((monthsBetween(contractStartDate,today) / billCycleInt).toNumber() + 1) * billCycleInt;
						//info "addValue:" + addValue;
						nextBillingDate = contractStartDate.addMonth(addValue);
						previousBillingDate = nextBillingDate.subMonth(billCycleInt);
						//info "nextBillingDate:" + nextBillingDate;
						//info "previousBillingDate:" + previousBillingDate;
						//info "daysBetween today and nextBillingDate :" + daysBetween(today,nextBillingDate);
						if(contractStartDate.getDay() == contractStartDate.eomonth(0).getDay())
						{
							nextBillingDate = nextBillingDate.eomonth(0);
						}
						//info "nextBillingDate:" + nextBillingDate;
						contractPeriodLeft = monthsBetween(nextBillingDate,contractEndDate);
						//info "contractPeriodLeft:" + contractPeriodLeft;
						if(contractPeriodLeft > 0)
						{
							//finalBillingDate = nextBillingDate.addMonth((contractPeriodLeft / billCycleInt).toNumber() * billCycleInt + billCycleInt);
							finalBillingDate = nextBillingDate.addMonth((contractPeriodLeft / billCycleInt).toNumber() * billCycleInt);
							//info "finalBillingDate:" + finalBillingDate;
							if(contractStartDate.getDay() == contractStartDate.eomonth(0).getDay())
							{
								finalBillingDate = finalBillingDate.eomonth(0);
							}
							else
							{
								finalBillingDate = finalBillingDate;
							}
							if(contractPeriodLeft > 0)
							{
								//info "contractEndDate:" + contractEndDate;
								if(nextBillingDate.addMonth(billCycleInt) > contractEndDate)
								{
									input.Latest_Billing_Date = nextBillingDate;
									input.Final_Billing_Date = nextBillingDate;
								}
								else
								{
									input.Next_Billing_Date = nextBillingDate;
									input.Final_Billing_Date = finalBillingDate;
								}
							}
							else if(contractPeriodLeft == 0)
							{
								input.Next_Billing_Date = nextBillingDate;
								input.Final_Billing_Date = nextBillingDate;
							}
							if(daysBetween(today,nextBillingDate) <= 5)
							{
								thisapp.invoice.create_invoice_previous_not_monthly(input.ID,billCycleInt,input.Customer_Code,previousBillingDate,previousBillingDate,true,nextBillingDate,nextBillingDate);
								//thisapp.invoice.create_invoice_previous_not_monthly(input.ID,billCycleInt,input.Customer_Code,nextBillingDate,nextBillingDate,false,null,null);
							}
							else if(daysBetween(today,nextBillingDate) > 5)
							{
								thisapp.invoice.create_invoice_previous_not_monthly(input.ID,billCycleInt,input.Customer_Code,nextBillingDate,nextBillingDate,false,null,null);
							}
						}
					}
					else
					{
						//info "contract start date same month of today or later date";
						input.Next_Billing_Date = contractStartDate.addMonth(billCycleInt);
						if(contractPeriod % billCycleInt == 0)
						{
							finalBillingDate = contractStartDate.addMonth(contractPeriod);
						}
						else
						{
							finalBillingDate = contractStartDate.addMonth((1 + (contractPeriod / billCycleInt).toNumber()) * billCycleInt);
						}
						if(contractStartDate.getDay() == contractStartDate.eomonth(0).getDay())
						{
							input.Final_Billing_Date = finalBillingDate.eomonth(0);
						}
						else
						{
							input.Final_Billing_Date = finalBillingDate;
						}
						if(daysBetween(today,input.Next_Billing_Date) <= 5)
						{
							thisapp.invoice.create_invoice_previous_not_monthly(input.ID,billCycleInt,input.Customer_Code,previousBillingDate,previousBillingDate,false,null,null);
						}
					}
				}
			)
		}
