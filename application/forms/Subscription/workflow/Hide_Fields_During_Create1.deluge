Hide_Fields_During_Create1 as "Hide Fields During Create"
{
	type =  form
	form = Subscription

	record event = on add

	on load
	{
		actions 
		{
			custom deluge script
			(
					hide Next_Billing_Date;
				hide Latest_Billing_Date;
				hide Final_Billing_Date;
				hide Prorate;
				hide Prorate_Note;
				hide User_Input_Trigger;
			)
		}
	}

}

