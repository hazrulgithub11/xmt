Handle_Invoice_Creation2 as "Handle Invoice Creation"
{
	type =  form
	form = Debit_Note

	record event = on add

	on success
	{
		actions 
		{
			custom deluge script
			(
					input.Invoice_No = thisapp.debit_note.generate_debit_note_no();
			)
		update Debit_Note[ID == input.ID]
		[
			Status = "Draft"
		]
		}
	}

}

