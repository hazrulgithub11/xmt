Handle_Invoice_Creation2 as "Handle Invoice Creation"
{
	type =  form
	form = Debit_Note

	record event = on add

	on success
	{
		actions 
		{
			custom deluge script
			(
					dnNo = thisapp.debit_note.generate_debit_note_no();
				update Debit_Note[ID == input.ID]
				[
					Invoice_No = dnNo
				];
				// Debit_Note_Blueprint start stage is already "Draft" on form add.
				// changeStage to Draft here fails: record is not yet active on the blueprint.
			)
		}
	}

}
