	actions
	{
		on add
		{
			submit
			(
   				type = submit
   				displayname = "Submit"
			)
			reset
			(
   				type = reset
   				displayname = "Reset"
			)
		}
		on edit
		{
			update
			(
   				type = submit
   				displayname = "Update"
			)
			cancel
			(
   				type = cancel
   				displayname = "Cancel"
			)
		}
	}
	blueprint components
	{
		stages = {"Draft","Pending Approval","Rejected","Approved","Sent","Partially Paid","Paid","Overdue"}
	}
}
