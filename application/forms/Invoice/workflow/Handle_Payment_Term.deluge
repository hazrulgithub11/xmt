Handle_Payment_Term as "Handle Payment Term"
{
	type =  form
	form = Invoice

	record event = on add or edit

	on user input of Payment_Term
	{
		actions 
		{
			custom deluge script
			(
								if(input.Invoice_Date != null && input.Payment_Term != null)
							{
								input.Due_Date = input.Invoice_Date.addDay(input.Payment_Term.Days);
							}
			)
		}
	}

}

