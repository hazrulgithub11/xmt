Handle_Update_Overdue_Cha as "Handle Update Overdue Charges"
{
	type =  form
	form = Invoice

	record event = on edit
		status = inactive

	on success
	{
		actions  (Blueprint.Current_Stage == "Draft" || Blueprint.Current_Stage == "Approved" || Blueprint.Current_Stage == "Pending Approval")
		{
			custom deluge script
			(
								thisapp.invoice.recalculate_overdue(input.Customer_Code,input.ID);
			)
		}
	}

}

