Load_of_the_form_Initiali as "Load of the form Initialization"
{
	type =  form
	form = Invoice

	record event = on add or edit

	on load
	{
		actions 
		{
			custom deluge script
			(
					/* Credits Applied Initialization */
				input.Is_Initialization = true;
				input.User_Input_Trigger = !input.User_Input_Trigger;
				/* Customer Name Trigger Initialization*/
				input.Customer_Name_Trigger = !input.Customer_Name_Trigger;
				if(input.Customer != null)
				{
					exclude_invoice_id = ifnull(input.ID,0);
					input.Previous_Balance = thisapp.invoice.get_previous_balance_for_customer(input.Customer,exclude_invoice_id);
					input.Total_Amount_Due = ifnull(input.Amount_Due,0) + ifnull(input.Previous_Balance,0);
				}
				/* Payment Received Line Item — only for saved invoices */
				if(input.ID != null && input.ID != 0)
				{
					invoice_Payments_Received_Line_Item_list = Payment_Received_Line_Item[Invoice_No == input.ID];
					for each  curr_invoice_Payments_Received_Line_Item in invoice_Payments_Received_Line_Item_list
					{
						curr_invoice_Payments_Received_Line_Item_row = Invoice.Payments_Received_Line_Item();
						curr_invoice_Payments_Received_Line_Item_row.Amount=curr_invoice_Payments_Received_Line_Item.Amount;
						curr_invoice_Payments_Received_Line_Item_row.Outstanding_Balance=curr_invoice_Payments_Received_Line_Item.Outstanding_Balance;
						curr_invoice_Payments_Received_Line_Item_row.Allocation=curr_invoice_Payments_Received_Line_Item.Allocation;
						curr_invoice_Payments_Received_Line_Item_row.Allocation_MYR=curr_invoice_Payments_Received_Line_Item.Allocation_MYR;
						curr_invoice_Payments_Received_Line_Item_row.Still_Owing=curr_invoice_Payments_Received_Line_Item.Still_Owing;
						curr_invoice_Payments_Received_Line_Item_row.Payment_Received=curr_invoice_Payments_Received_Line_Item.Payment_Received;
						input.Payments_Received_Line_Item.insert(curr_invoice_Payments_Received_Line_Item_row);
					}
				}
			)
		}
	}

}

