Handle_Customer_Code_Chan as "Handle Customer Code Changes"
{
	type =  form
	form = Invoice

	record event = on add or edit

	on user input of Customer_Code
	{
		actions 
		{
			custom deluge script
			(
					tenancyInfo = Tenancy[ID == input.Customer_Code];
				input.Enable_Reminder = ifnull(tenancyInfo.Enable_Reminder,null);
				input.Payable_To = ifnull(tenancyInfo.Payable_To,null);
				input.Payment_Term = ifnull(tenancyInfo.Payment_Term,null);
				if(input.Invoice_Date != null && input.Customer_Code != null && input.Payment_Term != null)
				{
					input.Due_Date = input.Invoice_Date.addDay(input.Payment_Term.Days);
				}
				if(input.Customer_Code == null)
				{
					input.Due_Date = null;
					input.Enable_Reminder = "";
					input.Previous_Balance = 0;
					input.Total_Amount_Due = ifnull(input.Amount_Due,0);
				}
				else if(input.Customer != null)
				{
					exclude_invoice_id = ifnull(input.ID,0);
					input.Previous_Balance = thisapp.invoice.get_previous_balance_for_customer(input.Customer,exclude_invoice_id);
					input.Total_Amount_Due = ifnull(input.Amount_Due,0) + ifnull(input.Previous_Balance,0);
				}
			)
		}
	}

}

