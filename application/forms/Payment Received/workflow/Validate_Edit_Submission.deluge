Validate_Edit_Submission as "Validate Edit Submission"
{
	type =  form
	form = Payment_Received

	record event = on add or edit

	on validate
	{
		actions 
		{
			custom deluge script
			(
					noPaymentReceivedLineItem = true;
				for each  paymentReceivedLineItem in input.Payment_Received_Line_Item
				{
					if(paymentReceivedLineItem.Allocation != null)
					{
						noPaymentReceivedLineItem = false;
						break;
					}
				}
				if(noPaymentReceivedLineItem == true)
				{
					if(input.Payment_Type == "Invoice/Debit Note")
					{
						alert "Cannot record payment: No available invoices / debit notes to apply this payment. Please ensure there is an open invoice / debit note for this customer before submitting.";
					}
					else if(input.Payment_Type == "Deposit")
					{
						alert "Cannot record payment: No available deposits to apply this payment. Please ensure there is an open deposits for this customer before submitting.";
					}
					cancel submit;
				}
			)
		}
	}

}

