Field_Rules_Payment_Type as "Field Rules Payment Type"
{
	type =  form
	form = Payment_Received

	record event = on add

	field rules
	{
		actions  (Payment_Type is null || Payment_Type == "")
		{
			hide Customer_Name,Customer_TIN,Customer_SST,Customer_Code,Payment_Date,Payment_Method,Paid_To,Reference,Payment_Received_Line_Item,Amount_Received,Exchange_Rate,Amount_Received_MYR,Customer_Email,Currency;
		}
	}

}

