Disable_Fields12 as "Disable Fields"
{
	type =  form
	form = Payment_Received

	record event = on edit

	on load
	{
		actions 
		{
			custom deluge script
			(
					disable Customer_Name;
				disable Customer_Code;
				disable Payment_Type;
				disable Payment_Received_Line_Item.Allocation;
				disable Payment_Received_Line_Item.Description;
				disable Paid_To;
				disable Payment_Date;
				disable Payment_Method;
			)
		}
	}

}

