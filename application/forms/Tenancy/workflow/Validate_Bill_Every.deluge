Validate_Bill_Every as "Validate Bill Every"
{
	type =  form
	form = Tenancy

	record event = on add or edit

	on validate
	{
		actions  (Billing_Cycle == "Monthly" && Bill_Every is null)
		{
			custom deluge script
			(
					alert(Bill_Every,"This field is mandatory. Enter a value.");
				cancel submit;
			)
		}
	}

}

