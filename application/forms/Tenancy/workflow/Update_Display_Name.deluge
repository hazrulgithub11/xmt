Update_Display_Name as "Update Display Name"
{
	type =  form
	form = Tenancy

	record event = on add or edit

	on validate
	{
		actions 
		{
			custom deluge script
			(
					if(input.Tenant_Name.toUpperCase() == Customer_Name.Customer_Name.toUpperCase())
				{
					input.Display_Name = input.Customer_Name.Customer_Name;
				}
				else
				{
					input.Display_Name = input.Customer_Name.Customer_Name + " - " + input.Tenant_Name;
				}
			)
		}
	}

}

