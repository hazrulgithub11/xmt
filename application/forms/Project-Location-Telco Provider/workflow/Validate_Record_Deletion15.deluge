Validate_Record_Deletion15 as "Validate Record Deletion"
{
	type =  form
	form = Project_Location_Telco_Provider

	record event = on delete

	on validate
	{
		actions 
		{
			custom deluge script
			(
					getTenants = Tenancy[Project_Location_Telco_Provider == input.ID].ID.getAll();
				if(getTenants.size() > 0)
				{
					alert "This record can’t be deleted because it’s used in tenancies module.";
					cancel delete;
				}
			)
		}
	}

}

