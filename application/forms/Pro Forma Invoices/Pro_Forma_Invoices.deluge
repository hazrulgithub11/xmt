		form Pro_Forma_Invoices
		{
			displayname = "Pro Forma Invoices"
			success message = "Deposit Added Successfully"
			Main_Section
			(
				type = section
				displayname = "Main Section"
	 			row = 1
	 			column = 0   
				width = medium
			)
			Supplier_TIN
			(
    			type = text
				displayname = "Supplier TIN"
	 			row = 1
	 			column = 1   
				width = medium
			)
			SST_ID
			(
    			type = text
				displayname = "SST ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			unique Pro_Forma_Invoice_No
			(
    			type = text
				displayname = "Pro Forma Invoice No."
    			description
    			[
    				type = tooltip
    			 	message = "Doc. No. will be generated after record is created"
    			]
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Customer_Name
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customer_Profile.ID
    			displayformat = [Customer_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Customer_Email
			(
    			type = email
				displayname = "Customer Email"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Customer_TIN
			(
    			type = text
				displayname = "Customer TIN"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_SST
			(
    			type = text
				displayname = "Customer SST"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Customer_Code
			(
				type = picklist	
				displayname = "Customer Code"
				values  = Tenancy[Customer_Name.ID == input.Customer_Name].ID
    			displayformat = [Customer_Code]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Draft","Pending Approval","Approved","Sent","Rejected","Paid","Drawn","Resubmit","Overdue"}
				initial value = "Draft"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Pro_Forma_Invoice_Date
			(
    			type = date
				displayname = "Pro Forma Invoice Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Payment_Term
			(
				type = picklist	
				displayname = "Payment Term"
				values  = Payment_Term.ID
    			displayformat = [Days]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Due_Date
			(
    			type = date
				displayname = "Due Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Payment_Method
			(
				type = picklist
				displayname = "Payment Method"
				maxchar = 100
				values = {"Cash","Cheque","IBFT","IBG","Foreign TT"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Payable_To1
			(
				type = list	
				displayname = "Payable To"
				values  = Chart_Of_Account[Account_Type == "Bank"].ID
    			displayformat = [Account + " - " + Bank_Account_Number]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 2   
				width = medium
			)
			Pro_Forma_Invoice_Line_Item
			(
				type = grid
				displayname = "Pro Forma Invoice Line Item"
				values  = Pro_Forma_Invoices_Line_Item.ID
    			bidirectional = Pro_Forma_Invoice
	 			row = 2
	 			column = 1   
				width = medium
			)
			Total_Section
			(
				type = section
				displayname = "Total Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Sub_Total
			(
				type = decimal
				displayname = "Sub Total"
				format = commadotwestern
				initial value = 0
	 			row = 3
	 			column = 1   
				width = medium
			)
			Total_Tax
			(
				type = decimal
				displayname = "Total Tax"
				format = commadotwestern
				initial value = 0
	 			row = 3
	 			column = 1   
				width = medium
			)
			Grand_Total
			(
				type = decimal
				displayname = "Grand Total"
				format = commadotwestern
				initial value = 0
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Currency
			(
				type = picklist
				maxchar = 100
				values = {"AED","AFN","ALL","AMD","ANG","AOA","ARS","AUD","AWG","AZN","BAM","BBD","BDT","BGN","BHD","BIF","BMD","BND","BOB","BOV","BRL","BSD","BTN","BWP","BYN","BZD","CAD","CDF","CHE","CHF","CHW","CLF","CLP","CNH","CNY","COP","COU","CRC","CUC","CUP","CVE","CZK","DJF","DKK","DOP","DZD","EGP","ERN","ETB","EUR","FJD","FKP","GBP","GEL","GHS","GIP","GMD","GNF","GTQ","GYD","HKD","HNL","HTG","HUF","IDR","ILS","INR","IQD","IRR","ISK","JMD","JOD","JPY","KES","KGS","KHR","KMF","KPW","KRW","KWD","KYD","KZT","LAK","LBP","LKR","LRD","LSL","LYD","MAD","MDL","MGA","MKD","MMK","MNT","MOP","MRU","MUR","MVR","MWK","MXN","MXV","MYR","MZN","NAD","NGN","NIO","NOK","NPR","NZD","OMR","PAB","PEN","PGK","PHP","PKR","PLN","PYG","QAR","RON","RSD","RUB","RWF","SAR","SBD","SCR","SDG","SEK","SGD","SHP","SLE","SLL","SOS","SRD","SSP","STN","SVC","SYP","SZL","THB","TJS","TMT","TND","TOP","TRY","TTD","TWD","TZS","UAH","UGX","USD","USN","UYI","UYU","UYW","UZS","VED","VES","VND","VUV","WST","XAF","XAG","XAU","XBA","XBB","XBC","XBD","XCD","XDR","XOF","XPD","XPF","XPT","XSU","XUA","XXX","YER","ZAR","ZMW","ZWL"}
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Exchange_Rate
			(
				type = decimal
				displayname = "Exchange Rate"
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Grand_Total_MYR
			(
				type = decimal
				displayname = "Grand Total(MYR)"
				format = commadotwestern
				initial value = 0
	 			row = 3
	 			column = 1   
				width = medium
			)
			Amount_Due
			(
				type = decimal
				displayname = "Amount Due"
				format = commadotwestern
				initial value = 0
	 			row = 3
	 			column = 1   
				width = medium
			)
			Amount_Paid
			(
				type = decimal
				displayname = "Amount Paid"
				format = commadotwestern
				initial value = 0
	 			row = 3
	 			column = 1   
				width = medium
			)
			Reject_Section
			(
				type = section
				displayname = "Reject Section"
	 			row = 4
	 			column = 0   
				width = medium
			)
			Rejection_Reason
			(
    			type = textarea
				displayname = "Rejection Reason"
				height = 100px
	 			row = 4
	 			column = 1   
				width = medium
			)
			Confirm_resubmission
			(
    			type = checkbox
				displayname = "Confirm resubmission?"
				initial value = false
	 			row = 4
	 			column = 1   
				width = medium
			)
			System_Section
			(
				type = section
				displayname = "System Section"
	 			row = 5
	 			column = 0   
				width = medium
			)
			Organization
			(
				type = picklist	
				values  = Organization_Settings.ID
    			displayformat = [Organization_Name]
				sortorder = ascending
	 			row = 5
	 			column = 1   
				width = medium
			)
			Send_Email
			(
    			type = checkbox
				displayname = "Send Email"
				initial value = false
	 			row = 5
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Draft","Pending Approval","Approved","Rejected"}
			}
		print template
			{
				PI_TEST_Footer
				{
							displayname = "PI TEST Footer"
							content = {"pageNumberOption":null,"orientation":"null","images":[{"fileName":"","imageId":"","imageType":"","fileId":""},{"fileName":"1728870692867_XMT_logo.png","imageId":"img_23764415999999642","imageType":"upload","fileId":"6069490000000054013"},{"fileName":"","imageId":"","imageType":"","fileId":""}],"imageId":"","isFooterEnabled":true,"footer":{"imageId":"","elements":[{"type":"columns","element":{"split":"100","id":"u_elem_12878410000002384","elemStyle":"","collayouts":[{"colElements":[{"type":"text","element":{"Fields":[{"Related_Fields":["Organization_Name"],"Label_Name":"Organization"}],"content":"<div style=\"\">\n   <table\n    style=\"margin: 0px auto; width: 100%; border: none\"\n          cellspacing=\"0\">\n    <tbody>\n     <tr>\n      <td\n          style=\"padding: 5px; width: 50%\" width=\"50%\"><font\n            style=\"font-size: 10px\"\n          face=\"arimo\">For direct bank-in, payments are to be made to :<\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left; padding: 5px\"><font\n            style=\"font-size: 10px\"\n                face=\"arimo\">Beneficiary Name :&nbsp; <b><font\n            color=\"#000000\">${Organization.Organization_Name}<\/font><\/b> <\/font><span style=\"font-size: 12px; color: rgb(68, 68, 68); font-family: Lato, Arimo, sans-serif; font-weight: 400; font-style: normal\">&nbsp; <br /><\/span><\/td>\n     <\/tr>\n    <\/tbody>\n   <\/table>\n  <\/div>"}},{"id":"u_elem_136137561487673261","type":"lookupfields","element":{"valueStyle":"width: 50%","valueTextStyle":"font-family: Arimo; font-size: 10px","fieldLayoutType":"1","related_Form":"Chart_Of_Account","labelText":"Payable To","wrapperStyle":"","labelStyle":"width: 50%; display: none","Label_Name":"Payable_To1","refFields":[{"valueStyle":"                        ","fieldLayoutType":"2","labelText":"Account","labelStyle":"background-color: rgba(0, 0, 0, 0)","Label_Name":"Account"},{"valueStyle":"                        ","f