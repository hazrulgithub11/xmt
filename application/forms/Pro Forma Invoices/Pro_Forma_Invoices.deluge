-size: 10px\" face=\"arimo\"><span\n        style=\"color: rgb(68, 68, 68); font-style: normal\"><b\n      style=\"font-size: 10px\">${Organization.Organization_Name}<\/b><\/span> <\/font>\n   <div>\n    <font\n      style=\"font-size: 10px\" face=\"arimo\"><font\n          style=\"font-size: 10px\">Company No:&nbsp;&nbsp; ${Organization.Company_Registration_Number} <span\n      style=\"color: rgb(68, 68, 68); font-weight: 400; font-style: normal\">&nbsp;<\/span> <\/font> <\/font>\n   <\/div>\n   <div>\n    <font\n      style=\"font-size: 12px\"><\/font> <font\n      style=\"font-size: 12px\"> <br /><\/font> <font\n      style=\"font-size: 10px\" face=\"arimo\"><span> <font\n            style=\"font-size: 10px\"> ${Organization.Street}, ${Organization.Postcode} <span\n        style=\"color: rgb(68, 68, 68); font-weight: 400; font-style: normal\">&nbsp;,<\/span> <\/font> <\/span> <span\n        style=\"letter-spacing: 0px; text-decoration-style: solid; text-decoration-color: rgb(68, 68, 68)\">${Organization.City}<\/span> <span\n        style=\"letter-spacing: 0px; text-decoration-style: solid; text-decoration-color: rgb(68, 68, 68)\">&nbsp;,<\/span> <span\n        style=\"letter-spacing: 0px; text-decoration-style: solid; text-decoration-color: rgb(68, 68, 68)\">${Organization.State},<\/span> <span\n        style=\"letter-spacing: 0px; text-decoration-style: solid; text-decoration-color: rgb(68, 68, 68)\">${Organization.Country}<\/span> <span style=\"letter-spacing: 0px; text-decoration-style: solid; text-decoration-color: rgb(68, 68, 68)\">&nbsp;<\/span><\/font>\n   <\/div>\n  <\/div>"}},{"type":"text","element":{"Fields":[{"Related_Fields":["Company_Email"],"Label_Name":"Organization"},{"Related_Fields":["Company_Fax"],"Label_Name":"Organization"},{"Related_Fields":["Company_Phone_Number"],"Label_Name":"Organization"},{"Related_Fields":["Company_Website"],"Label_Name":"Organization"}],"content":"<div style=\"\">\n   <table cellspacing=\"0\"\n          style=\"margi