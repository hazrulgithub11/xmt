}],"content":"<div style=\"\">\n   <table cellspacing=\"0\"\n          style=\"margin: 0px auto; width: 100%; border: 0; border-collapse: collapse\">\n    <tbody>\n     <tr>\n      <td\n          width=\"50%\" style=\"text-align: center\"><font color=\"#000000\"\n            style=\"font-size: 10px\" face=\"arimo\"> <font\n                style=\"font-size: 10px\"> ${Organization.Organization_Name} <span\n          style=\"font-weight: 400; font-style: normal\">&nbsp; <span>${Organization.Company_Registration_Number}<\/span> <\/span> <br /><\/font> <\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: center\"><font color=\"#000000\"\n            style=\"font-size: 10px\" face=\"arimo\"> <font\n                style=\"\"> <span>${Organization.Street}<\/span> <span\n                  style=\"font-weight: 400; font-style: normal\">, <span>${Organization.Postcode}<\/span> <span\n                    style=\"font-weight: 400; font-style: normal\">, <span>${Organization.City}<\/span> <span\n                      style=\"font-weight: 400; font-style: normal\">, <span>${Organization.State}<\/span> <span\n          style=\"font-weight: 400; font-style: normal\">, <span>${Organization.Country}<\/span> <\/span> <\/span> <\/span> <\/span> <br /><\/font> <\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: center\"><font color=\"#000000\"\n              style=\"\"><font style=\"font-size: 10px\" face=\"arimo\"> <font\n              style=\"\">Free.Komm Helpdesk:&nbsp; <span>${Organization.Helpdesk}<\/span> <\/font> <\/font><span\n                style=\"font-weight: 400; font-style: normal\"><font\n                style=\"font-size: 10px\" face=\"arimo\"> <\/font><font\n                  style=\"\"><font style=\"font-size: 10px\"\n                    face=\"arimo\">&nbsp;Fax:&nbsp; ${Organization.Company_Phone_Number} <span style=\"font-weight: 400; font-style: normal\">&nbsp;Email: cco@xmt.com.my<\/span><\/font> <\/font