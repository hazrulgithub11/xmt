Validation_Based_On_Statu3 as "Validation Based On Status"
{
	type =  form
	form = Pro_Forma_Invoices

	record event = on edit

	on validate
	{
		actions  (Status == "Rejected")
		{
			custom deluge script
			(
					if(input.Confirm_resubmission == false)
				{
					alert(Confirm_resubmission,"Please check to confirm resubmission");
					cancel submit;
				}
			)
		}
		actions  (Status == "Pending Approval")
		{
			custom deluge script
			(
					if(input.Rejection_Reason == "")
				{
					alert(Rejection_Reason,"This field is mandatory. Enter a value.");
					cancel submit;
				}
			)
		}
	}

}

