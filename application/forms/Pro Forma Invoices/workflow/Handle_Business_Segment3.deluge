Handle_Business_Segment3 as "Handle Business Segment"
{
	type =  form
	form = Pro_Forma_Invoices

	record event = on add or edit

	on user input of Pro_Forma_Invoice_Line_Item.Business_Segment
	{
		actions 
		{
			custom deluge script
			(
					if(row.Business_Segment != null)
				{
					getBusinessUnits = Business_Unit[Business_Segment == row.Business_Segment].ID.getAll();
					row.Business_Unit:ui.add(getBusinessUnits);
				}
				else
				{
					clear row.Business_Unit;
				}
			)
		}
	}

}

