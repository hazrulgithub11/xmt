Validate_Record_Deletion7 as "Validate Record Deletion"
{
	type =  form
	form = Chart_Of_Account

	record event = on delete

	on validate
	{
		actions 
		{
			custom deluge script
			(
					invoice_list = Invoice[Payable_To == input.ID].ID.getAll();
				credit_note_list = Credit_Note[Payable_To == input.ID].ID.getAll();
				debit_note_list = Debit_Note[Payable_To == input.ID].ID.getAll();
				pro_forma_invoice_list = Pro_Forma_Invoices[Payable_To.contains(input.ID)].ID.getAll();
				payment_received_list = Payment_Received[Paid_To == input.ID].ID.getAll();
				tenancy_list = Tenancy[Payable_To.contains(input.ID)].ID.getAll();
				subscription_list = Subscription[Payable_To.contains(input.ID)].ID.getAll();
				journal_entry_line_item_list = Journal_Entry_Line_Item[Account == input.ID].ID.getAll();
				if(invoice_list.size() > 0 || credit_note_list.size() > 0 || debit_note_list.size() > 0 || pro_forma_invoice_list.size() > 0 || payment_received_list.size() > 0 || tenancy_list.size() > 0 || subscription_list.size() > 0 || journal_entry_line_item_list.size() > 0)
				{
					alert "This account can't be deleted because it's used in another module.";
					cancel delete;
				}
			)
		}
	}

}

