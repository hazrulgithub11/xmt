			Handle_Credits_To_Apply as "Handle Credits To Apply"
			{
				type =  form
				form = Apply_Credit_To_Invoices

				record event = on add or edit

				on user input of Unpaid_Invoices.Credits_To_Apply
				{
					actions 
					{
						custom deluge script
						(
											if(row.Credits_To_Apply > row.Amount_Due)
										{
											alert "The credit amount cannot exceed the invoice’s outstanding balance.";
											row.Credits_To_Apply=0;
										}
						)
					}
				}

			}
			Validations_on_invoice_de as "Validations on invoice deletion"
			{
				type =  form
				form = Invoice

				record event = on delete

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// Payments Received
										get_payment_received_line_items = Payment_Received_Line_Item[Invoice_No == input.ID].ID.getAll();
										if(get_payment_received_line_items.size() > 0)
										{
											alert "This invoice has payments applied. Remove all associated payments before deleting the invoice.";
											cancel delete;
										}
										// Reference Debit Note 
										reference_debit_note_list = Debit_Note[Reference_Invoice == input.ID].ID.getAll();
										if(reference_debit_note_list.size() > 0)
										{
											alert "This invoice has debit notes applied. Remove all associated debit notes before deleting the invoice.";
											cancel delete;
										}
										// Reference Credit Note
										reference_credit_note_list = Apply_Credit_To_Invoice_Line[Invoice == input.ID].ID.getAll();
										if(reference_credit_note_list.size() > 0)
										{
											alert "This invoice has credits applied. Remove all associated credits before deleting the invoice.";
											cancel delete;
										}
						)
					}
				}

			}
