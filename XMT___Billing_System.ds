			Load_of_the_invoice_creat as "Load of the invoice created"
			{
				type =  form
				form = Invoice

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											// Organization info 
										get_organization = Organization_Settings[ID != null];
										input.Supplier = get_organization.ID;
										input.Supplier_Name = get_organization.Organization_Name;
										input.Supplier_TIN = get_organization.Supplier_TIN;
										input.Supplier_ID_Type = get_organization.Company_Registration_Number_Scheme;
										input.Supplier_Registration_Identification_Passport_Number = get_organization.Company_Registration_Number;
										input.Supplier_SST_Registration_Number = get_organization.SST_ID;
										input.Supplier_Business_Activity_Description = get_organization.MSIC_Description;
										input.Supplier_E_mail = get_organization.Company_Email;
										input.Supplier_Telephone_Number = get_organization.Company_Phone_Number;
										input.Supplier_Street = get_organization.Street;
										input.Supplier_City = get_organization.City;
										input.Supplier_Postcode = get_organization.Postcode;
										input.Supplier_Country = get_organization.Country;
										input.Supplier_State = get_organization.State;
										input.Base_Currency = get_organization.Base_Currency;
										input.Invoice_Date = zoho.currentdate;
										input.Invoice_For_Usage = thisapp.get_invoice_usage(zoho.currentdate);
										hide Invoice_No;
						)
					}
				}

			}
