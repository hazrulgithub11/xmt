			Refund1 as "Refund"
			{
				type =  functions
				form = Pro_Forma_Invoices
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						journalEntryLineItem = Collection();
										row1 = Journal_Entry.Journal_Entry_Line_Item();
										row1.Account=4662372000000087213;
										row1.Description="Pro Forma Invoice " + input.Invoice_No + " Xkomm Security Deposit";
										row1.Debit=ifnull(input.Grand_Total,0);
										row1.Credit=0;
										row2 = Journal_Entry.Journal_Entry_Line_Item();
										getPRLineItem = Payment_Received_Line_Item[Pro_Forma_Invoice_No == input.ID];
										getPR = Payment_Received[ID == getPRLineItem.Payment_Received];
										row2.Account=getPR.Paid_To;
										row2.Description="Pro Forma Invoice " + input.Invoice_No + " to " + getPR.Paid_To.Account + "-" + getPR.Paid_To.Bank_Account_Number;
										row2.Debit=0;
										row2.Credit=ifnull(input.Grand_Total,0);
										journalEntryLineItem.insert(row1,row2);
										newJournalEntryRecord = insert into Journal_Entry
										[
											Journal_Entry_No=thisapp.journal_entry.generate_journal_no()
											Document_No=input.Invoice_No
											Added_User=zoho.loginuser
											Deposits=input.ID
											Date_field=zoho.currentdate
											Journal_Entry_Line_Item=journalEntryLineItem
											Sub_Total_Debit=ifnull(input.Sub_Total,0)
											Sub_Total_Credit=ifnull(input.Grand_Total,0) - ifnull(input.Total_Tax,0)
											Total_Debit=ifnull(input.Grand_Total,0)
											Total_Credit=ifnull(input.Grand_Total,0)
											Difference=ifnull(input.Grand_Total,0) - ifnull(input.Grand_Total,0)
											Created_By_The_System=true
										];
					)
					}
				}
			}
			Record_Payment_Deposit1 as "Record_Payment_Deposit"
			{
				type =  functions
				form = Pro_Forma_Invoices
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						paymentType = "Payment_Type=Deposit";
										customerName = "&Customer_Name=" + input.Customer;
										customerCode = "&Customer_Code=" + input.Customer_Code;
										customerTIN = "&Customer_TIN=" + ifnull(input.Customer_TIN,"");
										customerSST = "&Customer_SST=" + ifnull(input.Customer_SST_Registration_Number,"");
										customerEmail = "&Customer_Email=" + ifnull(input.Customer_E_mail,"");
										paymentReceivedCurrency = "&Payment_Received_Currency=" + ifnull(input.Invoice_Currency,"");
										singlePaymentRecord = "&Single_Record_Payment=true";
										paymentTypeSingleRecord = "&Payment_Type_Single_Record=Pro Forma Invoice";
										pi = "&Pro_Forma_Invoices=" + input.ID;
										url = "#Form:Payment_Received?" + paymentType + customerName + customerCode + customerTIN + customerSST + customerEmail + paymentReceivedCurrency + singlePaymentRecord + paymentTypeSingleRecord + pi;
										openUrl(url,"popup window","height=100%,width=100%");
					)
					}
				}
			}
			Send_Email as "Send_Email"
			{
				type =  functions
				form = Pro_Forma_Invoices
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						openUrl("#Form:Email_Input_Form?Record_ID=" + input.ID + "&Document_Type=Pro Forma Invoices","popup");
					)
					}
				}
			}
			Create_Account_in_Desk as "Create_Account_in_Desk"
			{
				type =  functions
				form = Tenancy
				execution type = for each record	
				on start
				{
					actions 
					{
						thisapp.tenancy.create_account_desk(ID);
					}
				}
			}
			terminate_subscription as "terminate_subscription"
			{
				type =  functions
				form = Subscription
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						subscription_id = input.ID;
										termination_date = today;
										current_subscription = Subscription[ID == subscription_id];
										/* Guard: only Active subscriptions can be terminated */
										if(current_subscription.Subscription_Status != "Active")
										{
											return;
										}
										tenancy_id = current_subscription.Customer_Code;
										tenancy_info = Tenancy[ID == tenancy_id];
										bill_for = input.Bill_For;
										last_billing_date = current_subscription.Latest_Billing_Date;
										contract_start_date = current_subscription.Contract_Start_Date;
										exchange_rate = current_subscription.Exchange_Rate;
										currency = current_subscription.Subscription_Currency;
										/* For Previous Duration only: create a final prorate invoice for the unbilled period */
										if(bill_for == "Previous Duration")
										{
											period_start = last_billing_date;
											if(period_start == null)
											{
												/* Never invoiced — bill from contract start */
												period_start = contract_start_date;
											}
											if(period_start < termination_date)
											{
												/* Look up any pro-forma deposit already collected */
												pi_grand_total = Pro_Forma_Invoices[ID == current_subscription.Pro_Forma_Invoices].Grand_Total;
												total_deposit_amount = ifnull(pi_grand_total,0);
												/* Compute prorated totals from period_start to termination_date using 30-day basis */
												totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"days30",exchange_rate,period_start,termination_date,false);
												grand_total = totals.get("grand_total");
												sum_sub_total = totals.get("sum_sub_total");
												total_tax = totals.get("total_tax");
												sub_total_monthly_rental = totals.get("sub_total_monthly_rental");
												total_tax_monthly_rental = totals.get("total_tax_monthly_rental");
												grand_total_monthly_rental = totals.get("grand_total_monthly_rental");
												sub_total_internet_charges = totals.get("sub_total_internet_charges");
												total_tax_internet_charges = totals.get("total_tax_internet_charges");
												grand_total_internet_charges = totals.get("grand_total_internet_charges");
												sub_total_call_charges = totals.get("sub_total_call_charges");
												total_tax_call_charges = totals.get("total_tax_call_charges");
												grand_total_call_charges = totals.get("grand_total_call_charges");
												inv_no = thisapp.invoice.generate_invoice_number();
												invoice_usage = thisapp.get_invoice_usage(period_start);
												organization_info = Organization_Settings[ID != null];
												customer = tenancy_info.Customer_Name;
												customer_email_address = customer.Email_Address;
												customer_profile_info = Customer_Profile[ID == customer];
												due_date = termination_date.addDay(tenancy_info.Payment_Term.Days);
												error_msg = "";
												try 
												{
													create_invoice = insert into Invoice
													[
														Invoice_No=inv_no
														Payment_Term=tenancy_info.Payment_Term
														Customer_Code=tenancy_id
														Customer=customer
														Customer_TIN=customer_profile_info.Customer_TIN
														Customer_SST_Registration_Number=ifnull(customer_profile_info.Customer_SST,"")
														Customer_E_mail=customer_email_address
														Customer_Registration_Identification_Passport_Number=ifnull(customer_profile_info.Customer_Registration_Number,"")
														Customer_Street=ifnull(customer_profile_info.Business_Street,"")
														Customer_Postcode=ifnull(customer_profile_info.Postcode,"")
														Customer_City=ifnull(customer_profile_info.City,"")
														Customer_State=ifnull(customer_profile_info.State,null)
														Customer_Country=ifnull(customer_profile_info.Country,null)
														Supplier_TIN=organization_info.Supplier_TIN
														Supplier_SST_Registration_Number=organization_info.SST_ID
														Subscriptions=subscription_id
														Invoice_Date=termination_date
														Due_Date=due_date
														Sub_Total_Call_Charges=sub_total_call_charges
														Total_Tax_Call_Charges=total_tax_call_charges
														Grand_Total_Call_Charges=grand_total_call_charges
														Sub_Total_Monthly_Rental=0
														Total_Tax_Monthly_Rental=0
														Grand_Total_Monthly_Rental=0
														Amount_Due=grand_total
														Amount_Paid=0
														Deposit_Amount=total_deposit_amount
														Base_Currency=currency
														Exchange_Rate=exchange_rate
														Payable_To=current_subscription.Payable_To
														Invoice_For_Usage=invoice_usage
														Enable_Reminder=tenancy_info.Enable_Reminder
														Added_User=zoho.loginuser
														Supplier=Organization_Settings[ID != null].ID
													];
												}		catch (error)
												{
													error_msg = error;
												}
												if(error_msg == "")
												{
													get_invoice = Invoice[ID == create_invoice];
													get_invoice.Sub_Total_Monthly_Rental=sub_total_monthly_rental;
													get_invoice.Total_Tax_Monthly_Rental=total_tax_monthly_rental;
													get_invoice.Grand_Total_Monthly_Rental=grand_total_monthly_rental;
													get_invoice.Sub_Total_Internet_Charges=sub_total_internet_charges;
													get_invoice.Total_Tax_Internet_Charges=total_tax_internet_charges;
													get_invoice.Grand_Total_Internet_Charges=grand_total_internet_charges;
													get_invoice.Sub_Total_Call_Charges=sub_total_call_charges;
													get_invoice.Total_Tax_Call_Charges=total_tax_call_charges;
													get_invoice.Grand_Total_Call_Charges=grand_total_call_charges;
													/* Mark subscription Terminated only after invoice is confirmed created */
													current_subscription.Subscription_Status="Terminated";
													current_subscription.Next_Billing_Date=null;
													current_subscription.Final_Billing_Date=termination_date;
													current_subscription.Latest_Billing_Date=termination_date;
												}
											}
											else
											{
												/* period_start >= termination_date: nothing to bill, terminate directly */
												current_subscription.Subscription_Status="Terminated";
												current_subscription.Next_Billing_Date=null;
												current_subscription.Final_Billing_Date=termination_date;
												current_subscription.Latest_Billing_Date=termination_date;
											}
										}
										else
										{
											/* Current Duration: customer already paid for the current period upfront — no additional invoice */
											current_subscription.Subscription_Status="Terminated";
											current_subscription.Next_Billing_Date=null;
											current_subscription.Final_Billing_Date=termination_date;
											current_subscription.Latest_Billing_Date=termination_date;
										}
					)
					}
				}
			}
		}
	}
