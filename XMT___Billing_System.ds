				field rules
				{
					actions 
					{
					hide add row of Monthly_Rental,Internet_Charges,Call_Charges,Credit_Applied_Invoices,Refund_History;
					}
					actions  (Blueprint.Current_Stage == "Draft" || Blueprint.Current_Stage == "Pending Approval" || Blueprint.Current_Stage == "Rejected")
					{
