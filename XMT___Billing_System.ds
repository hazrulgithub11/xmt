				type = picklist
				displayname = "Tax Type"
				maxchar = 100
				values = {"Sales Tax","Service Tax","Tourism Tax","High-Value Goods Tax","Sales Tax on Low Value Goods","Not Applicable"}
	 			row = 1
	 			column = 1   
				width = medium
			)
