										}
										if(new_public_link != null && new_public_link != "")
										{
											input.Invoice_Public_Link = new_public_link;
										}
										input.Invoice_Related_List.insert(new_row_invoice_related_list);
					)
					}
				}
			}
			Convert_To_Debit_Note1 as "Convert To Debit Note"
			{
				type =  functions
				form = Invoice
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						errorMessage = "";
										create_debit_note_id = null;
										try 
										{
											blueprint_create_debit_note_id = insert into Debit_Note
											[
												Supplier=input.Supplier
												Customer=input.Customer
												Supplier_Name=input.Supplier_Name
												Supplier_TIN=input.Supplier_TIN
												Supplier_ID_Type=input.Supplier_ID_Type
												Supplier_Registration_Identification_Passport_Number=input.Supplier_Registration_Identification_Passport_Number
												Supplier_SST_Registration_Number=input.Supplier_SST_Registration_Number
												Supplier_Business_Activity_Description=input.Supplier_Business_Activity_Description
												Supplier_E_mail=input.Supplier_E_mail
												Supplier_Telephone_Number=input.Supplier_Telephone_Number
												Supplier_Street=input.Supplier_Street
												Supplier_City=input.Supplier_City
												Supplier_Postcode=input.Supplier_Postcode
												Supplier_Country=input.Supplier_Country
												Supplier_State=input.Supplier_State
												Customer_Name=input.Customer_Name
												Customer_TIN=input.Customer_TIN
												Customer_ID_Type=input.Customer_ID_Type
												Customer_Registration_Identification_Passport_Number=input.Customer_Registration_Identification_Passport_Number
												Customer_SST_Registration_Number=input.Customer_SST_Registration_Number
												Customer_Code=input.Customer_Code
												Customer_E_mail=input.Customer_E_mail
												Customer_Telephone_Number=input.Customer_Telephone_Number
												Customer_Street=input.Customer_Street
												Customer_City=input.Customer_City
												Customer_Postcode=input.Customer_Postcode
												Customer_Country=input.Customer_Country
												Customer_State=input.Customer_State
												Delivery_Street=input.Delivery_Street
												Delivery_City=input.Delivery_City
												Delivery_Postcode=input.Delivery_Postcode
												Delivery_Country=input.Delivery_Country
												Delivery_State=input.Delivery_State
												Invoice_No=thisapp.debit_note.generate_debit_note_no()
												Invoice_Date=zoho.currentdate
												Payment_Term=input.Payment_Term
												Due_Date=zoho.currentdate.addDay(input.Payment_Term.Days)
												Charge_Category=input.Charge_Category
												Attachment=input.Attachment
												Base_Currency=input.Base_Currency
												Invoice_Currency=input.Invoice_Currency
												Exchange_Rate=input.Exchange_Rate
												Sub_Total_Monthly_Rental=input.Sub_Total_Monthly_Rental
												Total_Tax_Monthly_Rental=input.Total_Tax_Monthly_Rental
												Grand_Total_Monthly_Rental=input.Grand_Total_Monthly_Rental
												Sub_Total_Internet_Charges=input.Sub_Total_Internet_Charges
												Total_Tax_Internet_Charges=input.Total_Tax_Internet_Charges
												Grand_Total_Internet_Charges=input.Grand_Total_Internet_Charges
												Sub_Total_Call_Charges=input.Sub_Total_Call_Charges
												Total_Tax_Call_Charges=input.Total_Tax_Call_Charges
												Grand_Total_Call_Charges=input.Grand_Total_Call_Charges
												Sub_Total=input.Sub_Total
												Total_Tax=input.Total_Tax
												Grand_Total=input.Grand_Total
												Grand_Total_Base_Currency=input.Grand_Total_Base_Currency
												Amount_Paid=0
												Amount_Due=input.Grand_Total
												Payable_To=input.Payable_To
												Reference_Invoice=input.ID
												Added_User=zoho.loginuser
											];
											thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Draft",blueprint_create_debit_note_id);
											create_debit_note_id = blueprint_create_debit_note_id;
											// Add item row to item subform
											total_monthly_rental = 0;
											total_internet_charges = 0;
											total_call_charges = 0;
											get_debit_note = Debit_Note[ID == create_debit_note_id];
											for each  curr_monthly_rental in input.Monthly_Rental
											{
												curr_debit_note_monthly_rental = Debit_Note.Monthly_Rental();
												curr_debit_note_monthly_rental.Item_Monthly_Rental=curr_monthly_rental.Item_Monthly_Rental;
												curr_debit_note_monthly_rental.Item_Code_Monthly_Rental=curr_monthly_rental.Item_Code_Monthly_Rental;
												curr_debit_note_monthly_rental.Classification_Codes_Monthly_Rental=curr_monthly_rental.Classification_Codes_Monthly_Rental;
												curr_debit_note_monthly_rental.Description_Monthly_Rental=curr_monthly_rental.Description_Monthly_Rental;
												curr_debit_note_monthly_rental.Quantity_Monthly_Rental=curr_monthly_rental.Quantity_Monthly_Rental;
												curr_debit_note_monthly_rental.Unit_Price_Monthly_Rental=curr_monthly_rental.Unit_Price_Monthly_Rental;
												curr_debit_note_monthly_rental.Sub_Total_Monthly_Rental=curr_monthly_rental.Sub_Total_Monthly_Rental;
												curr_debit_note_monthly_rental.Tax_Monthly_Rental=curr_monthly_rental.Tax_Monthly_Rental;
												curr_debit_note_monthly_rental.Tax_Type_Monthly_Rental=curr_monthly_rental.Tax_Type_Monthly_Rental;
												curr_debit_note_monthly_rental.Tax_Pct_Monthly_Rental=curr_monthly_rental.Tax_Pct_Monthly_Rental;
												curr_debit_note_monthly_rental.Tax_Amount_Monthly_Rental=curr_monthly_rental.Tax_Amount_Monthly_Rental;
												curr_debit_note_monthly_rental.Total_Monthly_Rental=curr_monthly_rental.Total_Monthly_Rental;
												curr_debit_note_monthly_rental.Business_Segment_Monthly_Rental=curr_monthly_rental.Business_Segment_Monthly_Rental;
												curr_debit_note_monthly_rental.Business_Unit_Monthly_Rental=curr_monthly_rental.Business_Unit_Monthly_Rental;
												curr_debit_note_monthly_rental.Circuit_ID_Monthly_Rental=curr_monthly_rental.Circuit_ID_Monthly_Rental;
												curr_debit_note_monthly_rental.Circuit_ID_Type_Monthly_Rental=curr_monthly_rental.Circuit_ID_Type_Monthly_Rental;
												get_debit_note.Monthly_Rental.insert(curr_debit_note_monthly_rental);
												total_monthly_rental = total_monthly_rental + 1;
											}
											for each  curr_internet_charges in input.Internet_Charges
											{
												curr_debit_note_internet_charges = Debit_Note.Internet_Charges();
												curr_debit_note_internet_charges.Item_Internet_Charges=curr_internet_charges.Item_Internet_Charges;
												curr_debit_note_internet_charges.Item_Code_Internet_Charges=curr_internet_charges.Item_Code_Internet_Charges;
												curr_debit_note_internet_charges.Classification_Codes_Internet_Charges=curr_internet_charges.Classification_Codes_Internet_Charges;
												curr_debit_note_internet_charges.Description_Internet_Charges=curr_internet_charges.Description_Internet_Charges;
												curr_debit_note_internet_charges.Quantity_Internet_Charges=curr_internet_charges.Quantity_Internet_Charges;
												curr_debit_note_internet_charges.Unit_Price_Internet_Charges=curr_internet_charges.Unit_Price_Internet_Charges;
												curr_debit_note_internet_charges.Sub_Total_Internet_Charges=curr_internet_charges.Sub_Total_Internet_Charges;
												curr_debit_note_internet_charges.Tax_Internet_Charges=curr_internet_charges.Tax_Internet_Charges;
												curr_debit_note_internet_charges.Tax_Type_Internet_Charges=curr_internet_charges.Tax_Type_Internet_Charges;
												curr_debit_note_internet_charges.Tax_Pct_Internet_Charges=curr_internet_charges.Tax_Pct_Internet_Charges;
												curr_debit_note_internet_charges.Tax_Amount_Internet_Charges=curr_internet_charges.Tax_Amount_Internet_Charges;
												curr_debit_note_internet_charges.Total_Internet_Charges=curr_internet_charges.Total_Internet_Charges;
												curr_debit_note_internet_charges.Business_Segment_Internet_Charges=curr_internet_charges.Business_Segment_Internet_Charges;
												curr_debit_note_internet_charges.Business_Unit_Internet_Charges=curr_internet_charges.Business_Unit_Internet_Charges;
												curr_debit_note_internet_charges.Circuit_ID_Internet_Charges=curr_internet_charges.Circuit_ID_Internet_Charges;
												curr_debit_note_internet_charges.Circuit_ID_Type_Internet_Charges=curr_internet_charges.Circuit_ID_Type_Internet_Charges;
												get_debit_note.Internet_Charges.insert(curr_debit_note_internet_charges);
												total_internet_charges = total_internet_charges + 1;
											}
											for each  curr_call_charges in input.Call_Charges
											{
												curr_debit_note_call_charges = Debit_Note.Call_Charges();
												curr_debit_note_call_charges.Item_Call_Charges=curr_call_charges.Item_Call_Charges;
												curr_debit_note_call_charges.Item_Code_Call_Charges=curr_call_charges.Item_Code_Call_Charges;
												curr_debit_note_call_charges.Classification_Codes_Call_Charges=curr_call_charges.Classification_Codes_Call_Charges;
												curr_debit_note_call_charges.Description_Call_Charges=curr_call_charges.Description_Call_Charges;
												curr_debit_note_call_charges.Quantity_Call_Charges=curr_call_charges.Quantity_Call_Charges;
												curr_debit_note_call_charges.Unit_Price_Call_Charges=curr_call_charges.Unit_Price_Call_Charges;
												curr_debit_note_call_charges.Sub_Total_Call_Charges=curr_call_charges.Sub_Total_Call_Charges;
												curr_debit_note_call_charges.Tax_Call_Charges=curr_call_charges.Tax_Call_Charges;
												curr_debit_note_call_charges.Tax_Type_Call_Charges=curr_call_charges.Tax_Type_Call_Charges;
												curr_debit_note_call_charges.Tax_Pct_Call_Charges=curr_call_charges.Tax_Pct_Call_Charges;
												curr_debit_note_call_charges.Tax_Amount_Call_Charges=curr_call_charges.Tax_Amount_Call_Charges;
												curr_debit_note_call_charges.Total_Call_Charges=curr_call_charges.Total_Call_Charges;
												curr_debit_note_call_charges.Business_Segment_Call_Charges=curr_call_charges.Business_Segment_Call_Charges;
												curr_debit_note_call_charges.Business_Unit_Call_Charges=curr_call_charges.Business_Unit_Call_Charges;
												curr_debit_note_call_charges.Circuit_ID_Call_Charges=curr_call_charges.Circuit_ID_Call_Charges;
												curr_debit_note_call_charges.Circuit_ID_Type_Call_Charges=curr_call_charges.Circuit_ID_Type_Call_Charges;
												get_debit_note.Call_Charges.insert(curr_debit_note_call_charges);
												total_call_charges = total_call_charges + 1;
											}
											// Validate total item rows on new invoice
											new_total_monthly_rental = 0;
											new_total_internet_charges = 0;
											new_total_call_charges = 0;
											for each  curr_monthly_rental in get_debit_note.Monthly_Rental
											{
												new_total_monthly_rental = new_total_monthly_rental + 1;
											}
											for each  curr_internet_charges in get_debit_note.Internet_Charges
											{
												new_total_internet_charges = new_total_internet_charges + 1;
											}
											for each  curr_call_charges in get_debit_note.Call_Charges
											{
												new_total_call_charges = new_total_call_charges + 1;
											}
											if(total_monthly_rental != new_total_monthly_rental || total_internet_charges != new_total_internet_charges || total_call_charges != new_total_call_charges)
											{
												delete from Debit_Note[ID == get_debit_note.ID];
											}
										}catch (error)
										{
											errorMessage = error;
										}
										if(errorMessage == "")
										{
											success message "Successfully Converted To Debit Note";
											openURL("#Form:Debit_Note?recLinkID=" + create_debit_note_id + "&viewLinkName=Debit_Notes","popup window");
										}
										else
										{
											openUrl("#Form:Alert_Message?Error_Message=" + errorMessage,"popup window","height=auto,width=auto");
										}
					)
					}
				}
			}
			Submit_Invoice_to_LHDN as "Submit Invoice to LHDN"
			{
				type =  functions
				form = Invoice
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						zoho_loginuser = zoho.loginuser;
										app_link_name = "xmt-billing-system";
										// Main info
										client_id = input.Supplier.Client_ID;
										client_secret = input.Supplier.Client_Secret;
										organization_scheme_id = input.Supplier.Scheme_ID;
										organization_scheme_agency_id = input.Supplier.Scheme_agency_ID;
										organization_tax_name = input.Supplier.Tax_Name;
										organization_environment = input.Supplier.LHDN_Portal_Environment;
										// Organization info
										organization_name = input.Supplier_Name;
										organization_tin = input.Supplier_TIN;
										organization_registration_number_scheme = input.Supplier_ID_Type;
										organization_registration_number = input.Supplier_Registration_Identification_Passport_Number;
										organization_sst_registration_number = input.Supplier_SST_Registration_Number;
										organization_msic_description = input.Supplier_Business_Activity_Description;
										organization_email = input.Supplier_E_mail;
										organization_phone = input.Supplier_Telephone_Number;
										organization_street_address = input.Supplier_Street;
										organization_city = input.Supplier_City;
										organization_zip = input.Supplier_Postcode;
										organization_country = input.Supplier_Country;
										organization_state = input.Supplier_State;
										organization_object = {"client_id":client_id,"client_secret":client_secret,"organization_scheme_id":organization_scheme_id,"organization_scheme_agency_id":organization_scheme_agency_id,"organization_tax_name":organization_tax_name,"organization_environment":organization_environment,"organization_name":organization_name,"organization_tin":organization_tin,"organization_registration_number_scheme":organization_registration_number_scheme,"organization_registration_number":organization_registration_number,"organization_sst_registration_number":organization_sst_registration_number,"organization_msic_description":organization_msic_description,"organization_email":organization_email,"organization_phone":organization_phone,"organization_street_address":organization_street_address,"organization_city":organization_city,"organization_zip":organization_zip,"organization_country":organization_country,"organization_state":organization_state};
										organization = organization_object.toString();
										// Customer info
										customer_name = input.Customer_Name;
										customer_tin = input.Customer_TIN;
										customer_registration_number_scheme = input.Customer_ID_Type;
										customer_registration_number = input.Customer_Registration_Identification_Passport_Number;
										customer_sst_registration_number = input.Customer_SST_Registration_Number;
										customer_email = input.Customer_E_mail;
										customer_phone = input.Customer_Telephone_Number;
										customer_billing_street_address = input.Customer_Street;
										customer_billing_city = input.Customer_City;
										customer_billing_zip = input.Customer_Postcode;
										customer_billing_country_name = input.Customer_Country;
										customer_billing_state = input.Customer_State;
										customer_shipping_street_address = input.Delivery_Street;
										customer_shipping_city = input.Delivery_City;
										customer_shipping_zip = input.Delivery_Postcode;
										customer_shipping_country_name = input.Delivery_Country;
										customer_shipping_state = input.Delivery_State;
										customer_object = {"customer_name":customer_name,"customer_tin":customer_tin,"customer_registration_number_scheme":customer_registration_number_scheme,"customer_registration_number":customer_registration_number,"customer_sst_registration_number":customer_sst_registration_number,"customer_email":customer_email,"customer_phone":customer_phone,"customer_billing_street_address":customer_billing_street_address,"customer_billing_city":customer_billing_city,"customer_billing_zip":customer_billing_zip,"customer_billing_country_name":customer_billing_country_name,"customer_billing_state":customer_billing_state,"customer_shipping_street_address":customer_shipping_street_address,"customer_shipping_city":customer_shipping_city,"customer_shipping_zip":customer_shipping_zip,"customer_shipping_country_name":customer_shipping_country_name,"customer_shipping_state":customer_shipping_state};
										customer = customer_object.toString();
										// Invoice info
										line_item_list = {};
										for each  curr_monthly_rental in input.Monthly_Rental
										{
											curr_item_name = curr_monthly_rental.Item_Code_Monthly_Rental;
											curr_item_classification_code_list = curr_monthly_rental.Classification_Codes_Monthly_Rental;
											curr_item_description = "Monthly Rental: " + curr_monthly_rental.Description_Monthly_Rental;
											curr_item_quantity = curr_monthly_rental.Quantity_Monthly_Rental;
											curr_item_unit_price = curr_monthly_rental.Unit_Price_Monthly_Rental;
											curr_item_price_extension = curr_monthly_rental.Sub_Total_Monthly_Rental;
											curr_item_tax_type = curr_monthly_rental.Tax_Type_Monthly_Rental;
											curr_item_tax_percentage = curr_monthly_rental.Tax_Pct_Monthly_Rental;
											curr_item_tax_amount = curr_monthly_rental.Tax_Amount_Monthly_Rental;
											curr_item = {"item_name":curr_item_name,"item_classification_code_list":curr_item_classification_code_list,"item_description":curr_item_description,"item_quantity":curr_item_quantity,"item_unit_price":curr_item_unit_price,"item_price_extension":curr_item_price_extension,"item_tax_type":curr_item_tax_type,"item_tax_percentage":curr_item_tax_percentage,"item_tax_amount":curr_item_tax_amount};
											line_item_list.add(curr_item);
										}
										for each  curr_internet_charge in input.Internet_Charges
										{
											curr_item_name = curr_internet_charge.Item_Code_Internet_Charges;
											curr_item_classification_code_list = curr_internet_charge.Classification_Codes_Internet_Charges;
											curr_item_description = "Internet Charge: " + curr_internet_charge.Description_Internet_Charges;
											curr_item_quantity = curr_internet_charge.Quantity_Internet_Charges;
											curr_item_unit_price = curr_internet_charge.Unit_Price_Internet_Charges;
											curr_item_price_extension = curr_internet_charge.Sub_Total_Internet_Charges;
											curr_item_tax_type = curr_internet_charge.Tax_Type_Internet_Charges;
											curr_item_tax_percentage = curr_internet_charge.Tax_Pct_Internet_Charges;
											curr_item_tax_amount = curr_internet_charge.Tax_Amount_Internet_Charges;
											curr_item = {"item_name":curr_item_name,"item_classification_code_list":curr_item_classification_code_list,"item_description":curr_item_description,"item_quantity":curr_item_quantity,"item_unit_price":curr_item_unit_price,"item_price_extension":curr_item_price_extension,"item_tax_type":curr_item_tax_type,"item_tax_percentage":curr_item_tax_percentage,"item_tax_amount":curr_item_tax_amount};
											line_item_list.add(curr_item);
										}
										for each  curr_call_charge in input.Call_Charges
										{
											curr_item_name = curr_call_charge.Item_Code_Call_Charges;
											curr_item_classification_code_list = curr_call_charge.Classification_Codes_Call_Charges;
											curr_item_description = "Call Charge: " + curr_call_charge.Description_Call_Charges;
											curr_item_quantity = curr_call_charge.Quantity_Call_Charges;
											curr_item_unit_price = curr_call_charge.Unit_Price_Call_Charges;
											curr_item_price_extension = curr_call_charge.Sub_Total_Call_Charges;
											curr_item_tax_type = curr_call_charge.Tax_Type_Call_Charges;
											curr_item_tax_percentage = curr_call_charge.Tax_Pct_Call_Charges;
											curr_item_tax_amount = curr_call_charge.Tax_Amount_Call_Charges;
											curr_item = {"item_name":curr_item_name,"item_classification_code_list":curr_item_classification_code_list,"item_description":curr_item_description,"item_quantity":curr_item_quantity,"item_unit_price":curr_item_unit_price,"item_price_extension":curr_item_price_extension,"item_tax_type":curr_item_tax_type,"item_tax_percentage":curr_item_tax_percentage,"item_tax_amount":curr_item_tax_amount};
											line_item_list.add(curr_item);
										}
										invoice_id = input.ID.toString();
										invoice_get_response = Map();
										invoice_get_response.put("Invoice_Date",input.Invoice_Date);
										invoice_get_response.put("Invoice_No",input.Invoice_No);
										invoice_get_response.put("Payment_Term",input.Payment_Term.Days.toString());
										invoice_get_response.put("ID",input.ID);
										invoice_get_response.put("Due_Date",input.Due_Date);
										invoice_get_response.put("invoice_uuid",input.Invoice_UUID);
										invoice_get_response.put("invoice_public_link",input.Invoice_Public_Link);
										invoice_get_response.put("invoice_subtotal",input.Sub_Total);
										invoice_get_response.put("invoice_tax_total",input.Total_Tax);
										invoice_get_response.put("invoice_total",input.Grand_Total);
										invoice_get_response.put("organization_currency_code",input.Base_Currency);
										invoice_get_response.put("invoice_currency_code",input.Invoice_Currency);
										invoice_get_response.put("invoice_exchange_rate",input.Exchange_Rate);
										invoice_get_response.put("line_items",line_item_list);
										invoice = invoice_get_response.toString();
										// Invoice LHDN submission
										invoice_submit_lhdn_output = thisapp.invoice_submit_lhdn(invoice,organization,customer);
										info invoice_submit_lhdn_output.get("output").toMap();
										invoice_submit_lhdn_output = invoice_submit_lhdn_output.get("output").toMap();
										current_date_time = zoho.currenttime;
										new_row_invoice_related_list = Invoice.Invoice_Related_List();
										new_row_invoice_related_list.USERNAME=zoho_loginuser;
										new_row_invoice_related_list.INVOICE_NUMBER=input.Invoice_No;
										new_row_invoice_related_list.Related_List_Date=current_date_time.toDate();
										new_row_invoice_related_list.Related_List_Time=current_date_time.toTime();
										new_row_invoice_related_list.SUBMISSION_ID=invoice_submit_lhdn_output.get("SUBMISSION_ID");
										new_row_invoice_related_list.UUID=invoice_submit_lhdn_output.get("UUID_LINK");
										new_row_invoice_related_list.PUBLIC_LINK=invoice_submit_lhdn_output.get("PUBLIC_LINK");
										new_row_invoice_related_list.STATUS=invoice_submit_lhdn_output.get("STATUS");
										new_row_invoice_related_list.MESSAGE=invoice_submit_lhdn_output.get("MESSAGE");
										// Invoice Info
										new_invoice_uuid = invoice_submit_lhdn_output.get("UUID");
										new_invoice_uuid_link = invoice_submit_lhdn_output.get("UUID_LINK");
										new_public_link = invoice_submit_lhdn_output.get("PUBLIC_LINK");
										if(new_invoice_uuid != null && new_invoice_uuid != "")
										{
											input.Invoice_UUID = new_invoice_uuid;
										}
										if(new_invoice_uuid_link != null && new_invoice_uuid_link != "")
										{
											input.Invoice_UUID_Link = new_invoice_uuid_link;
										}
										if(new_public_link != null && new_public_link != "")
										{
											input.Invoice_Public_Link = new_public_link;
										}
										input.Invoice_Related_List.insert(new_row_invoice_related_list);
					)
					}
				}
			}
			Send_Proforma_Invoice1 as "Send_Proforma_Invoice"
			{
				type =  functions
				form = Pro_Forma_Invoices
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						getEmailTemplate = Email_Templates[Template_Type == "Pro Forma Invoices" && Status == "Active"];
										toAddresses = input.Customer_E_mail;
										emailSubject = getEmailTemplate.Subject_field;
										emailBody = getEmailTemplate.Body;
										placeholders = getEmailTemplate.Placeholders;
										recId = input.ID;
										getRecordPI = zoho.creator.getRecordById(zoho.adminuser,zoho.appname,"Pro_Forma_Invoices_New",recId,"zoho_creator_connection");
										if(getRecordPI.get("code") == 3000)
										{
											piData = getRecordPI.get("data");
										}
										for each  placeholder in placeholders
										{
											if(piData.get(placeholder).size() != null)
											{
												listData = piData.get(placeholder).toString().replaceAllIgnoreCase("\{|\}|\"|\"","").toList(",");
												placeHolderValue = "";
												idx = 0;
												for each  data in listData
												{
													if(data.contains("display_value:"))
													{
														if(idx > 0)
														{
															placeHolderValue = placeHolderValue + ",";
														}
														placeHolderValue = placeHolderValue + data.getSuffix("display_value:");
														idx = idx + 1;
													}
												}
												emailSubject = emailSubject.replaceAllIgnoreCase("\{" + placeholder + "\}",placeHolderValue);
												emailBody = emailBody.replaceAllIgnoreCase("\{" + placeholder + "\}",placeHolderValue);
											}
											else
											{
												emailSubject = emailSubject.replaceAllIgnoreCase("\{" + placeholder + "\}",piData.get(placeholder));
												emailBody = emailBody.replaceAllIgnoreCase("\{" + placeholder + "\}",piData.get(placeholder));
											}
										}
										downloadPITempUrl = "https://creatorapp.zohopublic.com/xmttechnologiessdnbhd1/xmt-billing-system/record-pdf/Copy_of_All_Pro_Forma_Invoices/" + recId + "/" + input.Invoice_No + "/sEA7WFUM1Ffguk6qHdV2as2b2UQs9xS5yyMYDqCKQ5UFnhtwTfkEGJxdkeK0gq5SFa3MseeJ4jTKqaBJ9OBrURDUs4bYmXUddJB6";
										piFile = invokeurl
										[
											url :downloadPITempUrl
											type :GET
										];
										piFile.setparamname("file");
										sendmail
										[
											from :zoho.adminuserid
											to :toAddresses
											subject :emailSubject
											message :emailBody
											Attachments :file:piFile
										]
					)
					}
					actions 
					{
					on click
					(
						if(input.Due_Date > zoho.currentdate)
										{
											thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Sent",input.ID);
										}
										else
										{
											thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Overdue",input.ID);
										}
					)
					}
				}
			}
