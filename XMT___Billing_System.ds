			Submit_Refund_Note_to_LHD1 as "Submit Refund Note to LHDN"
			{
				type =  functions
				form = Refund_Note
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						zoho_loginuser = zoho.loginuser;
										app_link_name = "xmt-billing-system";
										// Main info
										client_id = input.Supplier.Client_ID;
										client_secret = input.Supplier.Client_Secret;
