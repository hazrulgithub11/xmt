				earlyDate = "01-Jan-2024";
				if(input.startDate == null)
				{
					input.startDate = earlyDate;
				}
				if(input.endDate == null)
				{
					input.endDate = currentdate;
				}
				if(input.prefixDateDuration != null)
				{
					input.prefixDateDuration = input.prefixDateDuration;
				}
			}
		}
