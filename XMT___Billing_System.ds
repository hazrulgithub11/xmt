			Validate_Active_Template1 as "Validate Active Template"
			{
				type =  form
				form = Email_Templates

				record event = on add or edit

				on validate
				{
					actions  (Template_Type != "Invoice Reminder" && Status == "Active")
					{
						custom deluge script
						(
											getReminderTemplates = Email_Templates[Template_Type == input.Template_Type && Status == "Active" && ID != input.ID].ID.getAll();
										if(getReminderTemplates.size() > 0)
										{
											alert "An active template already exists for this template type " + input.Template_Type + ". Please deactivate it before activating a new one.";
											cancel submit;
										}
						)
					}
					actions  (Template_Type == "Invoice Reminder")
					{
						custom deluge script
						(
											if(input.Reminder_Type == null || input.Reminder_Type == "")
										{
											alert(Reminder_Type,"This field is mandatory.Select a value.");
										}
										if(input.Status == "Active")
										{
											getReminderTemplates = Email_Templates[Reminder_Type == input.Reminder_Type && Status == "Active" && ID != input.ID].ID.getAll();
											if(getReminderTemplates.size() > 0)
											{
												alert "An active template already exists for this reminder type " + input.Reminder_Type + ". Please deactivate it before activating a new one.";
												cancel submit;
											}
										}
						)
					}
				}

			}
			Successful_form_submissio as "Successful form submission created/edited"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											/*
										get_invoices = Invoice[Subscriptions == input.ID].ID.getAll();
										if(get_invoices.size() == 0)
										{
											// Subscription info
											subscription_contract_start_date = input.Contract_Start_Date;
											subscription_contract_end_date = input.Contract_End_Date;
											subscription_contract_period = input.Contract_Period;
											subscription_bill_for = input.Bill_For;
											subscription_bill_every = input.Bill_Every;
											subscription_billing_cycle = input.Billing_Cycle;
											subscription_billing_cycle_int = thisapp.tenancy.convert_bill_cycle_to_int(subscription_billing_cycle);
											subscription_id = input.ID;
											if(subscription_billing_cycle == "Monthly")
											{
												current_billing_every_date = thisapp.subscription.resolve_billing_day_for_month(subscription_bill_every,today);
												start_billing_every_date = thisapp.subscription.resolve_billing_day_for_month(subscription_bill_every,subscription_contract_start_date);
											}
											else
											{
												current_billing_every_date = thisapp.subscription.resolve_billing_date_for_contract_day(subscription_contract_start_date,today);
												start_billing_every_date = thisapp.subscription.resolve_billing_date_for_contract_day(subscription_contract_start_date,subscription_contract_start_date);
											}
											if(subscription_bill_for == "Current Duration")
											{
												if(subscription_billing_cycle == "Monthly")
												{
													last_day_of_end_month = subscription_contract_end_date.eomonth(0).getDay();
													if(subscription_bill_every == "Last Day Of Month" || subscription_bill_every.toLong() > last_day_of_end_month)
													{
														bill_every_int = last_day_of_end_month;
													}
													else
													{
														bill_every_int = subscription_bill_every.toLong();
													}
													// ── Resolve anchor date depending on whether contract has started ──
													if(subscription_contract_start_date < today.toStartOfMonth())
													{
														anchor_date = current_billing_every_date;
														contract_periods_left = monthsBetween(anchor_date,subscription_contract_end_date);
														if(contract_periods_left > 0)
														{
															next_billing_date = anchor_date.addMonth(subscription_billing_cycle_int);
															clean_periods = (contract_periods_left / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int;
															subscription_final_billing_date = anchor_date.addMonth(clean_periods);
															invoice_start_date = subscription_contract_start_date;
															create_invoice = true;
														}
													}
													else if(subscription_contract_start_date <= today)
													{
														anchor_date = current_billing_every_date;
														more_periods = monthsBetween(anchor_date.addMonth(subscription_billing_cycle_int),subscription_contract_end_date);
														if(more_periods > 0)
														{
															next_billing_date = anchor_date.addMonth(subscription_billing_cycle_int);
															if(subscription_contract_end_date.getDay() == bill_every_int || subscription_contract_end_date.getDay() == 1)
															{
																period_offset = subscription_contract_period - subscription_billing_cycle_int;
															}
															else
															{
																period_offset = subscription_contract_period;
															}
															subscription_final_billing_date = anchor_date.addMonth(period_offset);
														}
														else
														{
															next_billing_date = null;
															subscription_final_billing_date = today;
														}
														invoice_start_date = subscription_contract_start_date;
														create_invoice = true;
													}
													else
													{
														// Contract starts in the future
														anchor_date = start_billing_every_date;
														next_billing_date = anchor_date;
														if(subscription_contract_end_date.getDay() == bill_every_int || subscription_contract_end_date.getDay() == 1)
														{
															period_offset = subscription_contract_period - subscription_billing_cycle_int;
														}
														else
														{
															period_offset = subscription_contract_period;
														}
														subscription_final_billing_date = anchor_date.addMonth(period_offset);
														invoice_start_date = anchor_date;
														if(daysBetween(today,anchor_date) <= 5)
														{
															create_invoice = true;
														}
													}
													if(subscription_final_billing_date != null)
													{
														subscription_final_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(subscription_final_billing_date,subscription_bill_every);
													}
													if(next_billing_date != null)
													{
														next_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(next_billing_date,subscription_bill_every);
													}
													input.Latest_Billing_Date = today;
													input.Next_Billing_Date = next_billing_date;
													input.Final_Billing_Date = subscription_final_billing_date;
													// ── Create invoice ──
													if(create_invoice)
													{
														bundle_next = false;
														if(next_billing_date != null && daysBetween(today,next_billing_date) <= 5)
														{
															bundle_next = true;
														}
														if(bundle_next)
														{
															thisapp.invoice.create_invoice_current_duration(true,subscription_id,anchor_date,invoice_start_date,true,next_billing_date,next_billing_date,true);
															input.Next_Billing_Date = next_billing_date.addMonth(subscription_billing_cycle_int);
														}
														else
														{
															thisapp.invoice.create_invoice_current_duration(true,subscription_id,anchor_date,invoice_start_date,false,null,null,true);
														}
													}
												}
												else
												{
													if(subscription_contract_start_date < today.toStartOfMonth())
													{
														contract_period_left = monthsBetween(current_billing_every_date,subscription_contract_end_date);
														add_month_value = (contract_period_left / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int;
														if(add_month_value > 0)
														{
															add_value = ((monthsBetween(subscription_contract_start_date,current_billing_every_date) / subscription_billing_cycle_int).toNumber() + 1) * subscription_billing_cycle_int;
															next_billing_date = subscription_contract_start_date.addMonth(add_value);
															previous_billing_date = next_billing_date.subMonth(subscription_billing_cycle_int);
															if(subscription_contract_period % subscription_billing_cycle_int == 0)
															{
																subscription_final_billing_date = subscription_contract_start_date.addMonth(subscription_contract_period - subscription_billing_cycle_int);
															}
															else
															{
																subscription_final_billing_date = subscription_contract_start_date.addMonth((subscription_contract_period / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int);
															}
															if(subscription_contract_start_date.eomonth(0).getDay() == subscription_contract_start_date.getDay())
															{
																next_billing_date = next_billing_date.eomonth(0);
																subscription_final_billing_date = subscription_final_billing_date.eomonth(0);
																previous_billing_date = previous_billing_date.eomonth(0);
															}
															input.Final_Billing_Date = subscription_final_billing_date;
															input.Latest_Billing_Date = today;
															input.Next_Billing_Date = next_billing_date;
															previous_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(previous_billing_date,subscription_bill_every);
															thisapp.invoice.create_invoice_current_duration(false,subscription_id,previous_billing_date,previous_billing_date,false,null,null,false);
															if(daysBetween(today,next_billing_date) <= 5)
															{
																thisapp.invoice.create_invoice_current_duration(false,subscription_id,next_billing_date,next_billing_date,false,null,null,false);
															}
														}
														input.Latest_Billing_Date = today;
													}
													else if(subscription_contract_start_date >= today.toStartOfMonth() && subscription_contract_start_date <= today.eomonth(0) && subscription_contract_start_date <= today)
													{
														input.Latest_Billing_Date = subscription_contract_start_date;
														add_month_value = (subscription_contract_period / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int;
														if(subscription_contract_period % subscription_billing_cycle_int == 0)
														{
															subscription_final_billing_date = subscription_contract_start_date.addMonth(subscription_contract_period - subscription_billing_cycle_int);
														}
														else
														{
															subscription_final_billing_date = subscription_contract_start_date.addMonth((subscription_contract_period / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int);
														}
														if(subscription_contract_start_date.eomonth(0).getDay() == subscription_contract_start_date.getDay())
														{
															subscription_final_billing_date = subscription_final_billing_date.eomonth(0);
														}
														if(monthsBetween(current_billing_every_date.addMonth(subscription_billing_cycle_int),subscription_contract_end_date) > 0)
														{
															input.Next_Billing_Date = subscription_contract_start_date.addMonth(subscription_billing_cycle_int);
														}
														else
														{
															subscription_final_billing_date = today;
															input.Next_Billing_Date = null;
														}
														input.Final_Billing_Date = subscription_final_billing_date;
														thisapp.invoice.create_invoice_current_duration(false,subscription_id,current_billing_every_date,subscription_contract_start_date,false,null,null,false);
													}
													else
													{
														input.Next_Billing_Date = subscription_contract_start_date;
														if(subscription_contract_period % subscription_billing_cycle_int == 0)
														{
															if(subscription_contract_period < subscription_billing_cycle_int)
															{
																subscription_final_billing_date = start_billing_every_date;
															}
															else
															{
																subscription_final_billing_date = start_billing_every_date.addMonth((subscription_contract_period / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int - subscription_billing_cycle_int);
															}
														}
														else
														{
															subscription_final_billing_date = start_billing_every_date.addMonth((subscription_contract_period / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int);
														}
														if(subscription_contract_start_date.eomonth(0).getDay() == subscription_contract_start_date.getDay())
														{
															subscription_final_billing_date = subscription_final_billing_date.eomonth(0);
														}
														input.Final_Billing_Date = subscription_final_billing_date;
														if(daysBetween(today,subscription_contract_start_date) <= 5)
														{
															thisapp.invoice.create_invoice_current_duration(false,subscription_id,start_billing_every_date,start_billing_every_date,false,null,null,false);
														}
													}
												}
											}
											else if(subscription_bill_for == "Previous Duration")
											{
												if(subscription_billing_cycle == "Monthly")
												{
													if(subscription_contract_start_date < today.toStartOfMonth())
													{
														next_billing_date = current_billing_every_date.addMonth(subscription_billing_cycle_int);
														contract_period_left = monthsBetween(next_billing_date,subscription_contract_end_date);
														if(contract_period_left >= 0)
														{
															if(subscription_contract_end_date < next_billing_date)
															{
																subscription_final_billing_date = next_billing_date.addMonth(contract_period_left);
															}
															else
															{
																subscription_final_billing_date = next_billing_date.addMonth(contract_period_left + subscription_billing_cycle_int);
															}
															subscription_final_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(subscription_final_billing_date,subscription_bill_every);
															next_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(next_billing_date,subscription_bill_every);
															input.Next_Billing_Date = next_billing_date;
															input.Final_Billing_Date = subscription_final_billing_date;
															input.Latest_Billing_Date = today;
															if(daysBetween(today,next_billing_date) <= 5)
															{
																thisapp.invoice.create_invoice_previous_duration(true,subscription_id,current_billing_every_date,subscription_contract_start_date,true,next_billing_date,next_billing_date,true);
																input.Next_Billing_Date = next_billing_date.addMonth(subscription_billing_cycle_int);
																input.Latest_Billing_Date = next_billing_date;
															}
															else
															{
																thisapp.invoice.create_invoice_previous_duration(true,subscription_id,current_billing_every_date,subscription_contract_start_date,false,null,null,true);
															}
														}
														else
														{
															subscription_final_billing_date = subscription_contract_end_date;
															input.Next_Billing_Date = null;
															input.Final_Billing_Date = subscription_final_billing_date;
															input.Latest_Billing_Date = today;
															input.Subscription_Status = "Inactive";
														}
													}
													else
													{
														next_billing_date = start_billing_every_date.addMonth(subscription_billing_cycle_int);
														subscription_final_billing_date = start_billing_every_date.addMonth(subscription_contract_period + subscription_billing_cycle_int);
														subscription_final_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(subscription_final_billing_date,subscription_bill_every);
														next_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(next_billing_date,subscription_bill_every);
														input.Next_Billing_Date = next_billing_date;
														input.Final_Billing_Date = subscription_final_billing_date;
														input.Latest_Billing_Date = today;
														if(daysBetween(today,next_billing_date) <= 5)
														{
															thisapp.invoice.create_invoice_previous_duration(true,subscription_id,next_billing_date,next_billing_date,false,null,null,true);
															input.Next_Billing_Date = next_billing_date.addMonth(subscription_billing_cycle_int);
															input.Latest_Billing_Date = next_billing_date;
														}
													}
												}
												else
												{
													if(subscription_contract_start_date < today.toStartOfMonth())
													{
														add_value = ((monthsBetween(subscription_contract_start_date,today) / subscription_billing_cycle_int).toNumber() + 1) * subscription_billing_cycle_int;
														next_billing_date = subscription_contract_start_date.addMonth(add_value);
														previous_billing_date = next_billing_date.subMonth(subscription_billing_cycle_int);
														if(subscription_contract_start_date.getDay() == subscription_contract_start_date.eomonth(0).getDay())
														{
															next_billing_date = next_billing_date.eomonth(0);
															previous_billing_date = previous_billing_date.eomonth(0);
														}
														contract_period_left = monthsBetween(next_billing_date,subscription_contract_end_date);
														if(contract_period_left > 0)
														{
															subscription_final_billing_date = next_billing_date.addMonth((contract_period_left / subscription_billing_cycle_int).toNumber() * subscription_billing_cycle_int);
															if(subscription_contract_start_date.getDay() == subscription_contract_start_date.eomonth(0).getDay())
															{
																subscription_final_billing_date = subscription_final_billing_date.eomonth(0);
															}
															if(next_billing_date.addMonth(subscription_billing_cycle_int) > subscription_contract_end_date)
															{
																input.Next_Billing_Date = null;
																input.Latest_Billing_Date = next_billing_date;
																input.Final_Billing_Date = next_billing_date;
															}
															else
															{
																input.Next_Billing_Date = next_billing_date;
																input.Final_Billing_Date = subscription_final_billing_date;
															}
															previous_billing_date = thisapp.tenancy.normalize_billing_date_for_bill_every(previous_billing_date,subscription_bill_every);
															if(daysBetween(today,next_billing_date) <= 5)
															{
																thisapp.invoice.create_invoice_previous_duration(false,subscription_id,previous_billing_date,previous_billing_date,true,next_billing_date,next_billing_date,false);
															}
															else if(daysBetween(today,next_billing_date) > 5)
															{
																thisapp.invoice.create_invoice_previous_duration(false,subscription_id,previous_billing_date,previous_billing_date,false,null,null,false);
															}
														}
														else if(contract_period_left == 0)
														{
															subscription_final_billing_date = next_billing_date;
															input.Final_Billing_Date = subscription_final_billing_date;
															input.Next_Billing_Date = next_billing_date;
															input.Latest_Billing_Date = today;
															if(daysBetween(today,next_billing_date) <= 5)
															{
																thisapp.invoice.create_invoice_previous_duration(false,subscription_id,next_billing_date,next_billing_date,false,null,null,false);
															}
														}
													}
													else
													{
														next_billing_date = subscription_contract_start_date.addMonth(subscription_billing_cycle_int);
														input.Next_Billing_Date = next_billing_date;
														if(subscription_contract_period % subscription_billing_cycle_int == 0)
														{
															subscription_final_billing_date = subscription_contract_start_date.addMonth(subscription_contract_period);
														}
														else
														{
															subscription_final_billing_date = subscription_contract_start_date.addMonth((1 + (subscription_contract_period / subscription_billing_cycle_int).toNumber()) * subscription_billing_cycle_int);
														}
														if(subscription_contract_start_date.getDay() == subscription_contract_start_date.eomonth(0).getDay())
														{
															input.Final_Billing_Date = subscription_final_billing_date.eomonth(0);
														}
														else
														{
															input.Final_Billing_Date = subscription_final_billing_date;
														}
														if(daysBetween(today,next_billing_date) <= 5)
														{
															thisapp.invoice.create_invoice_previous_duration(false,subscription_id,next_billing_date,next_billing_date,false,null,null,false);
															input.Latest_Billing_Date = next_billing_date;
														}
													}
												}
											}
										}
										*/
						)
					}
				}

			}
			Handle_Internet_Charges_Q1 as "Handle Internet Charges Quantity"
			{
				type =  form
				form = Invoice

				record event = on add or edit

				on user input of Internet_Charges.Quantity_Internet_Charges
				{
					actions 
					{
						custom deluge script
						(
											if(ifnull(row.Quantity_Internet_Charges,0) <= 0)
										{
											alert "Please enter a quantity more than 0";
											row.Quantity_Internet_Charges=1;
											return;
										}
										input.User_Input_Trigger = !input.User_Input_Trigger;
						)
					}
				}

			}
