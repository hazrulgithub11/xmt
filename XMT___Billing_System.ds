										{
											if(input.Contract_End_Date.getMonth() != input.Contract_Start_Date.addMonth(input.Contract_Period).getMonth() || input.Contract_End_Date.getYear() != input.Contract_Start_Date.addMonth(input.Contract_Period).getYear())
											{
												alert "Please select a contract end date that matches the subscription's period end date.";
												input.Contract_End_Date = input.Contract_Start_Date.addMonth(input.Contract_Period);
											}
											input.Prorate_Note = thisapp.subscription.get_prorate_note(input.Contract_Start_Date,input.Contract_End_Date,input.Billing_Cycle,input.Bill_For,input.Bill_Every,input.Prorate);
										}
						)
					}
				}

			}
