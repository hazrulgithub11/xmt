				}
			}
		}
		form Date_form
		{
			displayname = "Date form"
			store data in zc = false
			success message = ""
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Prefix_Date_Duration
			(
				type = picklist
				displayname = "Prefix Date Duration"
				maxchar = 100
				values = {"This Month","This Year","Custom"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Section
			(
				type = section
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Start_Date
			(
    			type = date
				displayname = "Start Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have End_Date
			(
    			type = date
				displayname = "End Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 2
	 			column = 2   
				width = medium
			)
	
			actions
			{
				Filter
				(
   					type = submit
   					displayname = "Filter"
				)
				Reset
				(
   					type = reset
   					displayname = "Reset"
				)
			}
		}
		form Debit_Note
		{
			displayname = "Debit Note"
			success message = "Invoice Added Successfully"
			Supplier_From_Section
			(
				type = section
				displayname = "Supplier (From)"
				visibility = true
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Supplier
			(
				type = picklist	
				values  = Organization_Settings.ID
    			displayformat = [Organization_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Business_Activity_Description
			(
    			type = text
				displayname = "Business Activity Description"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_TIN
			(
    			type = text
				displayname = "Tax Identification Number(TIN)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_ID_Type
			(
    			type = text
				displayname = "ID Type"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Registration_Identification_Passport_Number
			(
    			type = text
				displayname = "Registration / Identification / Passport Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_SST_Registration_Number
			(
    			type = text
				displayname = "SST Registration Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Telephone_Number
			(
    			type = phonenumber
				displayname = "Telephone Number"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Supplier_E_mail
			(
    			type = email
				displayname = "E-mail"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Supplier_Name
			(
    			type = text
				displayname = "Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Street
			(
    			type = textarea
				displayname = "Street"
				height = 100px
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Postcode
			(
    			type = text
				displayname = "Postcode"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_City
			(
    			type = text
				displayname = "City"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_State
			(
    			type = text
				displayname = "State"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Country
			(
    			type = text
				displayname = "Country"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Buyer_To_Section
			(
				type = section
				displayname = "Buyer (To)"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Customer
			(
				type = picklist	
				values  = Customer_Profile.ID
    			displayformat = [Customer_Name]
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_Code
			(
				type = picklist	
				displayname = "Customer Code"
				values  = Tenancy[Customer_Name.ID == input.Customer].ID
    			displayformat = [Customer_Code]
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_TIN
			(
    			type = text
				displayname = "Tax Identification Number(TIN)"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_ID_Type
			(
    			type = text
				displayname = "ID Type"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_Registration_Identification_Passport_Number
			(
    			type = text
				displayname = "Registration / Identification / Passport Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_SST_Registration_Number
			(
    			type = text
				displayname = "SST Registration Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_Telephone_Number
			(
    			type = phonenumber
				displayname = "Telephone Number"
	 			row = 2
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Customer_E_mail
			(
    			type = email
				displayname = "E-mail"
				maxchar = 80
	 			row = 2
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Customer_Name
			(
    			type = text
				displayname = "Name"
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_Street
			(
    			type = textarea
				displayname = "Street"
				height = 100px
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_Postcode
			(
    			type = text
				displayname = "Postcode"
	 			row = 2
	 			column = 2   
				width = medium
