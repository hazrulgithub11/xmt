				must have Unit_Price_Call_Charges
				(
					type = decimal
					displayname = "Unit Price"
					format = commadotwestern
					initial value = 0
					width = 100px
				)
				must have Sub_Total_Call_Charges
				(
					type = decimal
					displayname = "Sub Total"
					format = commadotwestern
					initial value = 0
					width = 100px
				)
				must have Tax_Call_Charges
