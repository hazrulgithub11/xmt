			Hide_Fields19 as "Hide Fields"
			{
				type =  form
				form = Debit_Note

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											// Handle rejection scenario
										if(input.Blueprint.Current_Stage != "Rejected" && input.Blueprint.Current_Stage != "Pending Approval")
										{
											hide Rejection_Section;
										}
										// Handle Miscellaneous Charges, Fixed Charges and Call Charges
										if(input.Charge_Category == "Miscellaneous Charges")
										{
											hide Call_Charges;
											clear Call_Charges;
										}
										else if(input.Charge_Category == "Fixed Charges")
										{
											hide Call_Charges;
											clear Call_Charges;
										}
										else
										{
											show Call_Charges;
										}
										// Hide fields
										hide Customer_Name_Trigger;
										hide User_Input_Trigger;
						)
					}
				}

			}
			Handle_Validation_Submiss1 as "Handle Validation Submission"
			{
				type =  form
				form = Debit_Note

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// Count Total Line Items
										count_item = 0;
										for each  curr_monthly_rental in input.Monthly_Rental
										{
											count_item = count_item + 1;
										}
										for each  curr_internet_charge in input.Internet_Charges
										{
											count_item = count_item + 1;
										}
										for each  curr_call_charge in input.Call_Charges
										{
											count_item = count_item + 1;
										}
										if(count_item == 0)
										{
											alert "Add at least one item need to be added.";
											cancel submit;
										}
										// Validate Call Charges for Telephone Category
										charges_categories = input.Charge_Category;
										if(charges_categories.containsIgnoreCase("Telephone Charges"))
										{
											row_number = 0;
											for each  call_charges in input.Call_Charges
											{
												row_number = row_number + 1;
											}
											if(row_number == 0)
											{
												alert "Please fill Call Charges";
												cancel submit;
											}
										}
										// Validate Monthly Rental Quantity & Unit Price
										for each  curr_monthly_rental in input.Monthly_Rental
										{
											if(ifnull(curr_monthly_rental.Quantity_Monthly_Rental,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_monthly_rental.Unit_Price_Monthly_Rental,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Internet Charges Quantity & Unit Price
										for each  curr_internet_charges in input.Internet_Charges
										{
											if(ifnull(curr_internet_charges.Quantity_Internet_Charges,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_internet_charges.Unit_Price_Internet_Charges,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Call Charges Quantity & Unit Price
										for each  curr_call_charges in input.Call_Charges
										{
											if(ifnull(curr_call_charges.Quantity_Call_Charges,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_call_charges.Unit_Price_Call_Charges,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
						)
					}
				}

			}
