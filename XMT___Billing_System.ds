 application "XMT : Billing System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Asia/Singapore"
 	time format = "24-hr"

 	forms
	{
		form Alert_Message
		{
			displayname = "Alert Message"
			store data in zc = false
			success message = ""
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Error_Message
			(
    			type = plaintext
				value = "Add your Note here ..."
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				Close
				(
   					type = submit
   					displayname = "Close"
				)
			}
		}
		form Announcement
		{
			success message = "Announcement Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Announcement_Message
			(
    			type = text
				displayname = "Announcement Message"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Announcement_Image
			(
    			type = image
				displayname = "Announcement Image"
				compression = true
				source  = file
				aspect ratio = square
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Apply_Credit_To_Invoice_Line
		{
			displayname = "Apply Credit To Invoice Line"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Invoice
			(
				type = picklist	
				values  = Invoice.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Credit_Note
			(
				type = picklist	
				displayname = "Credit Note"
				values  = Credit_Note.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Amount_Applied_Date
			(
    			type = date
				displayname = "Amount Applied Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Amount_Applied
			(
				type = decimal
				displayname = "Amount Applied"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Apply_Credit_To_Invoices
		{
			displayname = "Apply Credit To Invoices"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have invoice
			(
				type = picklist	
				values  = Credit_Note.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Credits_Remaining
			(
				type = decimal
				displayname = "Credits Remaining"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Unpaid_Invoices
			(
				type = grid
				displayname = "Unpaid Invoices"
				must have Invoice
				(
					type = picklist	
					displayname = "Invoice No"
					values  = Invoice.ID
    				displayformat = [Invoice_No]
					sortorder = ascending
					width = medium
				)
				must have Invoice_Date
				(
    				type = date
					displayname = "Invoice Date"
					alloweddays = 0,1,2,3,4,5,6
					width = medium
				)
				must have Grand_Total
				(
					type = decimal
					displayname = "Grand Total"
					format = commadotwestern
					width = medium
				)
				must have Amount_Due
				(
					type = decimal
					displayname = "Amount Due"
					format = commadotwestern
					width = medium
				)
				must have Credits_To_Apply
				(
					type = decimal
					displayname = "Credits To Apply"
					format = commadotwestern
					width = medium
				)
	 			row = 2
	 			column = 1   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Credit_Note_Selection_Trigger
			(
    			type = checkbox
				initial value = false
	 			row = 3
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
