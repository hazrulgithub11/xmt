            			}
        			}
        			stages
        			{
           			"Draft"
           			{
               			chart data
               			{
                   			position : "-240.27629540954445 -4.317468212851637"
               			}
           			}
           			"Pending Approval"
           			{
               			chart data
               			{
                   			position : "-356.65187874292985 275.4029197366406"
               			}
           			}
           			"Rejected"
           			{
               			chart data
