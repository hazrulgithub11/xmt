			custom actions
			(
				"Mark As Sent"
				(
	  			workflow = Mark_As_Sent_Payment_Rece
				show action in view header = true
				condition = (Receipt_Sent == false)
				confirmation before execution
				(
					message for individual record = "Are you sure you want to \"Mark As Sent\" this Payment Received   ${Payment_Received_No} ?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Send Payment Received"
				(
	  			workflow = Send_Payment_Receveid_Dep
				show action in view header = true
				confirmation before execution
				(
					message for individual record = "Are you sure you want to \"Send Payment Received \" this Payment Received   ${Payment_Received_No} ?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
			)
			conditional formatting
			(
				"Yes"
				{
				condition = (Receipt_Sent == true)
				fields = [Receipt_Sent]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"No"
				{
				condition = (Receipt_Sent == false)
				fields = [Receipt_Sent]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
