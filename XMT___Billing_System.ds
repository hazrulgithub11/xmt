			Handle_Customer_Name2 as "Handle Customer Name"
			{
				type =  form
				form = Payment_Received

				record event = on add or edit

				on user input of Customer_Name
				{
					actions  (Customer_Name.ID is not null)
					{
						custom deluge script
						(
											customerInfo = Customer_Profile[ID == input.Customer_Name];
										if(input.Single_Record_Payment != true)
										{
											input.Customer_Code = null;
										}
										input.Payment_Method = null;
										input.Reference = "";
										input.Customer_Email = ifnull(customerInfo.Email_Address,"");
										input.Customer_TIN = ifnull(customerInfo.Customer_TIN,"");
										input.Customer_SST = ifnull(customerInfo.Customer_SST,"");
										input.Paid_To = null;
										input.Payment_Received_Line_Item.clear();
										input.Amount_Received = 0;
										input.Payment_Received_Currency = null;
										input.Amount_Received_MYR = null;
						)
					}
					actions  (Payment_Type == "Invoice/Debit Note" && Customer_Name.ID is not null)
					{
						custom deluge script
						(
											customerInfo = Customer_Profile[ID == input.Customer_Name];
										get_invoice_list = Invoice[Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Overdue" && Customer == input.Customer_Name && Amount_Due > 0];
										get_debit_note_list = Debit_Note[Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Overdue" && Customer == input.Customer_Name && Amount_Due > 0];
										if(get_invoice_list.count() == 0 && get_debit_note_list.count() == 0 && input.Customer_Name != null)
										{
											alert "There are no unpaid invoices associated with this customer code.";
										}
										input.Payment_Received_Line_Item.clear();
										total_payment_amount_received = 0;
										total_payment_amount_received_myr = 0;
										payment_received_currency = null;
										for each  curr_invoice in get_invoice_list
										{
											curr_pay_row = Payment_Received.Payment_Received_Line_Item();
											curr_pay_row.Reference_No=curr_invoice.Invoice_No;
											curr_pay_row.Description="Payment Received For " + curr_invoice.Invoice_For_Usage + " INV " + curr_invoice.Invoice_No;
											curr_pay_row.Invoice_No=curr_invoice.ID;
											curr_pay_row.Document_Date=curr_invoice.Invoice_Date;
											curr_pay_row.Amount=curr_invoice.Grand_Total;
											curr_pay_row.Outstanding_Balance=curr_invoice.Amount_Due;
											curr_pay_row.Allocation=curr_invoice.Amount_Due;
											curr_pay_row.Allocation_MYR=curr_invoice.Amount_Due * curr_invoice.Exchange_Rate;
											curr_pay_row.Still_Owing=ifnull(curr_invoice.Amount_Due,0) - ifnull(curr_pay_row.Allocation,0);
											input.Payment_Received_Line_Item.insert(curr_pay_row);
											total_payment_amount_received = total_payment_amount_received + curr_invoice.Amount_Due;
											total_payment_amount_received_myr = total_payment_amount_received_myr + curr_invoice.Amount_Due * curr_invoice.Exchange_Rate;
											if(payment_received_currency == null)
											{
												payment_received_currency = curr_invoice.Invoice_Currency;
											}
										}
										for each  curr_debit_note in get_debit_note_list
										{
											curr_pay_row = Payment_Received.Payment_Received_Line_Item();
											curr_pay_row.Reference_No=curr_debit_note.Invoice_No;
											curr_pay_row.Description="Payment Received For Debit Note " + curr_debit_note.Invoice_No;
											curr_pay_row.Debit_Note_No=curr_debit_note.ID;
											curr_pay_row.Document_Date=curr_debit_note.Invoice_Date;
											curr_pay_row.Amount=curr_debit_note.Grand_Total;
											curr_pay_row.Outstanding_Balance=curr_debit_note.Amount_Due;
											curr_pay_row.Allocation=curr_debit_note.Amount_Due;
											curr_pay_row.Allocation_MYR=curr_debit_note.Amount_Due * curr_debit_note.Exchange_Rate;
											curr_pay_row.Still_Owing=ifnull(curr_debit_note.Amount_Due,0) - ifnull(curr_pay_row.Allocation,0);
											input.Payment_Received_Line_Item.insert(curr_pay_row);
											total_payment_amount_received = total_payment_amount_received + curr_debit_note.Amount_Due;
											total_payment_amount_received_myr = total_payment_amount_received_myr + curr_debit_note.Amount_Due * curr_debit_note.Exchange_Rate;
											if(payment_received_currency == null)
											{
												payment_received_currency = curr_debit_note.Invoice_Currency;
											}
										}
										input.Payment_Received_Currency = ifnull(payment_received_currency,input.Payment_Received_Currency);
										input.Amount_Received = total_payment_amount_received;
										input.Amount_Received_MYR = total_payment_amount_received_myr;
										total_still_Owing = 0;
										for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											total_still_Owing = total_still_Owing + ifnull(curr_payment_received_line_item.Outstanding_Balance,0) - ifnull(curr_payment_received_line_item.Allocation,0);
										}
										input.Total_Still_Owing = total_still_Owing;
						)
					}
					actions  (Payment_Type == "Deposit" && Customer_Name.ID is not null)
					{
						custom deluge script
						(
											customerInfo = Customer_Profile[ID == input.Customer_Name];
										tenancyInfo = Tenancy[ID == input.Customer_Code];
										//input.Paid_To2 = ifnull(tenancyInfo.Payable_To1,null);
										subTotal = 0;
										totalTax = 0;
										getPIs = Pro_Forma_Invoices[Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Overdue" && Customer_Code == input.Customer_Code && Amount_Due > 0];
										if(getPIs.ID == null && input.Customer_Code != null)
										{
											alert "There are no unpaid deposits associated with this customer code.";
										}
										input.Payment_Received_Line_Item.clear();
										totalPaymentReceived = 0;
										totalPaymentReceivedMYR = 0;
										payment_received_currency = null;
										for each  pi in getPIs
										{
											payRow = Payment_Received.Payment_Received_Line_Item();
											payRow.Reference_No=pi.Invoice_No;
											payRow.Description="Payment Received For DEP " + pi.Invoice_No;
											payRow.Pro_Forma_Invoice_No=pi.ID;
											payRow.Document_Date=pi.Invoice_Date;
											payRow.Amount=pi.Grand_Total;
											payRow.Outstanding_Balance=pi.Amount_Due;
											payRow.Allocation=pi.Amount_Due;
											payRow.Allocation_MYR=pi.Amount_Due * pi.Exchange_Rate;
											payRow.Still_Owing=ifnull(pi.Amount_Due,0) - ifnull(payRow.Allocation,0);
											input.Payment_Received_Line_Item.insert(payRow);
											totalPaymentReceived = totalPaymentReceived + pi.Amount_Due;
											totalPaymentReceivedMYR = totalPaymentReceivedMYR + pi.Amount_Due * pi.Exchange_Rate;
											if(payment_received_currency == null)
											{
												payment_received_currency = pi.Invoice_Currency;
											}
										}
										input.Payment_Received_Currency = ifnull(payment_received_currency,input.Payment_Received_Currency);
										input.Amount_Received = totalPaymentReceived;
										input.Amount_Received_MYR = totalPaymentReceivedMYR;
										total_still_Owing = 0;
										for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											total_still_Owing = total_still_Owing + ifnull(curr_payment_received_line_item.Outstanding_Balance,0) - ifnull(curr_payment_received_line_item.Allocation,0);
										}
										input.Total_Still_Owing = total_still_Owing;
						)
					}
				}

			}
			Successful_payment_receiv as "Successful payment received submission"
			{
				type =  form
				form = Payment_Received

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											thisapp.close_form();
										openUrl("#Report:Payment_Received_Report","same window");
										total_still_Owing = 0;
										for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											curr_still_owing = curr_payment_received_line_item.Outstanding_Balance - curr_payment_received_line_item.Allocation;
											curr_payment_received_line_item.Still_Owing=curr_still_owing;
											total_still_Owing = total_still_Owing + curr_still_owing;
										}
										input.Total_Still_Owing = total_still_Owing;
										//////////////////////////
										if(input.Payment_Type == "Invoice/Debit Note")
										{
											input.Payment_Received_No = thisapp.payment_received.generate_payment_received_no_invoice_and_debit_note();
										}
										else
										{
											input.Payment_Received_No = thisapp.payment_received.generate_payment_received_no_deposit();
										}
										journalEntryLineItem = Collection();
										row1 = Journal_Entry.Journal_Entry_Line_Item();
										row1.Account=input.Paid_To;
										row1.Description="Payment Received " + input.Payment_Received_No + " to " + input.Paid_To.Account + "-" + input.Paid_To.Bank_Account_Number;
										row1.Debit=ifnull(input.Amount_Received,0);
										row1.Credit=0;
										row2 = Journal_Entry.Journal_Entry_Line_Item();
										row2.Account=4662372000000941747;
										row2.Description="Payment Received " + input.Payment_Received_No + " Trade and Other Receivables";
										row2.Debit=0;
										row2.Credit=ifnull(input.Amount_Received,0);
										journalEntryLineItem.insert(row1,row2);
										newJournalEntryRecord = insert into Journal_Entry
										[
											Journal_Entry_No=thisapp.journal_entry.generate_journal_no()
											Document_No=input.Payment_Received_No
											Added_User=zoho.loginuser
											Payment_Received=input.ID
											Date_field=zoho.currentdate
											Journal_Entry_Line_Item=journalEntryLineItem
											Sub_Total_Debit=0
											Sub_Total_Credit=0
											Total_Debit=ifnull(input.Amount_Received,0)
											Total_Credit=ifnull(input.Amount_Received,0)
											Difference=ifnull(input.Amount_Received,0) - ifnull(input.Amount_Received,0)
											Created_By_The_System=true
										];
						)
					}
					actions  (Payment_Type == "Invoice/Debit Note")
					{
						custom deluge script
						(
											for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											if(curr_payment_received_line_item.Allocation > 0)
											{
												curr_payment_received_line_item.Still_Owing=curr_payment_received_line_item.Outstanding_Balance - curr_payment_received_line_item.Allocation;
												if(curr_payment_received_line_item.Invoice_No != null)
												{
													curr_get_invoice = Invoice[ID == curr_payment_received_line_item.Invoice_No];
													// Amount Paid and Amount Due Calculation
													curr_get_invoice.Amount_Paid=curr_get_invoice.Amount_Paid + curr_payment_received_line_item.Allocation;
													curr_get_invoice.Amount_Due=curr_get_invoice.Amount_Due - curr_payment_received_line_item.Allocation;
													// Invoice Blueprint status update
													if(ifnull(curr_get_invoice.Amount_Due,0) <= 0)
													{
														thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Paid",curr_get_invoice.ID);
													}
													else if(ifnull(curr_get_invoice.Amount_Paid,0) > 0)
													{
														thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Partially Paid",curr_get_invoice.ID);
													}
													else if(curr_get_invoice.Due_Date > zoho.currentdate)
													{
														thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Sent",curr_get_invoice.ID);
													}
													else
													{
														thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Overdue",curr_get_invoice.ID);
													}
													thisapp.tenancy.calculate_opening_balance_by_tenancy(curr_get_invoice.Customer_Code);
												}
												else if(curr_payment_received_line_item.Debit_Note_No != null)
												{
													curr_get_debit_note = Debit_Note[ID == curr_payment_received_line_item.Debit_Note_No];
													// Amount Paid and Amount Due Calculation
													curr_get_debit_note.Amount_Paid=curr_get_debit_note.Amount_Paid + curr_payment_received_line_item.Allocation;
													curr_get_debit_note.Amount_Due=curr_get_debit_note.Amount_Due - curr_payment_received_line_item.Allocation;
													// Debit Note Blueprint status update
													if(ifnull(curr_get_debit_note.Amount_Due,0) <= 0)
													{
														thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Paid",curr_get_debit_note.ID);
													}
													else if(ifnull(curr_get_debit_note.Amount_Paid,0) > 0)
													{
														thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Partially Paid",curr_get_debit_note.ID);
													}
													else if(curr_get_debit_note.Due_Date > zoho.currentdate)
													{
														thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Sent",curr_get_debit_note.ID);
													}
													else
													{
														thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Overdue",curr_get_debit_note.ID);
													}
												}
											}
											else
											{
												delete from Payment_Received_Line_Item[ID == curr_payment_received_line_item.ID];
											}
										}
						)
					}
					actions  (Payment_Type == "Deposit")
					{
						custom deluge script
						(
											for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											curr_payment_received_line_item.Still_Owing=curr_payment_received_line_item.Outstanding_Balance - curr_payment_received_line_item.Allocation;
											if(curr_payment_received_line_item.Allocation > 0)
											{
												curr_get_pro_forma = Pro_Forma_Invoices[ID == curr_payment_received_line_item.Pro_Forma_Invoice_No];
												// Amount Paid and Amount Due Calculation
												curr_get_pro_forma.Amount_Paid=curr_get_pro_forma.Amount_Paid + curr_payment_received_line_item.Allocation;
												curr_get_pro_forma.Amount_Due=curr_get_pro_forma.Amount_Due - curr_payment_received_line_item.Allocation;
												// Pro Forma Invoice Blueprint status update
												if(ifnull(curr_get_pro_forma.Amount_Due,0) <= 0)
												{
													thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Paid",curr_get_pro_forma.ID);
												}
												else if(ifnull(curr_get_pro_forma.Amount_Paid,0) > 0)
												{
													thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Partially Paid",curr_get_pro_forma.ID);
												}
												else if(curr_get_pro_forma.Due_Date > zoho.currentdate)
												{
													thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Sent",curr_get_pro_forma.ID);
												}
												else
												{
													thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Overdue",curr_get_pro_forma.ID);
												}
											}
											else
											{
												delete from Payment_Received_Line_Item[ID == curr_payment_received_line_item.ID];
											}
										}
						)
					}
				}

			}
			Handle_Payment_Received_L as "Handle Payment Received Line Item Allocation"
			{
				type =  form
				form = Payment_Received

				record event = on add or edit

				on user input of Payment_Received_Line_Item.Allocation
				{
					actions 
					{
						custom deluge script
						(
											if(row.Invoice_No == null && row.Debit_Note_No == null && row.Pro_Forma_Invoice_No == null)
										{
											alert "Payment Received line item requires a document reference — invoice, debit note, or pro forma invoice.";
										}
										else
										{
											row_allocation = ifnull(row.Allocation,0);
											if(row_allocation < 0)
											{
												alert "Allocation cannot be negative.";
												row_allocation = 0;
											}
											outstanding_balance = ifnull(row.Outstanding_Balance,0);
											if(row_allocation > outstanding_balance)
											{
												alert "The allocation amount entered is more than outstanding balance for the selected payment received line item.";
												row_allocation = outstanding_balance;
											}
											row.Allocation=row_allocation;
											row.Still_Owing=outstanding_balance - row_allocation;
											payment_received_line_item_document_exchange_rate = 1;
											if(row.Invoice_No != null)
											{
												payment_received_line_item_document_exchange_rate = ifnull(row.Invoice_No.Exchange_Rate,1);
											}
											else if(row.Debit_Note_No != null)
											{
												payment_received_line_item_document_exchange_rate = ifnull(row.Debit_Note_No.Exchange_Rate,1);
											}
											else if(row.Pro_Forma_Invoice_No != null)
											{
												payment_received_line_item_document_exchange_rate = ifnull(row.Pro_Forma_Invoice_No.Exchange_Rate,1);
											}
											row.Allocation_MYR=row_allocation * payment_received_line_item_document_exchange_rate;
											total_payment_amount_received = 0;
											total_payment_amount_received_myr = 0;
											for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
											{
												total_payment_amount_received = total_payment_amount_received + ifnull(curr_payment_received_line_item.Allocation,0);
												total_payment_amount_received_myr = total_payment_amount_received_myr + ifnull(curr_payment_received_line_item.Allocation_MYR,0);
											}
											input.Amount_Received = total_payment_amount_received;
											input.Amount_Received_MYR = total_payment_amount_received_myr;
											total_still_Owing = 0;
											for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
											{
												total_still_Owing = total_still_Owing + ifnull(curr_payment_received_line_item.Outstanding_Balance,0) - ifnull(curr_payment_received_line_item.Allocation,0);
											}
											input.Total_Still_Owing = total_still_Owing;
										}
						)
					}
				}

			}
			Handle_Payment_Type as "Handle Payment Type"
			{
				type =  form
				form = Payment_Received

				record event = on add or edit

				on user input of Payment_Type
				{
					actions 
					{
						custom deluge script
						(
											if(input.Single_Record_Payment != true)
										{
											input.Customer_Name = null;
											input.Customer_TIN = "";
											input.Customer_SST = "";
											input.Customer_Email = "";
											input.Customer_Code = null;
											input.Payment_Method = "";
											input.Paid_To = null;
											input.Reference = "";
											input.Payment_Received_Line_Item.clear();
											input.Amount_Received = null;
											input.Payment_Received_Currency = null;
											input.Amount_Received_MYR = null;
										}
						)
					}
				}

			}
			Validate_Payment_Received as "Validate Payment Received Submission"
			{
				type =  form
				form = Payment_Received

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											line_item_count = 0;
										has_positive_allocation = false;
										total_payment_amount_received = 0;
										total_payment_amount_received_myr = 0;
										total_still_Owing = 0;
										for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											line_item_count = line_item_count + 1;
											row_allocation = ifnull(curr_payment_received_line_item.Allocation,0);
											outstanding_balance = ifnull(curr_payment_received_line_item.Outstanding_Balance,0);
											if(row_allocation < 0)
											{
												alert "Allocation cannot be negative for payment received line items.";
												cancel submit;
											}
											if(row_allocation > outstanding_balance)
											{
												alert "The allocation amount cannot exceed the outstanding balance for " + ifnull(curr_payment_received_line_item.Reference_No,"the selected document") + ".";
												cancel submit;
											}
											if(row_allocation > 0)
											{
												if(curr_payment_received_line_item.Invoice_No == null && curr_payment_received_line_item.Debit_Note_No == null && curr_payment_received_line_item.Pro_Forma_Invoice_No == null)
												{
													alert "Payment Received line item requires a document reference — invoice, debit note, or pro forma invoice.";
													cancel submit;
												}
												has_positive_allocation = true;
											}
											row_allocation_myr = 0;
											if(row_allocation > 0)
											{
												payment_received_line_item_document_exchange_rate = 1;
												if(curr_payment_received_line_item.Invoice_No != null)
												{
													payment_received_line_item_document_exchange_rate = ifnull(curr_payment_received_line_item.Invoice_No.Exchange_Rate,1);
												}
												else if(curr_payment_received_line_item.Debit_Note_No != null)
												{
													payment_received_line_item_document_exchange_rate = ifnull(curr_payment_received_line_item.Debit_Note_No.Exchange_Rate,1);
												}
												else if(curr_payment_received_line_item.Pro_Forma_Invoice_No != null)
												{
													payment_received_line_item_document_exchange_rate = ifnull(curr_payment_received_line_item.Pro_Forma_Invoice_No.Exchange_Rate,1);
												}
												row_allocation_myr = row_allocation * payment_received_line_item_document_exchange_rate;
											}
											curr_payment_received_line_item.Still_Owing=outstanding_balance - row_allocation;
											total_payment_amount_received = total_payment_amount_received + row_allocation;
											total_payment_amount_received_myr = total_payment_amount_received_myr + row_allocation_myr;
											total_still_Owing = total_still_Owing + outstanding_balance - row_allocation;
										}
										if(line_item_count == 0)
										{
											if(input.Payment_Type == "Invoice/Debit Note")
											{
												alert "Cannot record payment: No available invoices / debit notes to apply this payment. Please ensure there is an open invoice / debit note for this customer before submitting.";
											}
											else if(input.Payment_Type == "Deposit")
											{
												alert "Cannot record payment: No available deposits to apply this payment. Please ensure there is an open deposits for this customer before submitting.";
											}
											cancel submit;
										}
										if(has_positive_allocation == false)
										{
											alert "Please allocate payment to at least one document before submitting.";
											cancel submit;
										}
										if(total_payment_amount_received <= 0)
										{
											alert "Total payment amount must be greater than zero.";
											cancel submit;
										}
										input.Amount_Received = total_payment_amount_received;
										input.Amount_Received_MYR = total_payment_amount_received_myr;
										input.Total_Still_Owing = total_still_Owing;
						)
					}
					actions 
					{
						custom deluge script
						(
											line_item_count = 0;
										has_positive_allocation = false;
										total_payment_amount_received = 0;
										total_payment_amount_received_myr = 0;
										total_still_Owing = 0;
										for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											line_item_count = line_item_count + 1;
											row_allocation = ifnull(curr_payment_received_line_item.Allocation,0);
											outstanding_balance = ifnull(curr_payment_received_line_item.Outstanding_Balance,0);
											if(row_allocation < 0)
											{
												alert "Allocation cannot be negative for payment received line items.";
												cancel submit;
											}
											if(row_allocation > outstanding_balance)
											{
												alert "The allocation amount cannot exceed the outstanding balance for " + ifnull(curr_payment_received_line_item.Reference_No,"the selected document") + ".";
												cancel submit;
											}
											if(row_allocation > 0)
											{
												if(curr_payment_received_line_item.Invoice_No == null && curr_payment_received_line_item.Debit_Note_No == null && curr_payment_received_line_item.Pro_Forma_Invoice_No == null)
												{
													alert "Payment Received line item requires a document reference — invoice, debit note, or pro forma invoice.";
													cancel submit;
												}
												has_positive_allocation = true;
											}
											row_allocation_myr = 0;
											if(row_allocation > 0)
											{
												payment_received_line_item_document_exchange_rate = 1;
												if(curr_payment_received_line_item.Invoice_No != null)
												{
													payment_received_line_item_document_exchange_rate = ifnull(curr_payment_received_line_item.Invoice_No.Exchange_Rate,1);
												}
												else if(curr_payment_received_line_item.Debit_Note_No != null)
												{
													payment_received_line_item_document_exchange_rate = ifnull(curr_payment_received_line_item.Debit_Note_No.Exchange_Rate,1);
												}
												else if(curr_payment_received_line_item.Pro_Forma_Invoice_No != null)
												{
													payment_received_line_item_document_exchange_rate = ifnull(curr_payment_received_line_item.Pro_Forma_Invoice_No.Exchange_Rate,1);
												}
												row_allocation_myr = row_allocation * payment_received_line_item_document_exchange_rate;
											}
											curr_payment_received_line_item.Still_Owing=outstanding_balance - row_allocation;
											total_payment_amount_received = total_payment_amount_received + row_allocation;
											total_payment_amount_received_myr = total_payment_amount_received_myr + row_allocation_myr;
											total_still_Owing = total_still_Owing + outstanding_balance - row_allocation;
										}
										if(line_item_count == 0)
										{
											if(input.Payment_Type == "Invoice/Debit Note")
											{
												alert "Cannot record payment: No available invoices / debit notes to apply this payment. Please ensure there is an open invoice / debit note for this customer before submitting.";
											}
											else if(input.Payment_Type == "Deposit")
											{
												alert "Cannot record payment: No available deposits to apply this payment. Please ensure there is an open deposits for this customer before submitting.";
											}
											cancel submit;
										}
										if(has_positive_allocation == false)
										{
											alert "Please allocate payment to at least one document before submitting.";
											cancel submit;
										}
										if(total_payment_amount_received <= 0)
										{
											alert "Total payment amount must be greater than zero.";
											cancel submit;
										}
										input.Amount_Received = total_payment_amount_received;
										input.Amount_Received_MYR = total_payment_amount_received_myr;
										input.Total_Still_Owing = total_still_Owing;
						)
					}
				}

			}
			_Successful_payment_recei as " Successful payment received deletion"
			{
				type =  form
				form = Payment_Received

				record event = on delete

				on success
				{
					actions  (Payment_Type == "Invoice/Debit Note")
					{
						custom deluge script
						(
											for each  curr_payment_received_line_item in input.Payment_Received_Line_Item
										{
											if(curr_payment_received_line_item.Invoice_No != null)
											{
												curr_get_invoice = Invoice[ID == curr_payment_received_line_item.Invoice_No];
												// Amount Paid and Amount Due Calculation
												curr_get_invoice.Amount_Paid=curr_get_invoice.Amount_Paid - curr_payment_received_line_item.Allocation;
												curr_get_invoice.Amount_Due=curr_get_invoice.Amount_Due + curr_payment_received_line_item.Allocation;
												// Invoice Blueprint status update
												if(ifnull(curr_get_invoice.Amount_Due,0) <= 0)
												{
													thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Paid",curr_get_invoice.ID);
												}
												else if(ifnull(curr_get_invoice.Amount_Paid,0) > 0)
												{
													thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Partially Paid",curr_get_invoice.ID);
												}
												else if(curr_get_invoice.Due_Date > zoho.currentdate)
												{
													thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Sent",curr_get_invoice.ID);
												}
												else
												{
													thisapp.blueprint.changeStage("Invoice","Invoice_Blueprint","Overdue",curr_get_invoice.ID);
												}
												thisapp.tenancy.calculate_opening_balance_by_tenancy(curr_get_invoice.Customer_Code);
											}
											else if(curr_payment_received_line_item.Debit_Note_No != null)
											{
												curr_get_debit_note = Debit_Note[ID == curr_payment_received_line_item.Debit_Note_No];
												// Amount Paid and Amount Due Calculation
												curr_get_debit_note.Amount_Paid=curr_get_debit_note.Amount_Paid - curr_payment_received_line_item.Allocation;
												curr_get_debit_note.Amount_Due=curr_get_debit_note.Amount_Due + curr_payment_received_line_item.Allocation;
												// Debit Note Blueprint status update
												if(ifnull(curr_get_debit_note.Amount_Due,0) <= 0)
												{
													thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Paid",curr_get_debit_note.ID);
												}
												else if(ifnull(curr_get_debit_note.Amount_Paid,0) > 0)
												{
													thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Partially Paid",curr_get_debit_note.ID);
												}
												else if(curr_get_debit_note.Due_Date > zoho.currentdate)
												{
													thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Sent",curr_get_debit_note.ID);
												}
												else
												{
													thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Overdue",curr_get_debit_note.ID);
												}
											}
											delete from Payment_Received_Line_Item[ID == curr_payment_received_line_item.ID];
										}
										delete from Journal_Entry[Payment_Received == input.ID];
						)
					}
					actions  (Payment_Type == "Deposit")
					{
						custom deluge script
						(
											for each  paymentReceived in input.Payment_Received_Line_Item
										{
											get_deposit = Pro_Forma_Invoices[ID == paymentReceived.Pro_Forma_Invoice_No];
											get_deposit.Amount_Paid=get_deposit.Amount_Paid - paymentReceived.Allocation;
											get_deposit.Amount_Due=get_deposit.Amount_Due + paymentReceived.Allocation;
											if(ifnull(get_deposit.Amount_Due,0) <= 0)
											{
												thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Paid",get_deposit.ID);
											}
											else if(ifnull(get_deposit.Amount_Paid,0) > 0)
											{
												thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Partially Paid",get_deposit.ID);
											}
											else if(get_deposit.Due_Date > zoho.currentdate)
											{
												thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Sent",get_deposit.ID);
											}
											else
											{
												thisapp.blueprint.changeStage("Pro_Forma_Invoices","Pro_Forma_Invoices_Bluepr","Overdue",get_deposit.ID);
											}
											delete from Payment_Received_Line_Item[ID == paymentReceived.ID];
											delete from Journal_Entry[Deposits == get_deposit.ID];
										}
										delete from Journal_Entry[Payment_Received == input.ID];
						)
					}
				}

			}
