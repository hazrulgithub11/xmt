	reports
	{
		default list All_Business_Units
		{
			displayName = "Business Units"
			show all rows from Business_Unit    
			(
				Business_Unit as "Business Unit"
				Business_Segment as "Business Segment"
			)
		}
		default list All_Buildings
		{
			displayName = "Buildings"
			show all rows from Building    
			(
				Building
			)
		}
		default list All_Project_location_telco_Providers
		{
			displayName = "Project/Location/Telco Providers"
			show all rows from Project_Location_Telco_Provider    
			(
				Project_Location_Telco_Provider as "Project/Location/Telco Provider"
			)
		}
		default list All_Customers_Profile
		{
			displayName = "All Customers Profile"
			show all rows from Customer_Profile    
			(
				Customer_Name as "Customer Name"
				Customer_Registration_Number as "Customer Registration Number"
				Business_Street as "Business Address"
				City
				Email_Address as "Email Address"
				Phone_Number as "Phone Number"
				(
					displayformat = plainnumber 
				)
				Delivery_Address_same_as_Business_Address as "Delivery Address same as Business Address"
				Delivery_Street as "Delivery Street"
				Delivery_City as "Delivery City"
				Delivery_Phone_Number as "Delivery Phone Number"
				(
					displayformat = plainnumber 
				)
				Status
				Attachment
				Postcode
				Delivery_Postcode as "Delivery Postcode"
				Customer_TIN as "Customer TIN"
				Customer_SST as "Customer SST"
				Credit_Available as "Credit Available"
				Business_Segment as "Business Segment"
				Delivery_Country as "Delivery Country"
				Delivery_State as "Delivery State"
				Country
				State
				Customer_Registration_Number_Scheme as "Customer Registration Number Scheme"
				Currency
			)
			sort by
			(
				Customer_Name ascending
			)
		}
		default list All_Subscriptions
		{
			displayName = "All Subscriptions"
			show all rows from Subscription    
			(
				Customer_Code as "Customer Code"
				(
					view = All_Tenancies
				)
				Contract_Start_Date as "Contract Start Date"
				Contract_End_Date as "Contract End Date"
				Contract_Period as "Contract Period (Month)"
				Customer_PO_No as "Customer PO No."
				Grand_Total as "Grand Total"
				Attachment
				Customer_Name as "Customer Name"
				(
					view = All_Customers_Profile
				)
				Next_Billing_Date as "Next Billing Date"
				Latest_Billing_Date as "Latest Billing Date"
				Final_Billing_Date as "Final Billing Date"
				Customer_Name.Modified_Time as "Modified Time"
				Customer_Name.Added_Time as "Added Time"
				Customer_Name.Modified_User as "Modified User"
				Customer_Name.Added_User as "Added User"
				Payment_Term as "Payment Term"
				Grand_Total_Base_Currency as "Grand Total (Base Currency)"
				Subscription_Status as "Subscription Status"
				Subscription_No as "Subscription No"
			)
			filters
			(
				Customer_Code
			)
			custom actions
			(
				"Create Work Order"
				(
	  			workflow = Create_Work_Order
				show action in view header = true
				show action in edit record menu = true
				condition = (Subscription_Status != "Terminated")
				confirmation before execution
				(
					message for individual record = "Execute the Create Work Order action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Terminate Subscription"
				(
	  			workflow = terminate_subscription
				show action in view header = true
				condition = (Subscription_Status == "Active")
				)
			)
		}
		default list All_Taxes
		{
			displayName = "Taxes"
			show all rows from Tax    
			(
				Tax_Name as "Tax Name"
				Tax_Percentage as "Tax Percentage"
				Tax_Type as "Tax Type"
			)
		}
		default list All_Transaction_Types
		{
			displayName = "Transaction Types"
			show all rows from Transaction_Type    
			(
				Item_Name as "Item Name"
				Unit_Price as "Unit Price"
				Tax
				Item_Code as "Item Code"
				Item_Category as "Item Category"
				Circuit_ID_Type as "Circuit ID Type"
				Description
				Charges_Type as "Charges Type"
				Tax.Tax_Type as "Tax Type"
				Classification_Codes as "Classification Codes"
				Circuit_ID as "Circuit ID"
			)
			group by
			(
				Item_Category ascending
			)
		}
		default list All_Invoices
		{
			displayName = "Invoices"
			print template = Miscellaneous_Invoice
			show all rows from Invoice    
			(
				Invoice_No as "Invoice No."
				Invoice_Date as "Invoice Date"
				Due_Date as "Due Date"
				Enable_Reminder as "Enable Reminder ?"
				Customer.Modified_User as "Modified User"
				Customer_Code.Added_User as "Added User"
				Rejection_Reason as "Rejection Reason"
				Attachment
				Customer.Credit_Available as "Credit Available"
				Grand_Total_Call_Charges as "Grand Total Call Charges (Analog, Domestic & Overseas)"
				Sub_Total_Monthly_Rental as "Sub Total Monthly Rental"
				Total_Tax_Monthly_Rental as "Total Tax Monthly Rental"
				Customer_E_mail as "E-mail"
				Announcement.Announcement_Image as "Announcement Image"
				Customer_TIN as "Tax Identification Number(TIN)"
				Supplier_TIN as "Tax Identification Number(TIN)"
				Sub_Total_Internet_Charges as "Sub Total Internet Charges"
				Total_Tax_Internet_Charges as "Total Tax Internet Charges"
				Grand_Total_Internet_Charges as "Grand Total Internet Charges"
				Customer_Registration_Identification_Passport_Number as "Registration / Identification / Passport Number"
				Customer_Street as "Street"
				Customer_Postcode as "Postcode"
				Customer_City as "City"
				Total_Amount_Due as "Total Amount Due"
				Previous_Balance as "Previous Balance"
				Invoice_UUID as "Invoice UUID"
				Invoice_Public_Link as "Invoice Public Link"
				Supplier_Registration_Identification_Passport_Number as "Registration / Identification / Passport Number"
				Supplier_SST_Registration_Number as "SST Registration Number"
				Supplier_Postcode as "Postcode"
				Supplier_City as "City"
				Delivery_Street as "Delivery Street"
				Delivery_City as "Delivery City"
				Delivery_Postcode as "Delivery Postcode"
				Supplier_ID_Type as "ID Type"
				Supplier_Country as "Country"
				Supplier_Business_Activity_Description as "Business Activity Description"
				Supplier_State as "State"
				Customer_ID_Type as "ID Type"
				Customer_Country as "Country"
				Customer_State as "State"
				Delivery_Country as "Delivery Country"
				Delivery_State as "Delivery State"
				Invoice_UUID_Link as "Invoice UUID Link"
				Sub_Total as "Sub Total"
				Total_Tax as "Total Tax"
				Credits_Applied.CA_Apply_Credit_To_Invoice_Line_ID as "Credits Applied"
				Credits_Applied_Trigger
				Credits_Applied_Total as "Credits Applied Total"
				Is_Initialization
				Supplier
				Customer.Customer_Name as "Customer Name"
				Customer
				Charge_Category as "Charge Category"
				Grand_Total as "Grand Total"
				Grand_Total_Base_Currency as "Grand Total (Base Currency)"
				Base_Currency as "Base Currency"
				Invoice_Currency as "Invoice Currency"
				Exchange_Rate as "Exchange Rate"
				Amount_Paid as "Amount Paid"
				Blueprint.Current_Stage as "Status"
			)
			sort by
			(
				Invoice_No descending
			)
			custom actions
			(
				"Bulk Send For Approval"
				(
	  			workflow = Bulk_Send_For_Approval_In
				show action in view header = true
				condition = (Blueprint.Current_Stage == "Pending Approval")
				)
				"Record Payment"
				(
	  			workflow = Record_Payment_Invoice
				show action in view header = true
				show action in edit record menu = true
				condition = (Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Overdue" || Blueprint.Current_Stage == "Paid")
				)
				"Convert To Credit Note"
				(
	  			workflow = Convert_To_Credit_Note
				show action in view header = true
				show action in edit record menu = true
				condition = (Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Paid" || Blueprint.Current_Stage == "Overdue")
				confirmation before execution
				(
					message for individual record = "Execute the  action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Bulk Approve"
				(
	  			workflow = Bulk_Approve_Invoices
				show action in view header = true
				condition = (Blueprint.Current_Stage == "Pending Approval")
				)
				"Send Email"
				(
	  			workflow = Send_Email5
				show action in view header = true
				show action in edit record menu = true
				condition = (Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Paid" || Blueprint.Current_Stage == "Overdue")
				confirmation before execution
				(
					message for individual record = "Execute the Send Email action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Convert To Debit Note"
				(
	  			workflow = Convert_To_Debit_Note1
				show action in view header = true
				show action in edit record menu = true
				condition = (Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "paid" || Blueprint.Current_Stage == "Overdue")
				confirmation before execution
				(
					message for individual record = "Are sure you want to convert this Invoice  ${Invoice_No} to Debit Note?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Submit Invoice to LHDN"
				(
	  			workflow = Submit_Invoice_to_LHDN
				show action in view header = true
				show action in edit record menu = true
				condition = (Blueprint.Current_Stage == "Approved")
				)
			)
			conditional formatting
			(
				"Overdue"
				{
				condition = (Blueprint.Current_Stage == "Approved" || Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Overdue" && Due_Date < zoho.currentdate)
				fields = [Due_Date]
				format = "color:#e64d3b;"
				}
				"Rejection Reason"
				{
				fields = [Rejection_Reason]
				format = "color:#e64d3b;"
				}
			)
		}
		default list Deposit_Payment_Received_Line_Item_Report
		{
			displayName = "Deposit Payment Received Line Item Report"
			show all rows from Payment_Received_Line_Item  [Payment_Received.Payment_Type == "Deposit"]  
			(
				Invoice_No as "Invoice No."
				Document_Date as "Document Date"
				Amount
				Outstanding_Balance as "Outstanding Balance"
				Allocation
				Payment_Received as "Payment Received"
				Reference_No as "Reference No."
				Description
				Allocation_MYR as "Allocation (MYR)"
				Still_Owing as "Still Owing"
				Debit_Note_No as "Debit Note No."
				Pro_Forma_Invoice_No as "Pro Forma Invoice No."
			)
		}
		default list Deposit_Payment_Received_Report
		{
			displayName = "Deposit Payment Received Report"
			show all rows from Payment_Received  [Payment_Type == "Deposit"]  
			(
				Customer_Code as "Customer Code"
				Customer_Name as "Customer Name"
				Payment_Date as "Payment Date"
				Payment_Method as "Payment Method"
				Amount_Received as "Amount Received"
				(
					display = total	
				)
				Reference
				Payment_Received_No as "Payment Received No."
				Paid_To as "Paid To"
				Customer_TIN as "Customer TIN"
				Customer_SST as "Customer SST"
				Customer_Email as "Customer Email"
				Receipt_Sent as "Receipt Sent"
				(
						displaytrue = "Yes"
						displayfalse = "No"
				)
				Amount_Received_MYR as "Amount Received (MYR)"
				(
					display = total	
				)
				Customer_Name.Added_Time as "Added Time"
				Customer_Name.Added_User as "Added User"
				Customer_Name.Modified_Time as "Modified Time"
				Customer_Code.Modified_User as "Modified User"
			)
			custom actions
			(
				"Mark As Sent"
				(
	  			workflow = Mark_As_Sent_Payment_Rece
				show action in view header = true
				condition = (Receipt_Sent == false)
				confirmation before execution
				(
					message for individual record = "Are you sure you want to \"Mark As Sent\" this Payment Received   ${Payment_Received_No} ?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Send Payment Received"
				(
	  			workflow = Send_Payment_Receveid_Dep
				show action in view header = true
				confirmation before execution
				(
					message for individual record = "Are you sure you want to \"Send Payment Received \" this Payment Received   ${Payment_Received_No} ?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
			)
			conditional formatting
			(
				"Yes"
				{
				condition = (Receipt_Sent == true)
				fields = [Receipt_Sent]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"No"
				{
				condition = (Receipt_Sent == false)
				fields = [Receipt_Sent]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
