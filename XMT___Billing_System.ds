\n            face=\"arimo\"><br /><\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"> <span>${Sub_Total_Monthly_Rental}<\/span> <br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"> <span>${Total_Tax_Monthly_Rental}<\/span> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n            face=\"arimo\">Internet Charges<\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n            face=\"arimo\"><br /><\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"> <span>${Sub_Total_Internet_Charges}<\/span> <br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"><span>${Total_Tax_Internet_Charges}<\/span><br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\">Call Charges<\/font><\/td>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n                face=\"arimo\"><span><font style=\"\"\n          color=\"#000000\">${Sub_Total_Call_Charges}<\/font><\/span><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n                face=\"arimo\"><span><font style=\"\"\n          color=\"#000000\">${Total_Tax_Call_Charges}<\/font><\/span><br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\" color=\"#000000\"\n          face=\"arimo\"><b>Total<\/b><\/font><\/td>\n      <td\n            style=\"border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\" color=\"#000000\" face=\"arimo\"><b\n          style=\"\"> ${Sub_Total} <br /><\/b><\/font><\/td>\n      <td\n            style=\"text-align: right; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\" face=\"arimo\"><span><font\n                    color=\"#000000\"><b> <font style=\"\">${Total_Tax}<\/font><\/b><\/font> <\/span> <br /><\/font><\/td>\n     <\/tr>\n    <\/tbody>\n   <\/table>\n  <\/div>"}},{"type":"text","element":{"id":"u_elem_161517163","fields":[],"content":"<div style=\"background: rgba(0, 0, 0, 0); padding: 0px\">\n   <h1\n      style=\"text-align: center; color: rgb(0, 0, 0); font-style: normal\"><font\n        style=\"\"> <font face=\"arimo\" style=\"font-size: 10px\"> <font\n            style=\"font-weight: 400\"> <font\n          style=\"\">\u200b<\/font>\u200b<\/font> <font style=\"\"><b style=\"\">This is a computer generated document and therefore no signature is required<\/b><\/font> <\/font> <\/font><\/h1>\n  <\/div>"}}],"style":""},{"colElements":[{"type":"spacer","element":{"id":"u_elem_1701381780000019","height":"25"}}],"style":""}]}},{"type":"columns","element":{"split":"100","id":"u_elem_118566535","elemStyle":"","collayouts":[{"colElements":[{"id":"u_elem_12504808640836898","type":"fields","element":{"valueStyle":"width: 50%; text-align: left","valueTextStyle":"font-size: 12px; width: 75%","fieldLayoutType":"2","labelText":"QR Invoice Public Link","wrapperStyle":"","labelStyle":"width: 50%","Label_Name":"QR_Invoice_Public_Link","labelTextStyle":""}},{"type":"spacer","element":{"id":"u_elem_11856653200000048","height":"25"}}],"style":""}]}},{"type":"columns","element":{"split":"100","id":"u_elem_17849664699999988","elemStyle":"","collayouts":[{"colElements":[{"type":"spacer","element":{"id":"u_elem_17849664600000024","height":"25"}}],"style":""}]}}],"id":1}],"resize":"a4","themeFont":"lato","isHeaderEnabled":false}
				}
			}
		}
		form Role
		{
			success message = "Role Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Role
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Subscription
		{
			success message = "Subscription Added Successfully"
			feature property = 64
			Customer_Info_Section
			(
				type = section
				displayname = "Customer Info Section"
				visibility = true
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Customer_Name
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customer_Profile.ID
    			displayformat = [Customer_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Customer_PO_No
			(
    			type = text
				displayname = "Customer PO No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Attachment
			(
    			type = upload file
				browse = local_drive
	 			row = 1
	 			column = 1   
				width = medium
			)
			Subscription_No
			(
    			type = text
				displayname = "Subscription No"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Customer_Code
			(
				type = picklist	
				displayname = "Customer Code"
				values  = Tenancy[Customer_Name.ID == input.Customer_Name].ID
    			displayformat = [Customer_Code]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Contact
			(
    			type = text
				displayname = "Technical Contact Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Technical_Email
			(
    			type = email
				displayname = "Technical Email"
				maxchar = 80
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			must have Phone_Number
			(
    			type = phonenumber
				displayname = "Technical Phone Number"
    			defaultcountry="my"
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			Contract_Terms_Section
			(
				type = section
				displayname = "Contract Terms Section"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Contract_Start_Date
			(
    			type = date
