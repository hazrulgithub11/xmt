			Handle_Credit_Note_Select1 as "Handle Credit_Note_Selection_Trigger Workflow"
			{
				type =  form
				form = Apply_Credit_To_Invoices

				record event = on add or edit

				on user input of Credit_Note_Selection_Trigger
				{
					actions 
					{
						custom deluge script
						(
											// Credits Note fields
										clear Unpaid_Invoices;
										input.Credits_Remaining = input.invoice.Credits_Remaining;
										get_credit_note = Credit_Note[ID == input.invoice];
										reference_invoice_id = get_credit_note.Reference_Invoice;
										// Invoice selection
										unpaid_invoice_list = Invoice[Customer == input.invoice.Customer && Amount_Due > 0 && Blueprint.Current_Stage in {"Sent","Partially Paid","Overdue"}];
										for each  curr_unpaid_invoice in unpaid_invoice_list
										{
											curr_new_invoice_row = Apply_Credit_To_Invoices.Unpaid_Invoices();
											curr_new_invoice_row.Invoice=curr_unpaid_invoice.ID;
											curr_new_invoice_row.Invoice_Date=curr_unpaid_invoice.Invoice_Date;
											curr_new_invoice_row.Grand_Total=curr_unpaid_invoice.Grand_Total;
											curr_new_invoice_row.Amount_Due=curr_unpaid_invoice.Amount_Due;
											curr_new_invoice_row.Credits_To_Apply=0;
											if(reference_invoice_id != null && curr_unpaid_invoice.ID == reference_invoice_id)
											{
												credits_to_apply = curr_unpaid_invoice.Amount_Due;
												if(credits_to_apply > input.Credits_Remaining)
												{
													credits_to_apply = input.Credits_Remaining;
												}
												curr_new_invoice_row.Credits_To_Apply=credits_to_apply;
											}
											input.Unpaid_Invoices.insert(curr_new_invoice_row);
										}
						)
					}
				}

			}
