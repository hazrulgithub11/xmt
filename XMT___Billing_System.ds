    				Send_Invoice as "Send Invoice"
    				{
         				type = normal
         				from stage = "Approved"
         				to stage = "Sent"
         				before
         				{
            				transition criteria = (Invoice_UUID is not null && QR_Invoice_Public_Link is not null)
         				}
         				after
         				{
							actions 
							{
								custom deluge script
								(
															if(input.Due_Date > today)
														{
															thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Sent",input.ID);
															Status = "Sent";
														}
														else
														{
															thisapp.blueprint.changeStage("Debit_Note","Debit_Note_Blueprint","Overdue",input.ID);
															Status = "Overdue";
														}
														if(input.Customer.Credit_Available > 0)
														{
															getCustomerProfile = Customer_Profile[ID == input.Customer];
															msg = "message=" + input.Customer.Customer_Name + " has a credit balance of " + getCustomerProfile.Credit_Available + ". Would you like to apply it to this Debit Note " + input.Invoice_No + "?";
															customerName = "&Customer_Name=" + input.Customer;
															customerCode = "&Customer_Code=" + input.Customer_Code;
															invoice = "&Invoice=" + input.ID;
															customerEmail = "&Customer_Email=" + input.Customer_E_mail;
															invoiceNo = "&Invoice_No=" + input.Invoice_No;
															typeOfAction = "&Type_Of_Action=Send Invoice";
															openUrl("#Form:Notify_Credits_Available?" + msg + customerName + customerCode + invoice + customerEmail + invoiceNo + typeOfAction,"popup window","height=auto,width=auto");
														}
								)
							}
         				}
         				chart data
         				{
             				from port : R1
             				to port   : L1
