						(
											disable Opening_Balance;
										disable Invoiced_Amount;
										disable Amount_Paid;
										disable Balance_Due;
										disable Transactions.Date_field;
										disable Transactions.Transaction;
										disable Transactions.Details;
										disable Transactions.Amount;
										disable Transactions.Payments;
										disable Transactions.Balance;
						)
					}
				}

			}
