		 functions
		 {
			 Deluge
			 {
				 void close_form()
                 {
                 	openUrl("#Script:page.parent.refresh","parent window");
                 }
				 void FilterOverdueRec(string report_name)
                 {
                 	url = "https://creatorapp.zoho.com" + zoho.appuri + "#Report:" + report_name + "?Status=Sent&Due_Date_op=22&Due_Date=" + zoho.currentdate;
                 	openUrl(url,"same window");
                 }
				 string get_invoice_usage(date usage_date)
                 {
                 	usage_year = usage_date.getYear().toString();
                 	month_number = usage_date.getMonth();
                 	if(month_number == 1)
                 	{
                 		month_name = "January";
                 	}
                 	else if(month_number == 2)
                 	{
                 		month_name = "February";
                 	}
                 	else if(month_number == 3)
                 	{
                 		month_name = "March";
                 	}
                 	else if(month_number == 4)
                 	{
                 		month_name = "April";
                 	}
                 	else if(month_number == 5)
                 	{
                 		month_name = "May";
                 	}
                 	else if(month_number == 6)
                 	{
                 		month_name = "June";
                 	}
                 	else if(month_number == 7)
                 	{
                 		month_name = "July";
                 	}
                 	else if(month_number == 8)
                 	{
                 		month_name = "August";
                 	}
                 	else if(month_number == 9)
                 	{
                 		month_name = "September";
                 	}
                 	else if(month_number == 10)
                 	{
                 		month_name = "October";
                 	}
                 	else if(month_number == 11)
                 	{
                 		month_name = "November";
                 	}
                 	else if(month_number == 12)
                 	{
                 		month_name = "December";
                 	}
                 	return month_name + " " + usage_year;
                 }
				 bool is_leap_year(int year)
                 {
                 	if(year % 400 == 0)
                 	{
                 		return true;
                 	}
                 	else if(year % 100 == 0)
                 	{
                 		return false;
                 	}
                 	else if(year % 4 == 0)
                 	{
                 		return true;
                 	}
                 	else
                 	{
                 		return false;
                 	}
                 }
				 void send_email_notification(string doc_type, string doc_no, bigint doc_id)
                 {
                 	current_user_email = zoho.loginuserid;
                 	doc_type_label = "";
                 	report_status_param = "";
                 	if(doc_type == "invoice")
                 	{
                 		doc_type_label = "Invoice";
                 		report_status_param = "Status=Pending+Approval";
                 	}
                 	else if(doc_type == "credit_note")
                 	{
                 		doc_type_label = "Credit Note";
                 		report_status_param = "Status=Pending+Approval";
                 	}
                 	else if(doc_type == "pro_forma")
                 	{
                 		doc_type_label = "Pro Forma Invoice";
                 		report_status_param = "Status=Pending+Approval";
                 	}
                 	else if(doc_type == "debit_note")
                 	{
                 		doc_type_label = "Debit Note";
                 		report_status_param = "Status=Pending+Approval";
                 	}
                 	notify_title = doc_type_label + " " + doc_no + " Approval Required";
                 	notify_message = "Please review and approve " + doc_type_label + " " + doc_no + " to complete processing.";
                 	url_report = "https://creatorapp.zoho.com" + zoho.appuri + "#Report:All_Invoices?" + report_status_param;
                 	sendmail
                 	[
                 		from :zoho.adminuserid
                 		to :current_user_email
                 		subject :doc_type_label + " " + doc_no + " Approval Required"
                 		message :"Dear,<br><br>We hope this message finds you well. Please review and approve " + doc_type_label + " " + doc_no + " at your earliest convenience. You can view the record by clicking <a href='" + url_report + "'>here</a>.<br><br>Best Regards,<br>XMT Technologies Sdn Bhd"
                 	]
                 }
				 list sort_list(list unsortedList, string sortKey)
                 {
                 	keyList = List();
                 	for each  u in unsortedList
                 	{
                 		keyList.add(u.get(sortKey));
                 	}
                 	keyList = keyList.distinct().sort();
                 	// Iterate over unsortedList in order of the sorted keyList to create the sortedList
                 	sortedList = list();
                 	for each  k in keyList
                 	{
                 		for each  u in unsortedList
                 		{
                 			if(u.get(sortKey) == k)
                 			{
                 				sortedList.add(u);
                 			}
                 		}
                 	}
                 	return sortedList;
                 }
				 string credit_note.generate_credit_note_no()
                 {
                 	prefix = "CN" + zoho.currentdate.getYear().toString().subText(2,4);
                 	invoiceInfo = Credit_Note[Invoice_No.containsIgnoreCase(prefix) && Invoice_No != ""] sort by Invoice_No desc;
                 	if(invoiceInfo.ID == null)
                 	{
                 		count = 0;
                 	}
                 	else
                 	{
                 		count = invoiceInfo.Invoice_No.getsuffix(prefix).toLong();
                 	}
                 	count = count + 1;
                 	if(count < 10)
                 	{
                 		pad = "00000";
                 	}
                 	else if(count < 100)
                 	{
                 		pad = "0000";
                 	}
                 	else if(count < 1000)
                 	{
                 		pad = "000";
                 	}
                 	else if(count < 10000)
                 	{
                 		pad = "00";
                 	}
                 	else if(count < 100000)
                 	{
                 		pad = "0";
                 	}
                 	else
                 	{
                 		pad = "";
                 	}
                 	invNumber = prefix + pad + count;
                 	return invNumber;
                 }
				 string debit_note.generate_debit_note_no()
                 {
                 	prefix = "DN" + zoho.currentdate.getYear().toString().subText(2,4);
                 	invoiceInfo = Debit_Note[Invoice_No.containsIgnoreCase(prefix) && Invoice_No != ""] sort by Invoice_No desc;
                 	if(invoiceInfo.ID == null)
                 	{
                 		count = 0;
                 	}
                 	else
                 	{
                 		count = invoiceInfo.Invoice_No.getsuffix(prefix).toLong();
                 	}
                 	count = count + 1;
                 	if(count < 10)
                 	{
                 		pad = "00000";
                 	}
                 	else if(count < 100)
                 	{
                 		pad = "0000";
                 	}
                 	else if(count < 1000)
                 	{
                 		pad = "000";
                 	}
                 	else if(count < 10000)
                 	{
                 		pad = "00";
                 	}
                 	else if(count < 100000)
                 	{
                 		pad = "0";
                 	}
                 	else
                 	{
                 		pad = "";
                 	}
                 	invNumber = prefix + pad + count;
                 	return invNumber;
                 }
				 string deposit.generate_proforma_invoice_no()
                 {
                 	prefix = "PI";
                 	depositInfo = Pro_Forma_Invoices[Invoice_No.containsIgnoreCase(prefix) && Invoice_No != ""] sort by Invoice_No desc;
                 	if(depositInfo.ID == null)
                 	{
                 		count = 0;
                 	}
                 	else
                 	{
                 		count = depositInfo.Invoice_No.getsuffix(prefix).toLong();
                 	}
                 	count = count + 1;
                 	if(count < 10)
                 	{
                 		pad = "000";
                 	}
                 	else if(count < 100)
                 	{
                 		pad = "00";
                 	}
                 	else if(count < 1000)
                 	{
                 		pad = "0";
                 	}
                 	else
                 	{
                 		pad = "";
                 	}
                 	depositNumber = prefix + pad + count;
                 	return depositNumber;
                 }
				 void invoice.calculate_invoice_previous_balance_and_total_amount_due(int invoice_id)
                 {
                 	get_invoice = Invoice[ID == invoice_id];
                 	get_customer_id = get_invoice.Customer;
                 	get_amount_due = get_invoice.Amount_Due;
                 	previous_balance_of_unpaid_invoices = 0;
                 	for each  curr_invoice in Invoice[Amount_Due > 0 && Blueprint.Current_Stage in {"Sent","Overdue","Partially Paid"} && Customer == get_customer_id && ID != invoice_id]
                 	{
                 		previous_balance_of_unpaid_invoices = previous_balance_of_unpaid_invoices + curr_invoice.Amount_Due;
                 	}
                 	total_amount_due = get_amount_due + previous_balance_of_unpaid_invoices;
                 	get_invoice.Previous_Balance=previous_balance_of_unpaid_invoices;
                 	get_invoice.Total_Amount_Due=total_amount_due;
                 }
				 map invoice.calculate_subtotal_item_line(string mode, decimal unit_price, decimal quantity, date range_start, date range_end)
                 {
                 	line_amounts = Map();
                 	if(mode == "single_period")
                 	{
                 		line_amounts.put("subTotal",(unit_price * quantity).round(2));
                 	}
                 	else if(mode == "prorate_start_month")
                 	{
                 		prorate_unit_price = unit_price / range_start.eomonth(0).getDay();
                 		days_used = range_start.eomonth(0).getDay() - range_start.getDay() + 1;
                 		sub_total = (prorate_unit_price * days_used * quantity).round(2);
                 		line_amounts.put("subTotal",sub_total);
                 		line_amounts.put("unitPrice",sub_total);
                 		line_amounts.put("quantity",1);
                 	}
                 	else if(mode == "prorate_final_month")
                 	{
                 		prorate_unit_price = unit_price / range_end.eomonth(0).getDay();
                 		sub_total = (prorate_unit_price * range_end.getDay() * quantity).round(2);
                 		line_amounts.put("subTotal",sub_total);
                 		line_amounts.put("unitPrice",sub_total);
                 		line_amounts.put("quantity",1);
                 	}
                 	else if(mode == "days30")
                 	{
                 		days_ratio = ((daysBetween(range_start,range_end) + 1) / 30).round(2);
                 		sub_total = (unit_price * quantity * days_ratio).round(2);
                 		display_quantity = days_ratio;
                 		display_unit_price = unit_price * quantity;
                 		if(days_ratio < 1)
                 		{
                 			display_quantity = 1;
                 			display_unit_price = sub_total;
                 		}
                 		line_amounts.put("subTotal",sub_total);
                 		line_amounts.put("quantity",display_quantity);
                 		line_amounts.put("unitPrice",display_unit_price);
                 	}
                 	return line_amounts;
                 }
				 map invoice.calculate_tax_item_line(decimal sub_total, decimal tax_pct)
                 {
                 	tax_amount = (sub_total * tax_pct / 100).round(2);
                 	total = (sub_total + tax_amount).round(2);
                 	line_tax = Map();
                 	line_tax.put("taxAmount",tax_amount);
                 	line_tax.put("total",total);
                 	return line_tax;
                 }
				 void invoice.create_invoice_current_duration(bool is_monthly, int subscription_id, date monthly_billing_date, date actual_billing_date, bool create_second_invoice, date second_monthly_billing_date, date second_actual_billing_date, bool sub_submission)
                 {
                 	/* --- Initialise running totals (accumulated across all line items) --- */
                 	grand_total = 0;
                 	sub_total_monthly_rental = 0;
                 	total_tax_monthly_rental = 0;
                 	grand_total_monthly_rental = 0;
                 	sub_total_internet_charges = 0;
                 	total_tax_internet_charges = 0;
                 	grand_total_internet_charges = 0;
                 	sub_total_call_charges = 0;
                 	total_tax_call_charges = 0;
                 	grand_total_call_charges = 0;
                 	total_deposit_amount = 0;
                 	/* --- Fetch subscription details --- */
                 	subscription_info = Subscription[ID == subscription_id];
                 	subscription_currency = subscription_info.Subscription_Currency;
                 	subscription_exchange_rate = subscription_info.Exchange_Rate;
                 	subscription_payable_to = subscription_info.Payable_To;
                 	subscription_final_billing_date = subscription_info.Final_Billing_Date;
                 	subscription_contract_start_date = subscription_info.Contract_Start_Date;
                 	subscription_contract_end_date = subscription_info.Contract_End_Date;
                 	subscription_bill_for = subscription_info.Bill_For;
                 	subscription_bill_every = subscription_info.Bill_Every;
                 	subscription_billing_cycle = subscription_info.Billing_Cycle;
                 	subscription_billing_cycle_int = thisapp.tenancy.convert_bill_cycle_to_int(subscription_billing_cycle);
                 	/* --- Fetch tenant and subscription context --- */
                 	tenancy_info = Tenancy[ID == subscription_info.Customer_Code];
                 	tenancy_enable_reminder = tenancy_info.Enable_Reminder;
                 	customer = tenancy_info.Customer_Name;
                 	customer_email_address = customer.Email_Address;
                 	/* Carry forward any pro-forma invoice deposit already collected */
                 	pi_grand_total = Pro_Forma_Invoices[ID == subscription_info.Pro_Forma_Invoices].Grand_Total;
                 	total_deposit_amount = total_deposit_amount + ifnull(pi_grand_total,0);
                 	new_next_billing_date = null;
                 	if(is_monthly)
                 	{
                 		/* Clamp actual_billing_date to at least the start of the billing month */
                 		if(actual_billing_date < monthly_billing_date.toStartOfMonth())
                 		{
                 			actual_billing_date = monthly_billing_date;
                 		}
                 		due_date = actual_billing_date.addDay(tenancy_info.Payment_Term.Days);
                 		/* Calculate the next billing date only when billing on the scheduled date */
                 		if(monthly_billing_date == actual_billing_date)
                 		{
                 			new_next_billing_date = actual_billing_date.addMonth(subscription_billing_cycle_int);
                 			/* Resolve the target day-of-month, handling "Last Day Of Month" specially */
                 			if(subscription_bill_every != "Last Day Of Month")
                 			{
                 				bill_every_int = subscription_bill_every.toLong();
                 			}
                 			else
                 			{
                 				bill_every_int = new_next_billing_date.eomonth(0).getDay();
                 			}
                 			/* Correct the day if it drifted (addMonth can shift the day in short months),
                 			   but skip February where day correction is unreliable */
                 			if(new_next_billing_date.getDay() != bill_every_int && new_next_billing_date.getMonth() != 2 && subscription_bill_every != "Last Day Of Month")
                 			{
                 				new_next_billing_date = toDate(subscription_bill_every + "-" + new_next_billing_date.getMonth() + "-" + new_next_billing_date.getYear(),"dd-MM-yyyy");
                 			}
                 		}
                 		else
                 		{
                 			/* Prorate scenario: next billing stays aligned to the original schedule */
                 			new_next_billing_date = monthly_billing_date.addMonth(subscription_billing_cycle_int);
                 		}
                 		/* Snap to last day of month when the tenant bills on the last day */
                 		if(subscription_bill_every == "Last Day Of Month")
                 		{
                 			new_next_billing_date = new_next_billing_date.eomonth(0);
                 		}
                 		invoice_usage = thisapp.get_invoice_usage(actual_billing_date);
                 		next_billing_date = subscription_info.Next_Billing_Date;
                 		last_billing_date = subscription_info.Latest_Billing_Date;
                 		subscription_prorate = subscription_info.Prorate;
                 		/* --- Determine billing type for line-item calculation --- */
                 		billing_type = "";
                 		is_final_billing = false;
                 		/* Prorate for the first partial month, or when billing started mid-cycle */
                 		if(actual_billing_date != monthly_billing_date || (actual_billing_date == monthly_billing_date && last_billing_date == null && actual_billing_date != subscription_final_billing_date && subscription_contract_start_date.getDay() != actual_billing_date.getDay()))
                 		{
                 			if(subscription_prorate)
                 			{
                 				billing_type = "prorate_start_month";
                 			}
                 			else
                 			{
                 				billing_type = "single_period";
                 			}
                 		}
                 		/* Final billing date handling */
                 		else if(actual_billing_date == subscription_final_billing_date)
                 		{
                 			/* Full period when contract ends on the last day of month, or no next date and no prorate */
                 			if((subscription_contract_end_date.getDay() == subscription_contract_end_date.eomonth(0).getDay() && next_billing_date != null) || (next_billing_date == null && !subscription_prorate))
                 			{
                 				billing_type = "single_period";
                 				is_final_billing = true;
                 			}
                 			else
                 			{
                 				billing_type = "prorate_final_month";
                 			}
                 		}
                 		/* Normal mid-contract billing period */
                 		else if(actual_billing_date == monthly_billing_date && actual_billing_date != subscription_final_billing_date)
                 		{
                 			billing_type = "single_period";
                 		}
                 		/* --- Accumulate line items for all charge categories --- */
                 		if(billing_type != "")
                 		{
                 			/* Monthly rental line items */
                 			for each  curr_monthly_rental_line_item in subscription_info.Monthly_Rental
                 			{
                 				unit_price = curr_monthly_rental_line_item.Unit_Price_Monthly_Rental;
                 				quantity = curr_monthly_rental_line_item.Quantity_Monthly_Rental;
                 				tax_pct = curr_monthly_rental_line_item.Tax_Pct_Monthly_Rental;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper(billing_type,unit_price,quantity,tax_pct,is_final_billing,subscription_exchange_rate,subscription_contract_start_date,subscription_contract_end_date,actual_billing_date);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_monthly_rental = sub_total_monthly_rental + amounts.get("subTotal");
                 				total_tax_monthly_rental = total_tax_monthly_rental + amounts.get("taxAmount");
                 				grand_total_monthly_rental = grand_total_monthly_rental + amounts.get("total");
                 			}
                 			/* Internet charges line items */
                 			for each  curr_internet_charges_line_item in subscription_info.Internet_Charges
                 			{
                 				unit_price = curr_internet_charges_line_item.Unit_Price_Internet_Charges;
                 				quantity = curr_internet_charges_line_item.Quantity_Internet_Charges;
                 				tax_pct = curr_internet_charges_line_item.Tax_Pct_Internet_Charges;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper(billing_type,unit_price,quantity,tax_pct,is_final_billing,subscription_exchange_rate,subscription_contract_start_date,subscription_contract_end_date,actual_billing_date);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_internet_charges = sub_total_internet_charges + amounts.get("subTotal");
                 				total_tax_internet_charges = total_tax_internet_charges + amounts.get("taxAmount");
                 				grand_total_internet_charges = grand_total_internet_charges + amounts.get("total");
                 			}
                 			/* Call charges line items */
                 			for each  curr_call_charges_line_item in subscription_info.Call_Charges
                 			{
                 				unit_price = curr_call_charges_line_item.Unit_Price_Call_Charges;
                 				quantity = curr_call_charges_line_item.Quantity_Call_Charges;
                 				tax_pct = curr_call_charges_line_item.Tax_Pct_Call_Charges;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper(billing_type,unit_price,quantity,tax_pct,is_final_billing,subscription_exchange_rate,subscription_contract_start_date,subscription_contract_end_date,actual_billing_date);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_call_charges = sub_total_call_charges + amounts.get("subTotal");
                 				total_tax_call_charges = total_tax_call_charges + amounts.get("taxAmount");
                 				grand_total_call_charges = grand_total_call_charges + amounts.get("total");
                 			}
                 		}
                 	}
                 	else
                 	{
                 		/* --- Non-monthly billing path --- */
                 		due_date = actual_billing_date.addDay(tenancy_info.Payment_Term.Days);
                 		invoice_usage = thisapp.get_invoice_usage(monthly_billing_date);
                 		/* Case 1: Contract started before the billing month and billing is delayed (mid-period catch-up) */
                 		if(subscription_contract_start_date < monthly_billing_date && actual_billing_date != monthly_billing_date)
                 		{
                 			/* Monthly rental line items — full single period */
                 			for each  curr_monthly_rental_line_item in subscription_info.Monthly_Rental
                 			{
                 				unit_price = curr_monthly_rental_line_item.Unit_Price_Monthly_Rental;
                 				quantity = curr_monthly_rental_line_item.Quantity_Monthly_Rental;
                 				tax_pct = curr_monthly_rental_line_item.Tax_Pct_Monthly_Rental;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,null,null);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_monthly_rental = sub_total_monthly_rental + amounts.get("subTotal");
                 				total_tax_monthly_rental = total_tax_monthly_rental + amounts.get("taxAmount");
                 				grand_total_monthly_rental = grand_total_monthly_rental + amounts.get("total");
                 			}
                 			/* Internet charges line items */
                 			for each  curr_internet_charges_line_item in subscription_info.Internet_Charges
                 			{
                 				unit_price = curr_internet_charges_line_item.Unit_Price_Internet_Charges;
                 				quantity = curr_internet_charges_line_item.Quantity_Internet_Charges;
                 				tax_pct = curr_internet_charges_line_item.Tax_Pct_Internet_Charges;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,null,null);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_internet_charges = sub_total_internet_charges + amounts.get("subTotal");
                 				total_tax_internet_charges = total_tax_internet_charges + amounts.get("taxAmount");
                 				grand_total_internet_charges = grand_total_internet_charges + amounts.get("total");
                 			}
                 			/* Call charges line items */
                 			for each  curr_call_charges_line_item in subscription_info.Call_Charges
                 			{
                 				unit_price = curr_call_charges_line_item.Unit_Price_Call_Charges;
                 				quantity = curr_call_charges_line_item.Quantity_Call_Charges;
                 				tax_pct = curr_call_charges_line_item.Tax_Pct_Call_Charges;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,null,null);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_call_charges = sub_total_call_charges + amounts.get("subTotal");
                 				total_tax_call_charges = total_tax_call_charges + amounts.get("taxAmount");
                 				grand_total_call_charges = grand_total_call_charges + amounts.get("total");
                 			}
                 		}
                 		/* Case 2: Final billing date — determine whether contract ends on a full or partial period */
                 		else if(actual_billing_date == subscription_final_billing_date)
                 		{
                 			/* Project what the end of this billing cycle would be */
                 			usage_end_date = subscription_final_billing_date.addMonth(subscription_billing_cycle_int);
                 			/* Normalise usage_end_date to match contract day-of-month conventions */
                 			if(subscription_contract_start_date.getDay() == subscription_contract_start_date.eomonth(0).getDay() && usage_end_date.getDay() != usage_end_date.eomonth(0).getDay())
                 			{
                 				usage_end_date = usage_end_date.eomonth(0);
                 			}
                 			else if(subscription_contract_start_date.getDay() == 30 && usage_end_date.getDay() != 30)
                 			{
                 				usage_end_date = toDate("30-" + usage_end_date.getMonth() + "-" + usage_end_date.getYear(),"dd-MM-yyyy");
                 			}
                 			/* Sub-case 2a: Projected end aligns with contract end — bill a full period */
                 			if(usage_end_date == subscription_contract_end_date)
                 			{
                 				/* Monthly rental line items — full period, flagged as final billing */
                 				for each  curr_monthly_rental_line_item in subscription_info.Monthly_Rental
                 				{
                 					unit_price = curr_monthly_rental_line_item.Unit_Price_Monthly_Rental;
                 					quantity = curr_monthly_rental_line_item.Quantity_Monthly_Rental;
                 					tax_pct = curr_monthly_rental_line_item.Tax_Pct_Monthly_Rental;
                 					amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,true,subscription_exchange_rate,null,null,null);
                 					grand_total = grand_total + amounts.get("total");
                 					sub_total_monthly_rental = sub_total_monthly_rental + amounts.get("subTotal");
                 					total_tax_monthly_rental = total_tax_monthly_rental + amounts.get("taxAmount");
                 					grand_total_monthly_rental = grand_total_monthly_rental + amounts.get("total");
                 				}
                 				/* Internet charges line items — full period, flagged as final billing */
                 				for each  curr_internet_charges_line_item in subscription_info.Internet_Charges
                 				{
                 					unit_price = curr_internet_charges_line_item.Unit_Price_Internet_Charges;
                 					quantity = curr_internet_charges_line_item.Quantity_Internet_Charges;
                 					tax_pct = curr_internet_charges_line_item.Tax_Pct_Internet_Charges;
                 					amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,true,subscription_exchange_rate,null,null,null);
                 					grand_total = grand_total + amounts.get("total");
                 					sub_total_internet_charges = sub_total_internet_charges + amounts.get("subTotal");
                 					total_tax_internet_charges = total_tax_internet_charges + amounts.get("taxAmount");
                 					grand_total_internet_charges = grand_total_internet_charges + amounts.get("total");
                 				}
                 				/* Call charges line items — full period, flagged as final billing */
                 				for each  curr_call_charges_line_item in subscription_info.Call_Charges
                 				{
                 					unit_price = curr_call_charges_line_item.Unit_Price_Call_Charges;
                 					quantity = curr_call_charges_line_item.Quantity_Call_Charges;
                 					tax_pct = curr_call_charges_line_item.Tax_Pct_Call_Charges;
                 					amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,true,subscription_exchange_rate,null,null,null);
                 					grand_total = grand_total + amounts.get("total");
                 					sub_total_call_charges = sub_total_call_charges + amounts.get("subTotal");
                 					total_tax_call_charges = total_tax_call_charges + amounts.get("taxAmount");
                 					grand_total_call_charges = grand_total_call_charges + amounts.get("total");
                 				}
                 			}
                 			else
                 			{
                 				/* Sub-case 2b: Contract ends mid-period — prorate using 30-day basis */
                 				for each  curr_monthly_rental_line_item in subscription_info.Monthly_Rental
                 				{
                 					unit_price = curr_monthly_rental_line_item.Unit_Price_Monthly_Rental;
                 					quantity = curr_monthly_rental_line_item.Quantity_Monthly_Rental;
                 					tax_pct = curr_monthly_rental_line_item.Tax_Pct_Monthly_Rental;
                 					amounts = thisapp.invoice.create_invoice_current_duration_helper("days30",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,subscription_contract_end_date,actual_billing_date);
                 					grand_total = grand_total + amounts.get("total");
                 					sub_total_monthly_rental = sub_total_monthly_rental + amounts.get("subTotal");
                 					total_tax_monthly_rental = total_tax_monthly_rental + amounts.get("taxAmount");
                 					grand_total_monthly_rental = grand_total_monthly_rental + amounts.get("total");
                 				}
                 				for each  curr_internet_charges_line_item in subscription_info.Internet_Charges
                 				{
                 					unit_price = curr_internet_charges_line_item.Unit_Price_Internet_Charges;
                 					quantity = curr_internet_charges_line_item.Quantity_Internet_Charges;
                 					tax_pct = curr_internet_charges_line_item.Tax_Pct_Internet_Charges;
                 					amounts = thisapp.invoice.create_invoice_current_duration_helper("days30",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,subscription_contract_end_date,actual_billing_date);
                 					grand_total = grand_total + amounts.get("total");
                 					sub_total_internet_charges = sub_total_internet_charges + amounts.get("subTotal");
                 					total_tax_internet_charges = total_tax_internet_charges + amounts.get("taxAmount");
                 					grand_total_internet_charges = grand_total_internet_charges + amounts.get("total");
                 				}
                 				for each  curr_call_charges_line_item in subscription_info.Call_Charges
                 				{
                 					unit_price = curr_call_charges_line_item.Unit_Price_Call_Charges;
                 					quantity = curr_call_charges_line_item.Quantity_Call_Charges;
                 					tax_pct = curr_call_charges_line_item.Tax_Pct_Call_Charges;
                 					amounts = thisapp.invoice.create_invoice_current_duration_helper("days30",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,subscription_contract_end_date,actual_billing_date);
                 					grand_total = grand_total + amounts.get("total");
                 					sub_total_call_charges = sub_total_call_charges + amounts.get("subTotal");
                 					total_tax_call_charges = total_tax_call_charges + amounts.get("taxAmount");
                 					grand_total_call_charges = grand_total_call_charges + amounts.get("total");
                 				}
                 			}
                 		}
                 		/* Case 3: Regular on-schedule billing — not final, not a catch-up */
                 		else if(actual_billing_date == monthly_billing_date && actual_billing_date != subscription_final_billing_date)
                 		{
                 			/* Monthly rental line items */
                 			for each  curr_monthly_rental_line_item in subscription_info.Monthly_Rental
                 			{
                 				unit_price = curr_monthly_rental_line_item.Unit_Price_Monthly_Rental;
                 				quantity = curr_monthly_rental_line_item.Quantity_Monthly_Rental;
                 				tax_pct = curr_monthly_rental_line_item.Tax_Pct_Monthly_Rental;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,null,null);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_monthly_rental = sub_total_monthly_rental + amounts.get("subTotal");
                 				total_tax_monthly_rental = total_tax_monthly_rental + amounts.get("taxAmount");
                 				grand_total_monthly_rental = grand_total_monthly_rental + amounts.get("total");
                 			}
                 			/* Internet charges line items */
                 			for each  curr_internet_charges_line_item in subscription_info.Internet_Charges
                 			{
                 				unit_price = curr_internet_charges_line_item.Unit_Price_Internet_Charges;
                 				quantity = curr_internet_charges_line_item.Quantity_Internet_Charges;
                 				tax_pct = curr_internet_charges_line_item.Tax_Pct_Internet_Charges;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,null,null);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_internet_charges = sub_total_internet_charges + amounts.get("subTotal");
                 				total_tax_internet_charges = total_tax_internet_charges + amounts.get("taxAmount");
                 				grand_total_internet_charges = grand_total_internet_charges + amounts.get("total");
                 			}
                 			/* Call charges line items */
                 			for each  curr_call_charges_line_item in subscription_info.Call_Charges
                 			{
                 				unit_price = curr_call_charges_line_item.Unit_Price_Call_Charges;
                 				quantity = curr_call_charges_line_item.Quantity_Call_Charges;
                 				tax_pct = curr_call_charges_line_item.Tax_Pct_Call_Charges;
                 				amounts = thisapp.invoice.create_invoice_current_duration_helper("single_period",unit_price,quantity,tax_pct,false,subscription_exchange_rate,null,null,null);
                 				grand_total = grand_total + amounts.get("total");
                 				sub_total_call_charges = sub_total_call_charges + amounts.get("subTotal");
                 				total_tax_call_charges = total_tax_call_charges + amounts.get("taxAmount");
                 				grand_total_call_charges = grand_total_call_charges + amounts.get("total");
                 			}
                 		}
                 		else
                 		{
                 			/* No billing case matched — skip to prevent a zero-total ghost invoice */
                 			return;
                 		}
                 	}
                 	/* --- Create the invoice record --- */
                 	inv_no = thisapp.invoice.generate_invoice_number();
                 	organization_info = Organization_Settings[ID != null];
                 	customer_profile_info = Customer_Profile[ID == customer];
                 	error_msg = "";
                 	try 
                 	{
                 		create_invoice = insert into Invoice
                 		[
                 			Invoice_No=inv_no
                 			Payment_Term=tenancy_info.Payment_Term
                 			Customer_Code=subscription_info.Customer_Code
                 			Customer=customer
                 			Customer_TIN=customer_profile_info.Customer_TIN
                 			Customer_SST_Registration_Number=ifnull(customer_profile_info.Customer_SST,"")
                 			Customer_E_mail=customer_email_address
                 			Customer_Registration_Identification_Passport_Number=ifnull(customer_profile_info.Customer_Registration_Number,"")
                 			Customer_Street=ifnull(customer_profile_info.Business_Street,"")
                 			Customer_Postcode=ifnull(customer_profile_info.Postcode,"")
                 			Customer_City=ifnull(customer_profile_info.City,"")
                 			Customer_State=ifnull(customer_profile_info.State,null)
                 			Customer_Country=ifnull(customer_profile_info.Country,null)
                 			Supplier_TIN=organization_info.Supplier_TIN
                 			Supplier_SST_Registration_Number=organization_info.SST_ID
                 			Subscriptions=subscription_id
                 			Invoice_Date=actual_billing_date
                 			Due_Date=due_date
                 			Sub_Total_Monthly_Rental=sub_total_monthly_rental
                 			Total_Tax_Monthly_Rental=total_tax_monthly_rental
                 			Grand_Total_Monthly_Rental=grand_total_monthly_rental
                 			Sub_Total_Internet_Charges=sub_total_internet_charges
                 			Total_Tax_Internet_Charges=total_tax_internet_charges
                 			Grand_Total_Internet_Charges=grand_total_internet_charges
                 			Sub_Total_Call_Charges=sub_total_call_charges
                 			Total_Tax_Call_Charges=total_tax_call_charges
                 			Grand_Total_Call_Charges=grand_total_call_charges
                 			Amount_Due=grand_total
                 			Amount_Paid=0
                 			Deposit_Amount=total_deposit_amount
                 			Base_Currency=subscription_currency
                 			Exchange_Rate=subscription_exchange_rate
                 			Payable_To=subscription_payable_to
                 			Invoice_For_Usage=invoice_usage
                 			Enable_Reminder=tenancy_enable_reminder
                 			Added_User=zoho.loginuser
                 			Supplier=Organization_Settings[ID != null].ID
                 		];
                 	}	catch (error)
                 	{
                 		error_msg = error;
                 	}
                 	if(error_msg == "")
                 	{
                 		/* Sync the subscription's next and latest billing date fields */
                 		thisapp.subscription.update_subscription_next_and_last_billing_date(subscription_id,subscription_bill_for,subscription_billing_cycle_int,actual_billing_date,monthly_billing_date,subscription_bill_every);
                 		/* Re-push the category subtotals to the invoice record (ensures totals are persisted correctly) */
                 		get_invoice = Invoice[ID == create_invoice];
                 		get_invoice.Sub_Total_Monthly_Rental=sub_total_monthly_rental;
                 		get_invoice.Total_Tax_Monthly_Rental=total_tax_monthly_rental;
                 		get_invoice.Grand_Total_Monthly_Rental=grand_total_monthly_rental;
                 		get_invoice.Sub_Total_Internet_Charges=sub_total_internet_charges;
                 		get_invoice.Total_Tax_Internet_Charges=total_tax_internet_charges;
                 		get_invoice.Grand_Total_Internet_Charges=grand_total_internet_charges;
                 		get_invoice.Sub_Total_Call_Charges=sub_total_call_charges;
                 		get_invoice.Total_Tax_Call_Charges=total_tax_call_charges;
                 		get_invoice.Grand_Total_Call_Charges=grand_total_call_charges;
                 		/* Recursively create the second invoice if requested (e.g. split billing period) */
                 		if(create_second_invoice)
                 		{
                 			thisapp.invoice.create_invoice_current_duration(is_monthly,subscription_id,second_monthly_billing_date,second_actual_billing_date,false,null,null,true);
                 		}
                 	}
                 }
				 map invoice.create_invoice_current_duration_helper(string billing_type, decimal unit_price, decimal quantity, decimal tax_pct, bool is_final_billing, decimal exchange_rate, date contract_start_date, date contract_end_date, date actual_billing_date)
                 {
                 	if(billing_type == "prorate_start_month")
                 	{
                 		line_amounts = thisapp.invoice.calculate_subtotal_item_line("prorate_start_month",unit_price,quantity,contract_start_date,null);
                 	}
                 	else if(billing_type == "prorate_final_month")
                 	{
                 		line_amounts = thisapp.invoice.calculate_subtotal_item_line("prorate_final_month",unit_price,quantity,null,contract_end_date);
                 	}
                 	else if(billing_type == "days30")
                 	{
                 		line_amounts = thisapp.invoice.calculate_subtotal_item_line("days30",unit_price,quantity,actual_billing_date,contract_end_date);
                 	}
                 	else
                 	{
                 		line_amounts = thisapp.invoice.calculate_subtotal_item_line("single_period",unit_price,quantity,null,null);
                 	}
                 	sub_total = line_amounts.get("subTotal");
                 	line_tax = thisapp.invoice.calculate_tax_item_line(sub_total,tax_pct);
                 	tax_amount = line_tax.get("taxAmount");
                 	total = line_tax.get("total");
                 	result = Map();
                 	result.put("subTotal",sub_total);
                 	result.put("taxAmount",tax_amount);
                 	result.put("total",total);
                 	result.put("totalMyr",total * exchange_rate);
                 	return result;
                 }
				 void invoice.create_invoice_previous_duration(bool is_monthly, int subscription_id, date monthly_billing_date, date actual_billing_date, bool create_second_invoice, date second_monthly_billing_date, date second_actual_billing_date, bool sub_submission)
                 {
                 	/* --- Initialise running totals (accumulated across all line items) --- */
                 	grand_total = 0;
                 	sub_total_call_charges = 0;
                 	total_tax_call_charges = 0;
                 	grand_total_call_charges = 0;
                 	sub_total_monthly_rental = 0;
                 	total_tax_monthly_rental = 0;
                 	grand_total_monthly_rental = 0;
                 	sub_total_internet_charges = 0;
                 	total_tax_internet_charges = 0;
                 	grand_total_internet_charges = 0;
                 	total_deposit_amount = 0;
                 	/* --- Fetch subscription details --- */
                 	subscription_info = Subscription[ID == subscription_id];
                 	subscription_exchange_rate = subscription_info.Exchange_Rate;
                 	last_billing_date = subscription_info.Latest_Billing_Date;
                 	next_billing_date = subscription_info.Next_Billing_Date;
                 	final_billing_date = subscription_info.Final_Billing_Date;
                 	bill_for = subscription_info.Bill_For;
                 	bill_every = subscription_info.Bill_Every;
                 	subscription_billing_cycle = subscription_info.Billing_Cycle;
                 	subscription_billing_cycle_int = thisapp.tenancy.convert_bill_cycle_to_int(subscription_billing_cycle);
                 	subscription_prorate = subscription_info.Prorate;
                 	subscription_payable_to = subscription_info.Payable_To;
                 	contract_end_date = subscription_info.Contract_End_Date;
                 	contract_start_date = subscription_info.Contract_Start_Date;
                 	/* --- Fetch tenant and subscription context --- */
                 	tenancy_info = Tenancy[ID == subscription_info.Customer_Code];
                 	customer = tenancy_info.Customer_Name;
                 	customer_email_address = customer.Email_Address;
                 	enable_reminder = tenancy_info.Enable_Reminder;
                 	due_date = actual_billing_date.addDay(tenancy_info.Payment_Term.Days);
                 	/* BRANCH A: Monthly billing logic */
                 	if(is_monthly)
                 	{
                 		currency = subscription_info.Subscription_Currency;
                 		/* Calculate the next billing date by advancing one billing_cycle from today or from monthly_billing_date */
                 		if(monthly_billing_date == actual_billing_date)
                 		{
                 			new_next_billing_date = actual_billing_date.addMonth(subscription_billing_cycle_int);
                 			/* Resolve bill_every to a day integer; Last Day Of Month uses the last day of the computed month */
                 			if(bill_every != "Last Day Of Month")
                 			{
                 				bill_every_int = bill_every.toLong();
                 			}
                 			else
                 			{
                 				bill_every_int = new_next_billing_date.eomonth(0).getDay();
                 			}
                 			/* Correct the day if month shift landed on the wrong day; skip for February and Last Day Of Month */
                 			if(new_next_billing_date.getDay() != bill_every_int && new_next_billing_date.getMonth() != 2 && bill_every != "Last Day Of Month")
                 			{
                 				new_next_billing_date = toDate(bill_every + "-" + new_next_billing_date.getMonth() + "-" + new_next_billing_date.getYear(),"dd-MM-yyyy");
                 			}
                 		}
                 		else
                 		{
                 			new_next_billing_date = monthly_billing_date.addMonth(subscription_billing_cycle_int);
                 		}
                 		/* Snap next billing date to end of month when using Last Day Of Month mode */
                 		if(bill_every == "Last Day Of Month")
                 		{
                 			new_next_billing_date = new_next_billing_date.eomonth(0);
                 		}
                 		contract_period = subscription_info.Contract_Period;
                 		/* Determine usage reference date, correcting for day-29 and Last Day Of Month edge cases */
                 		usage_date = actual_billing_date.subMonth(1);
                 		if(bill_every == "29" && usage_date.getDay() != 29 && usage_date.getMonth() != 2)
                 		{
                 			usage_date = toDate("29-" + usage_date.getMonth() + "-" + usage_date.getYear(),"dd-MM-yyyy");
                 		}
                 		else if(bill_every == "Last Day Of Month")
                 		{
                 			usage_date = toDate("01-" + usage_date.getMonth() + "-" + usage_date.getYear(),"dd-MM-yyyy").eomonth(0);
                 		}
                 		invoice_usage = thisapp.get_invoice_usage(usage_date);
                 		/* Select line-item calculation strategy based on where in the contract lifecycle this invoice falls */
                 		if(last_billing_date == null)
                 		{
                 			/* First invoice ever for this subscription */
                 			if(subscription_prorate)
                 			{
                 				/* Prorate from contract start date for the first partial month */
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"prorate_first_month",subscription_exchange_rate,contract_start_date,null,false);
                 			}
                 			else
                 			{
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"single_period",subscription_exchange_rate,null,null,false);
                 			}
                 		}
                 		else if(actual_billing_date == final_billing_date)
                 		{
                 			/* Final invoice: use full period if contract end aligns to month-end, otherwise prorate the final partial month */
                 			if((contract_end_date.getDay() == contract_end_date.eomonth(0).getDay() && next_billing_date != null) || (next_billing_date == null && !subscription_prorate))
                 			{
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"single_period",subscription_exchange_rate,null,null,true);
                 			}
                 			else
                 			{
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"prorate_final_month",subscription_exchange_rate,null,contract_end_date,false);
                 			}
                 		}
                 		else if(actual_billing_date == monthly_billing_date && actual_billing_date != final_billing_date)
                 		{
                 			/* Standard mid-contract monthly billing — charge a full period */
                 			totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"single_period",subscription_exchange_rate,null,null,false);
                 		}
                 		else
                 		{
                 			/* No billing condition matched — skip invoice creation */
                 			return;
                 		}
                 		/* Unpack the totals map returned by the helper into local variables */
                 		grand_total = totals.get("grand_total");
                 		sub_total_monthly_rental = totals.get("sub_total_monthly_rental");
                 		total_tax_monthly_rental = totals.get("total_tax_monthly_rental");
                 		grand_total_monthly_rental = totals.get("grand_total_monthly_rental");
                 		sub_total_internet_charges = totals.get("sub_total_internet_charges");
                 		total_tax_internet_charges = totals.get("total_tax_internet_charges");
                 		grand_total_internet_charges = totals.get("grand_total_internet_charges");
                 		sub_total_call_charges = totals.get("sub_total_call_charges");
                 		total_tax_call_charges = totals.get("total_tax_call_charges");
                 		grand_total_call_charges = totals.get("grand_total_call_charges");
                 		/* Generate a unique invoice number and load supplier/customer details */
                 		inv_no = thisapp.invoice.generate_invoice_number();
                 		organization_info = Organization_Settings[ID != null];
                 		customer_profile_info = Customer_Profile[ID == customer];
                 		/* Insert the invoice record; monthly rental and internet sub-totals are corrected after insert */
                 		error_msg = "";
                 		try 
                 		{
                 			create_invoice = insert into Invoice
                 			[
                 				Invoice_No=inv_no
                 				Payment_Term=tenancy_info.Payment_Term
                 				Customer_Code=subscription_info.Customer_Code
                 				Customer=customer
                 				Customer_TIN=customer_profile_info.Customer_TIN
                 				Customer_SST_Registration_Number=ifnull(customer_profile_info.Customer_SST,"")
                 				Customer_E_mail=customer_email_address
                 				Customer_Registration_Identification_Passport_Number=ifnull(customer_profile_info.Customer_Registration_Number,"")
                 				Customer_Street=ifnull(customer_profile_info.Business_Street,"")
                 				Customer_Postcode=ifnull(customer_profile_info.Postcode,"")
                 				Customer_City=ifnull(customer_profile_info.City,"")
                 				Customer_State=ifnull(customer_profile_info.State,null)
                 				Customer_Country=ifnull(customer_profile_info.Country,null)
                 				Supplier_TIN=organization_info.Supplier_TIN
                 				Supplier_SST_Registration_Number=organization_info.SST_ID
                 				Subscriptions=subscription_id
                 				Invoice_Date=actual_billing_date
                 				Due_Date=due_date
                 				Sub_Total_Call_Charges=sub_total_call_charges
                 				Total_Tax_Call_Charges=total_tax_call_charges
                 				Grand_Total_Call_Charges=grand_total_call_charges
                 				Sub_Total_Monthly_Rental=0
                 				Total_Tax_Monthly_Rental=0
                 				Grand_Total_Monthly_Rental=0
                 				Amount_Due=grand_total
                 				Amount_Paid=0
                 				Deposit_Amount=total_deposit_amount
                 				Base_Currency=currency
                 				Exchange_Rate=subscription_exchange_rate
                 				Payable_To=subscription_payable_to
                 				Invoice_For_Usage=invoice_usage
                 				Enable_Reminder=enable_reminder
                 				Added_User=zoho.loginuser
                 				Supplier=Organization_Settings[ID != null].ID
                 			];
                 		}		catch (error)
                 		{
                 			error_msg = error;
                 		}
                 		if(error_msg == "")
                 		{
                 			/* Advance the subscription's own next and last billing dates */
                 			thisapp.subscription.update_subscription_next_and_last_billing_date(subscription_id,bill_for,subscription_billing_cycle_int,actual_billing_date,monthly_billing_date,bill_every);
                 			/* Post-insert correction: write breakdown sub-totals that could not be set atomically */
                 			get_invoice = Invoice[ID == create_invoice];
                 			get_invoice.Sub_Total_Monthly_Rental=sub_total_monthly_rental;
                 			get_invoice.Total_Tax_Monthly_Rental=total_tax_monthly_rental;
                 			get_invoice.Grand_Total_Monthly_Rental=grand_total_monthly_rental;
                 			get_invoice.Sub_Total_Internet_Charges=sub_total_internet_charges;
                 			get_invoice.Total_Tax_Internet_Charges=total_tax_internet_charges;
                 			get_invoice.Grand_Total_Internet_Charges=grand_total_internet_charges;
                 			get_invoice.Sub_Total_Call_Charges=sub_total_call_charges;
                 			get_invoice.Total_Tax_Call_Charges=total_tax_call_charges;
                 			get_invoice.Grand_Total_Call_Charges=grand_total_call_charges;
                 			/* Recurse for a second invoice if needed; sub_submission=true prevents duplicate tenant date updates */
                 			if(create_second_invoice)
                 			{
                 				thisapp.invoice.create_invoice_previous_duration(true,subscription_id,second_monthly_billing_date,second_actual_billing_date,false,null,null,true);
                 			}
                 		}
                 	}
                 	/* BRANCH B: Non-monthly (custom period) billing logic */
                 	else
                 	{
                 		/* Currency comes from the subscription itself rather than the customer profile */
                 		currency = subscription_info.Subscription_Currency;
                 		invoice_usage = thisapp.get_invoice_usage(actual_billing_date.subMonth(subscription_billing_cycle_int));
                 		/* Select calculation strategy for non-monthly billing based on contract state */
                 		if(last_billing_date == null && final_billing_date != actual_billing_date && contract_start_date != actual_billing_date)
                 		{
                 			/* First invoice — prorate from contract start if enabled, otherwise full catch-up period */
                 			if(subscription_prorate)
                 			{
                 				invoice_usage = thisapp.get_invoice_usage(contract_start_date);
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"days30",subscription_exchange_rate,contract_start_date,monthly_billing_date,false);
                 			}
                 			else
                 			{
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"single_period",subscription_exchange_rate,null,null,false);
                 			}
                 		}
                 		else if(actual_billing_date == final_billing_date)
                 		{
                 			if(final_billing_date == contract_end_date && next_billing_date != null)
                 			{
                 				/* Contract end coincides with a scheduled billing date — charge a full period */
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"single_period",subscription_exchange_rate,null,null,false);
                 			}
                 			else if(next_billing_date == null)
                 			{
                 				/* No future billing dates — prorate from contract start to end using days30 */
                 				invoice_usage = thisapp.get_invoice_usage(contract_start_date);
                 				totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"days30",subscription_exchange_rate,contract_start_date,contract_end_date,false);
                 			}
                 			else
                 			{
                 				/* Partial final period — prorate from previous cycle start or contract start depending on history */
                 				if(last_billing_date == null && contract_start_date < monthly_billing_date.subMonth(subscription_billing_cycle_int).toStartOfMonth())
                 				{
                 					if(subscription_prorate)
                 					{
                 						/* Prorate from contract start date when subscription started before the previous cycle */
                 						invoice_usage = thisapp.get_invoice_usage(contract_start_date);
                 						totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"days30",subscription_exchange_rate,contract_start_date,contract_end_date,false);
                 					}
                 					else
                 					{
                 						totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"single_period",subscription_exchange_rate,null,null,false);
                 					}
                 				}
                 				else
                 				{
                 					/* Prorate from the start of the previous billing cycle to the contract end date */
                 					totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"days30",subscription_exchange_rate,monthly_billing_date.subMonth(subscription_billing_cycle_int),contract_end_date,false);
                 				}
                 			}
                 		}
                 		else if(actual_billing_date == monthly_billing_date && actual_billing_date != final_billing_date)
                 		{
                 			/* Standard non-monthly period billing — charge a full period */
                 			totals = thisapp.invoice.create_invoice_previous_duration_helper(subscription_id,"single_period",subscription_exchange_rate,null,null,false);
                 		}
                 		else
                 		{
                 			/* No billing condition matched — skip invoice creation */
                 			return;
                 		}
                 		/* Unpack totals map into local variables */
                 		grand_total = totals.get("grand_total");
                 		sub_total_monthly_rental = totals.get("sub_total_monthly_rental");
                 		total_tax_monthly_rental = totals.get("total_tax_monthly_rental");
                 		grand_total_monthly_rental = totals.get("grand_total_monthly_rental");
                 		sub_total_internet_charges = totals.get("sub_total_internet_charges");
                 		total_tax_internet_charges = totals.get("total_tax_internet_charges");
                 		grand_total_internet_charges = totals.get("grand_total_internet_charges");
                 		sub_total_call_charges = totals.get("sub_total_call_charges");
                 		total_tax_call_charges = totals.get("total_tax_call_charges");
                 		grand_total_call_charges = totals.get("grand_total_call_charges");
                 		inv_no = thisapp.invoice.generate_invoice_number();
                 		organization_info = Organization_Settings[ID != null];
                 		customer_profile_info = Customer_Profile[ID == customer];
                 		/* Insert the invoice record */
                 		error_msg = "";
                 		try 
                 		{
                 			create_invoice = insert into Invoice
                 			[
                 				Invoice_No=inv_no
                 				Payment_Term=tenancy_info.Payment_Term
                 				Customer_Code=subscription_info.Customer_Code
                 				Customer=customer
                 				Customer_TIN=customer_profile_info.Customer_TIN
                 				Customer_SST_Registration_Number=ifnull(customer_profile_info.Customer_SST,"")
                 				Customer_E_mail=customer_email_address
                 				Customer_Registration_Identification_Passport_Number=ifnull(customer_profile_info.Customer_Registration_Number,"")
                 				Customer_Street=ifnull(customer_profile_info.Business_Street,"")
                 				Customer_Postcode=ifnull(customer_profile_info.Postcode,"")
                 				Customer_City=ifnull(customer_profile_info.City,"")
                 				Customer_State=ifnull(customer_profile_info.State,null)
                 				Customer_Country=ifnull(customer_profile_info.Country,null)
                 				Supplier_TIN=organization_info.Supplier_TIN
                 				Supplier_SST_Registration_Number=organization_info.SST_ID
                 				Subscriptions=subscription_id
                 				Invoice_Date=actual_billing_date
                 				Due_Date=due_date
                 				Sub_Total_Call_Charges=sub_total_call_charges
                 				Total_Tax_Call_Charges=total_tax_call_charges
                 				Grand_Total_Call_Charges=grand_total_call_charges
                 				Sub_Total_Monthly_Rental=0
                 				Total_Tax_Monthly_Rental=0
                 				Grand_Total_Monthly_Rental=0
                 				Amount_Due=grand_total
                 				Amount_Paid=0
                 				Deposit_Amount=total_deposit_amount
                 				Base_Currency=currency
                 				Exchange_Rate=subscription_exchange_rate
                 				Payable_To=subscription_payable_to
                 				Invoice_For_Usage=invoice_usage
                 				Enable_Reminder=enable_reminder
                 				Added_User=zoho.loginuser
                 				Supplier=Organization_Settings[ID != null].ID
                 			];
                 		}		catch (error)
                 		{
                 			error_msg = error;
                 		}
                 		if(error_msg == "")
                 		{
                 			/* Advance the subscription's billing dates for the non-monthly cycle */
                 			thisapp.subscription.update_subscription_next_and_last_billing_date(subscription_id,bill_for,subscription_billing_cycle_int,actual_billing_date,monthly_billing_date,bill_every);
                 			/* Post-insert correction of breakdown sub-totals */
                 			get_invoice = Invoice[ID == create_invoice];
                 			get_invoice.Sub_Total_Monthly_Rental=sub_total_monthly_rental;
                 			get_invoice.Total_Tax_Monthly_Rental=total_tax_monthly_rental;
                 			get_invoice.Grand_Total_Monthly_Rental=grand_total_monthly_rental;
                 			get_invoice.Sub_Total_Internet_Charges=sub_total_internet_charges;
                 			get_invoice.Total_Tax_Internet_Charges=total_tax_internet_charges;
                 			get_invoice.Grand_Total_Internet_Charges=grand_total_internet_charges;
                 			get_invoice.Sub_Total_Call_Charges=sub_total_call_charges;
                 			get_invoice.Total_Tax_Call_Charges=total_tax_call_charges;
                 			get_invoice.Grand_Total_Call_Charges=grand_total_call_charges;
                 			/* Recurse for a second invoice if requested; sub_submission=true prevents duplicate tenancy date updates */
                 			if(create_second_invoice)
                 			{
                 				thisapp.invoice.create_invoice_previous_duration(false,subscription_id,second_monthly_billing_date,second_actual_billing_date,false,null,null,true);
                 			}
                 		}
                 	}
                 }
				 map invoice.create_invoice_previous_duration_helper(int subscription_id, string calc_mode, decimal exchange_rate, date start_date, date end_date, bool is_final_tax)
                 {
                 	sub_info = Subscription[ID == subscription_id];
                 	sum_sub_total = 0;
                 	total_tax = 0;
                 	grand_total = 0;
                 	grand_total_myr = 0;
                 	sub_total_monthly_rental = 0;
                 	total_tax_monthly_rental = 0;
                 	grand_total_monthly_rental = 0;
                 	sub_total_internet_charges = 0;
                 	total_tax_internet_charges = 0;
                 	grand_total_internet_charges = 0;
                 	sub_total_call_charges = 0;
                 	total_tax_call_charges = 0;
                 	grand_total_call_charges = 0;
                 	for each  monthly_rental_line_item in sub_info.Monthly_Rental
                 	{
                 		unit_price = monthly_rental_line_item.Unit_Price_Monthly_Rental;
                 		quantity = monthly_rental_line_item.Quantity_Monthly_Rental;
                 		tax_pct = monthly_rental_line_item.Tax_Pct_Monthly_Rental;
                 		if(calc_mode == "prorate_first_month")
                 		{
                 			prorate_unit_price = unit_price / start_date.eomonth(0).getDay();
                 			days_used = start_date.eomonth(0).getDay() - start_date.getDay() + 1;
                 			sub_total = (prorate_unit_price * days_used * quantity).round(2);
                 		}
                 		else if(calc_mode == "prorate_final_month")
                 		{
                 			line_amounts = thisapp.invoice.calculate_subtotal_item_line("prorate_final_month",unit_price,quantity,null,end_date);
                 			sub_total = line_amounts.get("subTotal");
                 		}
                 		else if(calc_mode == "days30")
                 		{
                 			sub_total = thisapp.invoice.calculate_subtotal_item_line("days30",unit_price,quantity,start_date,end_date).get("subTotal");
                 		}
                 		else
                 		{
                 			sub_total = thisapp.invoice.calculate_subtotal_item_line("single_period",unit_price,quantity,null,null).get("subTotal");
                 		}
                 		line_tax = thisapp.invoice.calculate_tax_item_line(sub_total,tax_pct);
                 		tax_amount = line_tax.get("taxAmount");
                 		total = line_tax.get("total");
                 		total_myr = total * exchange_rate;
                 		sum_sub_total = sum_sub_total + sub_total;
                 		total_tax = total_tax + tax_amount;
                 		grand_total = grand_total + total;
                 		grand_total_myr = grand_total_myr + total_myr;
                 		sub_total_monthly_rental = sub_total_monthly_rental + sub_total;
                 		total_tax_monthly_rental = total_tax_monthly_rental + tax_amount;
                 		grand_total_monthly_rental = grand_total_monthly_rental + total;
                 	}
                 	for each  internet_charges_line_item in sub_info.Internet_Charges
                 	{
                 		unit_price = internet_charges_line_item.Unit_Price_Internet_Charges;
                 		quantity = internet_charges_line_item.Quantity_Internet_Charges;
                 		tax_pct = internet_charges_line_item.Tax_Pct_Internet_Charges;
                 		if(calc_mode == "prorate_first_month")
                 		{
                 			prorate_unit_price = unit_price / start_date.eomonth(0).getDay();
                 			days_used = start_date.eomonth(0).getDay() - start_date.getDay() + 1;
                 			sub_total = (prorate_unit_price * days_used * quantity).round(2);
                 		}
                 		else if(calc_mode == "prorate_final_month")
                 		{
                 			line_amounts = thisapp.invoice.calculate_subtotal_item_line("prorate_final_month",unit_price,quantity,null,end_date);
                 			sub_total = line_amounts.get("subTotal");
                 		}
                 		else if(calc_mode == "days30")
                 		{
                 			sub_total = thisapp.invoice.calculate_subtotal_item_line("days30",unit_price,quantity,start_date,end_date).get("subTotal");
                 		}
                 		else
                 		{
                 			sub_total = thisapp.invoice.calculate_subtotal_item_line("single_period",unit_price,quantity,null,null).get("subTotal");
                 		}
                 		line_tax = thisapp.invoice.calculate_tax_item_line(sub_total,tax_pct);
                 		tax_amount = line_tax.get("taxAmount");
                 		total = line_tax.get("total");
                 		total_myr = total * exchange_rate;
                 		sum_sub_total = sum_sub_total + sub_total;
                 		total_tax = total_tax + tax_amount;
                 		grand_total = grand_total + total;
                 		grand_total_myr = grand_total_myr + total_myr;
                 		sub_total_internet_charges = sub_total_internet_charges + sub_total;
                 		total_tax_internet_charges = total_tax_internet_charges + tax_amount;
                 		grand_total_internet_charges = grand_total_internet_charges + total;
                 	}
                 	for each  call_charges_line_item in sub_info.Call_Charges
                 	{
                 		unit_price = call_charges_line_item.Unit_Price_Call_Charges;
                 		quantity = call_charges_line_item.Quantity_Call_Charges;
                 		tax_pct = call_charges_line_item.Tax_Pct_Call_Charges;
                 		if(calc_mode == "prorate_first_month")
                 		{
                 			prorate_unit_price = unit_price / start_date.eomonth(0).getDay();
                 			days_used = start_date.eomonth(0).getDay() - start_date.getDay() + 1;
                 			sub_total = (prorate_unit_price * days_used * quantity).round(2);
                 		}
                 		else if(calc_mode == "prorate_final_month")
                 		{
                 			line_amounts = thisapp.invoice.calculate_subtotal_item_line("prorate_final_month",unit_price,quantity,null,end_date);
                 			sub_total = line_amounts.get("subTotal");
                 		}
                 		else if(calc_mode == "days30")
                 		{
                 			sub_total = thisapp.invoice.calculate_subtotal_item_line("days30",unit_price,quantity,start_date,end_date).get("subTotal");
                 		}
                 		else
                 		{
                 			sub_total = thisapp.invoice.calculate_subtotal_item_line("single_period",unit_price,quantity,null,null).get("subTotal");
                 		}
                 		line_tax = thisapp.invoice.calculate_tax_item_line(sub_total,tax_pct);
                 		tax_amount = line_tax.get("taxAmount");
                 		total = line_tax.get("total");
                 		total_myr = total * exchange_rate;
                 		sum_sub_total = sum_sub_total + sub_total;
                 		total_tax = total_tax + tax_amount;
                 		grand_total = grand_total + total;
                 		grand_total_myr = grand_total_myr + total_myr;
                 		sub_total_call_charges = sub_total_call_charges + sub_total;
                 		total_tax_call_charges = total_tax_call_charges + tax_amount;
                 		grand_total_call_charges = grand_total_call_charges + total;
                 	}
                 	return {"sum_sub_total":sum_sub_total,"total_tax":total_tax,"grand_total":grand_total,"grand_total_myr":grand_total_myr,"sub_total_monthly_rental":sub_total_monthly_rental,"total_tax_monthly_rental":total_tax_monthly_rental,"grand_total_monthly_rental":grand_total_monthly_rental,"sub_total_internet_charges":sub_total_internet_charges,"total_tax_internet_charges":total_tax_internet_charges,"grand_total_internet_charges":grand_total_internet_charges,"sub_total_call_charges":sub_total_call_charges,"total_tax_call_charges":total_tax_call_charges,"grand_total_call_charges":grand_total_call_charges};
                 }
				 string invoice.generate_invoice_number()
                 {
                 	prefix = "XK" + zoho.currentdate.getYear().toString().subText(2,4);
                 	invoiceInfo = Invoice[Invoice_No.containsIgnoreCase(prefix) && Invoice_No != ""] sort by Invoice_No desc;
                 	if(invoiceInfo.ID == null)
                 	{
                 		count = 0;
                 	}
                 	else
                 	{
                 		count = invoiceInfo.Invoice_No.getsuffix(prefix).toLong();
                 	}
                 	count = count + 1;
                 	if(count < 10)
                 	{
                 		pad = "00000";
                 	}
                 	else if(count < 100)
                 	{
                 		pad = "0000";
                 	}
                 	else if(count < 1000)
                 	{
                 		pad = "000";
                 	}
                 	else if(count < 10000)
                 	{
                 		pad = "00";
                 	}
                 	else if(count < 100000)
                 	{
                 		pad = "0";
                 	}
                 	else
                 	{
                 		pad = "";
                 	}
                 	invNumber = prefix + pad + count;
                 	return invNumber;
                 }
				 float invoice.get_previous_balance_for_customer(int customer_id, int exclude_invoice_id)
                 {
                 	previous_balance = 0;
                 	for each  curr_invoice in Invoice[Amount_Due > 0 && Blueprint.Current_Stage in {"Sent","Overdue","Partially Paid"} && Customer == customer_id && ID != exclude_invoice_id]
                 	{
                 		previous_balance = previous_balance + curr_invoice.Amount_Due;
                 	}
                 	return previous_balance;
                 }
