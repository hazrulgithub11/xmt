			User_Input_Trigger_Workfl5 as "User_Input_Trigger_Workflow"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of User_Input_Trigger
				{
					actions 
					{
						custom deluge script
						(
											////////////////////////////////////////////////////////////////////////////////////////////
										// Line Items Calculation
										calculated_grand_total = 0;
										calculated_grand_total_myr = 0;
										calculated_total_tax = 0;
										exchange_rate = input.Exchange_Rate;
										// Monthly Rental Calculation
										for each  curr_monthly_rental_line_item in input.Monthly_Rental
										{
											curr_sub_total = curr_monthly_rental_line_item.Quantity_Monthly_Rental * curr_monthly_rental_line_item.Unit_Price_Monthly_Rental;
											curr_tax_amount = curr_sub_total * curr_monthly_rental_line_item.Tax_Pct_Monthly_Rental / 100;
											curr_total = curr_sub_total + curr_tax_amount;
											curr_monthly_rental_line_item.Sub_Total_Monthly_Rental=curr_sub_total;
											curr_monthly_rental_line_item.Tax_Amount_Monthly_Rental=curr_tax_amount;
											curr_monthly_rental_line_item.Total_Monthly_Rental=curr_total;
											// Accumulate form-level totals
											calculated_grand_total = calculated_grand_total + curr_total;
											calculated_grand_total_myr = calculated_grand_total_myr + curr_total * exchange_rate;
											calculated_total_tax = calculated_total_tax + curr_tax_amount;
										}
										// Internet Charges Calculation
										for each  curr_internet_charges_line_item in input.Internet_Charges
										{
											curr_sub_total = curr_internet_charges_line_item.Quantity_Internet_Charges * curr_internet_charges_line_item.Unit_Price_Internet_Charges;
											curr_tax_amount = curr_sub_total * curr_internet_charges_line_item.Tax_Pct_Internet_Charges / 100;
											curr_total = curr_sub_total + curr_tax_amount;
											curr_internet_charges_line_item.Sub_Total_Internet_Charges=curr_sub_total;
											curr_internet_charges_line_item.Tax_Amount_Internet_Charges=curr_tax_amount;
											curr_internet_charges_line_item.Total_Internet_Charges=curr_total;
											// Accumulate form-level totals
											calculated_grand_total = calculated_grand_total + curr_total;
											calculated_grand_total_myr = calculated_grand_total_myr + curr_total * exchange_rate;
											calculated_total_tax = calculated_total_tax + curr_tax_amount;
										}
										// Call Charges Calculation
										for each  curr_call_charges_line_item in input.Call_Charges
										{
											curr_sub_total = curr_call_charges_line_item.Quantity_Call_Charges * curr_call_charges_line_item.Unit_Price_Call_Charges;
											curr_tax_amount = curr_sub_total * curr_call_charges_line_item.Tax_Pct_Call_Charges / 100;
											curr_total = curr_sub_total + curr_tax_amount;
											curr_call_charges_line_item.Sub_Total_Call_Charges=curr_sub_total;
											curr_call_charges_line_item.Tax_Amount_Call_Charges=curr_tax_amount;
											curr_call_charges_line_item.Total_Call_Charges=curr_total;
											// Accumulate form-level totals
											calculated_grand_total = calculated_grand_total + curr_total;
											calculated_grand_total_myr = calculated_grand_total_myr + curr_total * exchange_rate;
											calculated_total_tax = calculated_total_tax + curr_tax_amount;
										}
										////////////////////////////////////////////////////////////////////////////////////////////
										// Form-level totals
										input.Grand_Total = calculated_grand_total;
										input.Total_Tax = calculated_total_tax;
										input.Grand_Total_Base_Currency = calculated_grand_total_myr;
						)
					}
				}

			}
			Handle_Charge_Category1 as "Handle_Charge_Category"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Charge_Category
				{
					actions 
					{
						custom deluge script
						(
											if(input.Charge_Category == "Miscellaneous Charges")
										{
											hide Call_Charges;
											clear Call_Charges;
										}
										else if(input.Charge_Category == "Fixed Charges")
										{
											hide Call_Charges;
											clear Call_Charges;
										}
										else
										{
											show Call_Charges;
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											input.User_Input_Trigger = !input.User_Input_Trigger;
						)
					}
				}

			}
			Handle_Monthly_Rental_Ite5 as "Handle_Monthly_Rental_Item"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Monthly_Rental.Item_Monthly_Rental
				{
					actions 
					{
						custom deluge script
						(
											if(input.Exchange_Rate == null || input.Exchange_Rate == 0)
										{
											alert "Ensure Exchange Rate is not empty before selecting an item.";
											row.Item_Monthly_Rental=null;
											return;
										}
										if(row.Item_Monthly_Rental == null)
										{
											row.Item_Code_Monthly_Rental=null;
											row.Classification_Codes_Monthly_Rental=null;
											row.Description_Monthly_Rental=null;
											row.Quantity_Monthly_Rental=null;
											row.Unit_Price_Monthly_Rental=null;
											row.Sub_Total_Monthly_Rental=null;
											row.Tax_Monthly_Rental=null;
											row.Tax_Type_Monthly_Rental=null;
											row.Tax_Pct_Monthly_Rental=null;
											row.Tax_Amount_Monthly_Rental=null;
											row.Total_Monthly_Rental=null;
											row.Circuit_ID_Monthly_Rental=null;
											row.Circuit_ID_Type_Monthly_Rental=null;
										}
										else
										{
											itemRecord = Transaction_Type[ID == row.Item_Monthly_Rental];
											row.Item_Code_Monthly_Rental=itemRecord.Item_Code;
											row.Classification_Codes_Monthly_Rental=itemRecord.Classification_Codes;
											row.Description_Monthly_Rental=itemRecord.Description;
											row.Quantity_Monthly_Rental=thisapp.tenancy.convert_bill_cycle_to_int(input.Billing_Cycle);
											unitPriceMYR = ifnull(itemRecord.Unit_Price,0);
											row.Unit_Price_Monthly_Rental=unitPriceMYR / ifnull(input.Exchange_Rate,1);
											row.Tax_Monthly_Rental=itemRecord.Tax;
											row.Tax_Type_Monthly_Rental=itemRecord.Tax.Tax_Type;
											row.Tax_Pct_Monthly_Rental=itemRecord.Tax.Tax_Percentage;
											row.Circuit_ID_Monthly_Rental=itemRecord.Circuit_ID;
											row.Circuit_ID_Type_Monthly_Rental=itemRecord.Circuit_ID_Type;
										}
										input.User_Input_Trigger = !input.User_Input_Trigger;
						)
					}
				}

			}
			Handle_Monthly_Rental_Qua as "Handle_Monthly_Rental_Quantity"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Monthly_Rental.Quantity_Monthly_Rental
				{
					actions 
					{
						custom deluge script
						(
											if(ifnull(row.Quantity_Monthly_Rental,0) <= 0)
										{
											alert "Please enter a quantity more than 0";
											row.Quantity_Monthly_Rental=1;
											return;
										}
										input.User_Input_Trigger = !input.User_Input_Trigger;
						)
