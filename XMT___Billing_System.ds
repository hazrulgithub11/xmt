                 			for each  inv in Invoice[Invoice_Date >= startDate && Invoice_Date <= endDate && Customer == customerProfile && Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Overdue" || Blueprint.Current_Stage == "Partially Paid"]
