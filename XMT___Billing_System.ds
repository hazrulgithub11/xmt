			Handle_Deletion_Row_Call_ as "Handle Deletion Row Call Charges"
			{
				type =  form
				form = Invoice

				record event = on add or edit

				on delete row of Call_Charges
				{
					actions 
					{
						custom deluge script
						(
											input.User_Input_Trigger = !input.User_Input_Trigger;
						)
					}
					actions 
					{
						custom deluge script
						(
											newAmountDue = ifnull(input.Amount_Due,0) - ifnull(row.Total_Call_Charges,0);
										if(newAmountDue > 0)
										{
											input.Amount_Due = newAmountDue;
										}
										else
										{
											input.Amount_Due = 0;
										}
						)
					}
				}

			}
			Validations_on_subscripti1 as "Validations on subscription deletion"
			{
				type =  form
				form = Subscription

				record event = on delete

				on validate
				{
					actions 
					{
						custom deluge script
						(
											subscriptionId = input.ID;
										get_invoice_list = Invoice[Subscriptions.contains(subscriptionId)].ID.getAll();
										get_credit_note_list = Credit_Note[Subscriptions.contains(subscriptionId)].ID.getAll();
										get_refund_note_list = Refund_Note[Subscriptions.contains(subscriptionId)].ID.getAll();
										get_work_order_list = Work_Order_Creation[Subscription == subscriptionId].ID.getAll();
										message = "This subscription can't be deleted because it is used in the following module(s):\n\n";
										hasDependency = false;
										if(get_invoice_list.size() > 0)
										{
											message = message + "- Invoices: " + get_invoice_list.size() + "\n";
											hasDependency = true;
										}
										if(get_credit_note_list.size() > 0)
										{
											message = message + "- Credit Notes: " + get_credit_note_list.size() + "\n";
											hasDependency = true;
										}
										if(get_refund_note_list.size() > 0)
										{
											message = message + "- Refund Notes: " + get_refund_note_list.size() + "\n";
											hasDependency = true;
										}
										if(get_work_order_list.size() > 0)
										{
											message = message + "- Work Order Creations: " + get_work_order_list.size() + "\n";
											hasDependency = true;
										}
										if(input.Pro_Forma_Invoices != null)
										{
											message = message + "- Pro Forma Invoice linked on this subscription\n";
											hasDependency = true;
										}
										if(hasDependency)
										{
											message = message + "\nPlease remove or reassign these records before deleting the subscription.";
											alert message;
											cancel delete;
										}
						)
					}
				}

			}
