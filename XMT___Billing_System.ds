		form Tax
		{
			success message = "Tax Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Tax_Name
			(
    			type = text
				displayname = "Tax Name"
	 			row = 1
	 			column = 1   
				width = medium
