			Validations_on_form_submi as "Validations on form submission"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// Bill Every is required for Monthly billing cycle
										if(input.Billing_Cycle == "Monthly" && input.Bill_Every == null || input.Bill_Every == "")
										{
											alert(Bill_Every,"Bill Every is required when Billing Cycle is Monthly.");
											cancel submit;
										}
										// Toggle User Input Trigger
										input.User_Input_Trigger = !input.User_Input_Trigger;
										// Count Total Line Items across all grids
										count_item = 0;
										for each  curr_monthly_rental_line_item in input.Monthly_Rental
										{
											count_item = count_item + 1;
										}
										for each  curr_internet_charges_line_item in input.Internet_Charges
										{
											count_item = count_item + 1;
										}
										for each  curr_call_charges_line_item in input.Call_Charges
										{
											count_item = count_item + 1;
										}
										if(count_item == 0)
										{
											alert "Add at least one item need to be added.";
											cancel submit;
										}
										// Validate Monthly Rental Quantity & Unit Price
										for each  curr_monthly_rental_line_item in input.Monthly_Rental
										{
											if(ifnull(curr_monthly_rental_line_item.Quantity_Monthly_Rental,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_monthly_rental_line_item.Unit_Price_Monthly_Rental,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Internet Charges Quantity & Unit Price
										for each  curr_internet_charges_line_item in input.Internet_Charges
										{
											if(ifnull(curr_internet_charges_line_item.Quantity_Internet_Charges,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_internet_charges_line_item.Unit_Price_Internet_Charges,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Call Charges Quantity & Unit Price
										for each  curr_call_charges_line_item in input.Call_Charges
										{
											if(ifnull(curr_call_charges_line_item.Quantity_Call_Charges,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_call_charges_line_item.Unit_Price_Call_Charges,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Work Order Type
										if(input.Create_Work_Order == true)
										{
											if(input.Work_Order_Type == null || input.Work_Order_Type.isEmpty())
											{
												alert "Please select a Work Order Type before submitting";
												cancel submit;
											}
										}
						)
					}
				}

			}
