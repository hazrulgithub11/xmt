					actions 
					{
						custom deluge script
						(
											input.Subscription_No = thisapp.subscription.generate_subscription_no();
						)
					}
					actions 
					{
						custom deluge script
						(
											// Subscription info
										subscription_contract_start_date = input.Contract_Start_Date;
										subscription_contract_end_date = input.Contract_End_Date;
										subscription_contract_period = input.Contract_Period;
										subscription_bill_for = input.Bill_For;
										subscription_bill_every = input.Bill_Every;
										subscription_billing_cycle = input.Billing_Cycle;
										subscription_billing_cycle_int = thisapp.tenancy.convert_bill_cycle_to_int(subscription_billing_cycle);
										subscription_id = input.ID;
										if(subscription_billing_cycle == "Monthly")
										{
											current_billing_every_date = thisapp.subscription.resolve_billing_day_for_month(subscription_bill_every,today);
											start_billing_every_date = thisapp.subscription.resolve_billing_day_for_month(subscription_bill_every,subscription_contract_start_date);
										}
										else
										{
											current_billing_every_date = thisapp.subscription.resolve_billing_date_for_contract_day(subscription_contract_start_date,today);
											start_billing_every_date = thisapp.subscription.resolve_billing_date_for_contract_day(subscription_contract_start_date,subscription_contract_start_date);
										}
						)
					}
				}

			}
