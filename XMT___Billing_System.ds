				type = list	
				displayname = "Business Segment"
				values  = Business_Segment.ID
    			displayformat = [Business]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Active","Inactive","Terminated"}
