				 string subscription.build_work_order_perma_url(int woId)
                 {
                 	return "https://creatorapp.zohopublic.com/" + zoho.adminuser + "/" + zoho.appname + "/report-perma/All_Work_Order_Creations/VdbndsS1m3EHhRMdrSZhfhqgf48gsSOVkQ5v1pbMZVR2H6XfrXATWSwUP7B2xVaCBmtWaKXBYeKj8k5B79afguswAdx7HB4ezBvp?ID=" + woId.toString();
                 }
				 map subscription.createTicketUpdateWo(int subsId, int woId, string ticketType, string url)
                 {
                 	department_id = "1027140000000006907";
                 	mess = Map();
                 	mess.put("code",403);
                 	if(ticketType == null || ticketType == "")
                 	{
                 		mess.put("message","No ticket created. Must choose a Ticket Type.");
                 		return mess;
                 	}
                 	subRec = Subscription[ID == subsId];
                 	woRec = Work_Order_Creation[ID == woId];
                 	if(subRec == null)
                 	{
                 		mess.put("message","Subscription record not found.");
                 		return mess;
                 	}
                 	if(woRec == null)
                 	{
                 		mess.put("message","Work order record not found.");
                 		return mess;
                 	}
                 	deskContext = thisapp.subscription.resolve_desk_account_and_contact(subsId);
                 	contact_id = deskContext.get("contact_id");
                 	account_id = deskContext.get("account_id");
                 	customer_code_display_value = deskContext.get("customer_code_display_value");
                 	contact_name = deskContext.get("contact_name");
                 	contact_email = deskContext.get("contact_email");
                 	contact_phone = deskContext.get("contact_phone");
                 	if(ifnull(contact_id,"") == "")
                 	{
                 		mess.put("message","Desk contact could not be resolved or created.");
                 		return mess;
                 	}
                 	cf = Map();
                 	cf.put("cf_customer_code",customer_code_display_value);
                 	cf.put("cf_contact",contact_name);
                 	cf.put("cf_technical_email",contact_email);
                 	cf.put("cf_technical_phone_number",contact_phone);
                 	cf.put("cf_ticket_type",ticketType);
                 	cf.put("cf_url_to_subscription_record_in_billing_system",url);
                 	cf.put("cf_problem_category","Not Applicable");
                 	cf.put("cf_subcategory","Not Applicable");
                 	cf.put("cf_maintenance_type","Not Applicable");
                 	cf.put("cf_service_type","Please Select Service Type");
                 	cf.put("cf_business_unit","Please Select Business Unit");
                 	ticket_data = Map();
                 	ticket_data.put("subject","Work Order - " + ticketType);
                 	ticket_data.put("description","This ticket is created for " + ticketType);
                 	ticket_data.put("departmentId",department_id);
                 	ticket_data.put("contactId",contact_id);
                 	ticket_data.put("accountId",account_id);
                 	ticket_data.put("status","Open");
                 	ticket_data.put("cf",cf);
                 	create_ticket_response = invokeurl
                 	[
                 		url :"https://desk.zoho.com/api/v1/tickets"
                 		type :POST
                 		parameters:ticket_data.toString()
                 		connection:"zdesk"
                 	];
                 	if(ifnull(create_ticket_response.get("id"),"") != "")
                 	{
                 		woRec.Ticket_ID=create_ticket_response.get("id");
                 		woRec.Ticket_Number=create_ticket_response.get("ticketNumber");
                 		woRec.Customer_Name=subRec.Customer_Name;
                 		woRec.Customer_Code=subRec.Customer_Code;
                 		mess.put("code",200);
                 		mess.put("message","Ticket created successfully.");
                 		mess.put("ticketId",create_ticket_response.get("id"));
                 		mess.put("ticketNumber",create_ticket_response.get("ticketNumber"));
                 	}
                 	else
                 	{
                 		mess.put("message","Failed to create Desk ticket. Error: " + create_ticket_response.toString());
                 	}
                 	return mess;
                 }
				 map subscription.create_ticket_for_work_order(int subsId, int woId, string ticketType)
                 {
                 	woUrl = thisapp.subscription.build_work_order_perma_url(woId);
                 	return thisapp.subscription.createTicketUpdateWo(subsId,woId,ticketType,woUrl);
                 }
				 string subscription.generate_subscription_no()
                 {
                 	prefix = "SUB" + zoho.currentdate.getYear().toString().subText(2,4);
                 	subscription_info = Subscription[Subscription_No.containsIgnoreCase(prefix) && Subscription_No != ""] sort by Subscription_No desc;
                 	if(subscription_info.ID == null)
                 	{
                 		count = 0;
                 	}
                 	else
                 	{
                 		count = subscription_info.Subscription_No.getsuffix(prefix).toLong();
                 	}
                 	count = count + 1;
                 	if(count < 10)
                 	{
                 		pad = "00000";
                 	}
                 	else if(count < 100)
                 	{
                 		pad = "0000";
                 	}
                 	else if(count < 1000)
                 	{
                 		pad = "000";
                 	}
                 	else if(count < 10000)
                 	{
                 		pad = "00";
                 	}
                 	else if(count < 100000)
                 	{
                 		pad = "0";
                 	}
                 	else
                 	{
                 		pad = "";
                 	}
                 	invNumber = prefix + pad + count;
                 	return invNumber;
                 }
				 string subscription.get_prorate_note(date p_start, date p_end, string p_cycle, string p_for, string p_every, bool p_prorate)
                 {
                 	note = "";
                 	if(p_cycle == "Monthly")
                 	{
                 		if(p_for == "Current Duration" && p_start > today.toStartOfMonth() && p_start <= today.eomonth(0))
                 		{
                 			if(p_prorate)
                 			{
                 				note = "The first invoice will only cover the current billing period from " + p_start + " to " + p_start.eomonth(0) + ".";
                 			}
                 			else
                 			{
                 				note = "The first invoice will only cover the current billing period from " + p_start.toStartOfMonth() + " to " + p_start.eomonth(0) + ".";
                 			}
                 			return note;
                 		}
                 		else if(p_for == "Previous Duration" && p_start > today.subMonth(1).toStartOfMonth() && p_start <= today.eomonth(0) && p_start.getDay() != 1)
                 		{
                 			if(p_prorate)
                 			{
                 				note = "The first invoice will only cover the current billing period from " + p_start + " to " + p_start.eomonth(0) + ".";
                 			}
                 			else
                 			{
                 				note = "The first invoice will only cover the current billing period from " + p_start.toStartOfMonth() + " to " + p_start.eomonth(0) + ".";
                 			}
                 			return note;
                 		}
                 	}
                 	return note;
                 }
				 void subscription.get_subsId_tenatId_nextBillingDate(string customerPONo)
                 {
                 	getSubs = Subscription[Customer_PO_No == customerPONo];
                 	getTenant = Tenancy[ID = getSubs.Customer_Code];
                 	info "customerPoNo:" + getSubs.Customer_PO_No;
                 	info "subscriptionID:" + getSubs.ID;
                 	info "billCycle:" + thisapp.tenancy.convert_bill_cycle_to_int(getSubs.Billing_Cycle);
                 	info "tenantID:" + getSubs.Customer_Code;
                 	info "nextBillingDate:" + getSubs.Next_Billing_Date;
                 }
				 date subscription.resolve_billing_date_for_contract_day(date contract_start_date, date reference_date)
                 {
                 	last_day = toDate("01-" + reference_date.getMonth() + "-" + reference_date.getYear(),"dd-MM-yyyy").eomonth(0);
                 	if(contract_start_date.getDay() > last_day.getDay())
                 	{
                 		return last_day;
                 	}
                 	return toDate(contract_start_date.getDay() + "-" + reference_date.getMonth() + "-" + reference_date.getYear(),"dd-MM-yyyy");
                 }
				 date subscription.resolve_billing_day_for_month(string bill_every, date reference_date)
                 {
                 	last_day = toDate("01-" + reference_date.getMonth() + "-" + reference_date.getYear(),"dd-MM-yyyy").eomonth(0);
                 	if(bill_every == "Last Day Of Month" || bill_every.toNumber() > last_day.getDay())
                 	{
                 		return last_day;
                 	}
                 	return toDate(bill_every + "-" + reference_date.getMonth() + "-" + reference_date.getYear(),"dd-MM-yyyy");
                 }
				 map subscription.resolve_desk_account_and_contact(int subsId)
                 {
                 	result = Map();
                 	result.put("contact_id","");
                 	result.put("account_id","");
                 	result.put("customer_code_display_value","");
                 	result.put("contact_name","");
                 	result.put("contact_email","");
                 	result.put("contact_phone","");
                 	subRec = Subscription[ID == subsId];
                 	if(subRec == null)
                 	{
                 		return result;
                 	}
                 	contact_name = subRec.Contact;
                 	contact_email = subRec.Technical_Email;
                 	contact_phone = subRec.Phone_Number;
                 	customer_code_id = subRec.Customer_Code;
                 	result.put("contact_name",contact_name);
                 	result.put("contact_email",contact_email);
                 	result.put("contact_phone",contact_phone);
                 	account_id = "";
                 	customer_code_display_value = "";
                 	if(customer_code_id != null)
                 	{
                 		tenancy_record = Tenancy[ID == customer_code_id];
                 		if(tenancy_record != null)
                 		{
                 			customer_code_display_value = tenancy_record.Customer_Code;
                 			result.put("customer_code_display_value",customer_code_display_value);
                 			search_account_url = "https://desk.zoho.com/api/v1/accounts/search?customField1=cf_single_line_1:" + customer_code_display_value;
                 			search_account_response = invokeurl
                 			[
                 				url :search_account_url
                 				type :GET
                 				connection:"zdesk"
                 			];
                 			if(search_account_response.get("data") != null && search_account_response.get("data").size() > 0)
                 			{
                 				account_id = search_account_response.get("data").get(0).get("id");
                 				result.put("account_id",account_id);
                 			}
                 		}
                 	}
                 	contact_id = "";
                 	if(ifnull(contact_email,"") != "")
                 	{
                 		search_contact_url = "https://desk.zoho.com/api/v1/contacts/search?customField1=cf_technical_email:" + contact_email;
                 		search_contact_response = invokeurl
                 		[
                 			url :search_contact_url
                 			type :GET
                 			connection:"zdesk"
                 		];
                 		if(search_contact_response.get("data") != null && search_contact_response.get("data").size() > 0)
                 		{
                 			for each  contactRec in search_contact_response.get("data")
                 			{
                 				if(ifnull(account_id,"") == "" || contactRec.get("accountId") == account_id)
                 				{
                 					contact_id = contactRec.get("id");
                 					break;
                 				}
                 			}
                 		}
                 		if(contact_id == "")
                 		{
                 			cf = Map();
                 			if(ifnull(account_id,"") != "")
                 			{
                 				cf.put("accountId",account_id.toLong());
                 			}
                 			cf.put("cf_technical_contact_name",contact_name);
                 			cf.put("cf_technical_email",contact_email);
                 			cf.put("cf_technical_phone_number",contact_phone);
                 			contact_data = Map();
                 			contact_data.put("lastName",contact_name);
                 			contact_data.put("email",contact_email);
                 			contact_data.put("cf",cf);
                 			create_contact_response = invokeurl
                 			[
                 				url :"https://desk.zoho.com/api/v1/contacts"
                 				type :POST
                 				parameters:contact_data.toString()
                 				connection:"zdesk"
                 			];
                 			if(create_contact_response.get("id") != null)
                 			{
                 				contact_id = create_contact_response.get("id");
                 			}
                 		}
                 	}
                 	result.put("contact_id",contact_id);
                 	return result;
                 }
				 void subscription.update_subscription_next_and_last_billing_date(int subscription_id, string bill_for, int billing_cycle, date actual_billing_date, date monthly_billing_date, string bill_every)
                 {
                 	if(billing_cycle == 1)
                 	{
                 		if(bill_for.containsIgnoreCase("Current"))
                 		{
                 			sub_info = Subscription[ID == subscription_id];
                 			final_billing_date = sub_info.Final_Billing_Date;
                 			contract_start_date = sub_info.Contract_Start_Date;
                 			new_next_billing_date = thisapp.tenancy.compute_next_billing_date(billing_cycle,actual_billing_date,monthly_billing_date,bill_every,contract_start_date);
                 			if(actual_billing_date == monthly_billing_date && actual_billing_date != final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=new_next_billing_date;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 			else if(actual_billing_date == final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=null;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 				sub_info.Subscription_Status="Inactive";
                 			}
                 			else if(actual_billing_date != monthly_billing_date)
                 			{
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 		}
                 		else if(bill_for.containsIgnoreCase("Previous"))
                 		{
                 			sub_info = Subscription[ID == subscription_id];
                 			final_billing_date = sub_info.Final_Billing_Date;
                 			contract_start_date = sub_info.Contract_Start_Date;
                 			new_next_billing_date = thisapp.tenancy.compute_next_billing_date(billing_cycle,actual_billing_date,monthly_billing_date,bill_every,contract_start_date);
                 			if(actual_billing_date != monthly_billing_date)
                 			{
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 			if(actual_billing_date == monthly_billing_date && actual_billing_date != final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=new_next_billing_date;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 			else if(actual_billing_date == final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=null;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 				sub_info.Subscription_Status="Inactive";
                 			}
                 		}
                 	}
                 	else
                 	{
                 		sub_info = Subscription[ID == subscription_id];
                 		final_billing_date = sub_info.Final_Billing_Date;
                 		contract_start_date = sub_info.Contract_Start_Date;
                 		new_next_billing_date = thisapp.tenancy.compute_next_billing_date(billing_cycle,actual_billing_date,monthly_billing_date,bill_every,contract_start_date);
                 		if(bill_for.containsIgnoreCase("Current"))
                 		{
                 			if(actual_billing_date == monthly_billing_date && actual_billing_date != final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=new_next_billing_date;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 			else if(actual_billing_date == final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=null;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 				sub_info.Subscription_Status="Inactive";
                 			}
                 			else if(actual_billing_date != monthly_billing_date)
                 			{
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 		}
                 		else if(bill_for.containsIgnoreCase("Previous"))
                 		{
                 			if(actual_billing_date != monthly_billing_date)
                 			{
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 			if(actual_billing_date == monthly_billing_date && actual_billing_date != final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=new_next_billing_date;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 			}
                 			else if(actual_billing_date == final_billing_date)
                 			{
                 				sub_info.Next_Billing_Date=null;
                 				sub_info.Latest_Billing_Date=actual_billing_date;
                 				sub_info.Subscription_Status="Inactive";
                 			}
                 		}
                 	}
                 }
				 void tenancy.calculate_opening_balance_by_tenancy(int tenancy_id)
                 {
                 	tenancy_info = Tenancy[ID = tenancy_id];
                 	opening_balance = 0;
                 	for each  curr_invoice in Invoice[Amount_Due > 0 && Blueprint.Current_Stage in {"Sent","Overdue","Partially Paid"} && Customer_Code == tenancy_id]
                 	{
                 		opening_balance = opening_balance + curr_invoice.Amount_Due * curr_invoice.Exchange_Rate;
                 	}
                 	tenancy_info.Opening_Balance=opening_balance;
                 }
				 date tenancy.compute_next_billing_date(int billing_cycle, date actual_billing_date, date monthly_billing_date, string bill_every, date contract_start_date)
                 {
                 	new_next_billing_date = null;
                 	if(billing_cycle == 1)
                 	{
                 		if(monthly_billing_date == actual_billing_date)
                 		{
                 			new_next_billing_date = actual_billing_date.addMonth(billing_cycle);
                 			if(bill_every != "Last Day Of Month")
                 			{
                 				bill_every_int = bill_every.toLong();
                 			}
                 			else
                 			{
                 				bill_every_int = new_next_billing_date.eomonth(0).getDay();
                 			}
                 			if(new_next_billing_date.getDay() != bill_every_int && new_next_billing_date.getMonth() != 2 && bill_every != "Last Day Of Month")
                 			{
                 				new_next_billing_date = toDate(bill_every + "-" + new_next_billing_date.getMonth() + "-" + new_next_billing_date.getYear(),"dd-MM-yyyy");
                 			}
                 		}
                 		else
                 		{
                 			new_next_billing_date = monthly_billing_date.addMonth(billing_cycle);
                 		}
                 		if(bill_every == "Last Day Of Month")
                 		{
                 			new_next_billing_date = new_next_billing_date.eomonth(0);
                 		}
                 	}
                 	else
                 	{
                 		if(monthly_billing_date == actual_billing_date)
                 		{
                 			if(contract_start_date.getDay() == contract_start_date.eomonth(0).getDay())
                 			{
                 				new_next_billing_date = actual_billing_date.addMonth(billing_cycle).eomonth(0);
                 			}
                 			else if(contract_start_date.getDay() != actual_billing_date.addMonth(billing_cycle).getDay() && actual_billing_date.addMonth(billing_cycle).getMonth() != 2)
                 			{
                 				new_next_billing_date = toDate(contract_start_date.getDay() + "-" + actual_billing_date.addMonth(billing_cycle).getMonth() + "-" + actual_billing_date.addMonth(billing_cycle).getYear(),"dd-MM-yyyy");
                 			}
                 			else
                 			{
                 				new_next_billing_date = actual_billing_date.addMonth(billing_cycle);
                 			}
                 		}
                 		else
                 		{
                 			new_next_billing_date = monthly_billing_date.addMonth(billing_cycle);
                 			if(contract_start_date.getDay() == contract_start_date.eomonth(0).getDay())
                 			{
                 				new_next_billing_date = new_next_billing_date.eomonth(0);
                 			}
                 		}
                 	}
                 	return new_next_billing_date;
                 }
				 int tenancy.convert_bill_cycle_to_int(string billCycle)
                 {
                 	if(billCycle == "Monthly")
                 	{
                 		monthsToAdd = 1;
                 	}
                 	else if(billCycle == "Quarterly")
                 	{
                 		monthsToAdd = 3;
                 	}
                 	else if(billCycle == "Half Yearly")
                 	{
                 		monthsToAdd = 6;
                 	}
                 	else if(billCycle == "Yearly")
                 	{
                 		monthsToAdd = 12;
                 	}
                 	return monthsToAdd;
                 }
				 map tenancy.create_account_desk(int tenantID)
                 {
                 	tenantRec = Tenancy[ID == tenantID];
                 	tenant_name = tenantRec.Tenant_Name;
                 	customer_code = tenantRec.Customer_Code;
                 	contact_name = tenantRec.Contact;
                 	contact_email = tenantRec.Technical_Email;
                 	contact_phone = tenantRec.Phone_Number;
                 	info customer_code;
                 	// Step 1: Check if Account Exists
                 	search_account_url = "https://desk.zoho.com/api/v1/accounts/search?accountName=" + tenant_name;
                 	search_account_response = invokeurl
                 	[
                 		url :search_account_url
                 		type :GET
                 		connection:"zdesk"
                 	];
                 	account_id = "";
                 	if(search_account_response.get("data") != null && search_account_response.get("data").size() > 0)
                 	{
                 		// Account exists, retrieve its ID
                 		account_id = search_account_response.get("data").get(0).get("id");
                 		//info "Account with Tenant Name '" + tenant_name + "' already exists in Zoho Desk. Account ID: " + account_id;
                 		// Step 1.1: Update Account with Billing URL
                 		billing_url = "https://creatorapp.zohopublic.com/xmttechnologiessdnbhd1/xmt-billing-system/report-perma/All_Tenancies/ACSbAKFqeBVrnpJx9wWxHxHH57T8fBbWP85vU06myb4p87QSRjjVaGmt10qGvuPXEXJZ71T5mX2zfbBEJXwk9GsUfMtZY2hzyJzD?Customer_Code=" + customer_code;
                 		update_account_data = Map();
                 		update_cf = Map();
                 		update_cf.put("cf_url_to_billing_system",billing_url);
                 		update_account_data.put("cf",update_cf);
                 		update_account_response = invokeurl
                 		[
                 			url :"https://desk.zoho.com/api/v1/accounts/" + account_id
                 			type :PATCH
                 			parameters:update_account_data.toString()
                 			connection:"zdesk"
                 		];
                 		if(update_account_response.get("id") != null)
                 		{
                 			//info "Account updated successfully with Billing URL.";
                 		}
                 		else
                 		{
                 			//info "Failed to update Account with Billing URL: " + update_account_response.toString();
                 		}
                 	}
                 	else
                 	{
                 		// Step 2: Create Account
                 		desk_account_data = Map();
                 		desk_account_data.put("accountName",tenant_name);
                 		cf = Map();
                 		cf.put("cf_single_line_1",customer_code);
                 		cf.put("cf_technical_contact",contact_name);
                 		cf.put("cf_technical_email",contact_email);
                 		cf.put("cf_technical_phone_number",contact_phone);
                 		// Add the Billing URL during account creation
                 		billing_url = "https://creatorapp.zohopublic.com/xmttechnologiessdnbhd1/xmt-billing-system/report-perma/All_Tenancies/ACSbAKFqeBVrnpJx9wWxHxHH57T8fBbWP85vU06myb4p87QSRjjVaGmt10qGvuPXEXJZ71T5mX2zfbBEJXwk9GsUfMtZY2hzyJzD?Customer_Code=" + customer_code;
                 		cf.put("cf_url_to_billing_system",billing_url);
                 		desk_account_data.put("cf",cf);
                 		desk_api_url = "https://desk.zoho.com/api/v1/accounts";
                 		response = invokeurl
                 		[
                 			url :desk_api_url
                 			type :POST
                 			parameters:desk_account_data.toString()
                 			connection:"zdesk"
                 		];
                 		if(response.get("id") != null)
                 		{
                 			account_id = response.get("id");
                 			//info "Account created successfully in Zoho Desk. Account ID: " + account_id;
                 		}
                 		else
                 		{
                 			//info "Failed to create account in Zoho Desk. Error: " + response.toString();
                 		}
                 	}
                 	// Step 3: Update the Tenancy module with the Desk Account ID
                 	if(account_id != "")
                 	{
                 		// Update the Record_ID field in the Tenancy module
                 		tenantRec.Record_ID=account_id;
                 		//info "Record_ID field in the Tenancy module updated with Account ID: " + account_id;
                 		// Optional: Create Contact Associated with the Account
                 		cf = Map();
                 		cf.put("cf_customer_code",customer_code);
                 		cf.put("cf_technical_contact_name",contact_name);
                 		cf.put("cf_technical_email",contact_email);
                 		cf.put("cf_technical_phone_number",contact_phone);
                 		contact_data = Map();
                 		contact_data.put("lastName",contact_name);
                 		contact_data.put("email",contact_email);
                 		contact_data.put("phone",contact_phone);
                 		contact_data.put("accountId",account_id);
                 		contact_data.put("cf",cf);
                 		desk_contact_url = "https://desk.zoho.com/api/v1/contacts";
                 		create_contact_response = invokeurl
                 		[
                 			url :desk_contact_url
                 			type :POST
                 			parameters:contact_data.toString()
                 			connection:"zdesk"
                 		];
                 		if(create_contact_response.get("id") != null)
                 		{
                 			//info "Contact created successfully in Zoho Desk. Contact ID: " + create_contact_response.get("id");
                 		}
                 		else
                 		{
                 			//info "Failed to create contact in Zoho Desk. Error: " + create_contact_response.toString();
                 		}
                 	}
                 	else
                 	{
                 		//info "No valid account ID. Contact creation and Record_ID update aborted.";
                 	}
                 	return create_contact_response;
                 }
				 string tenancy.find_desk_contact_for_account(string technicalEmail, string deskAccountId)
                 {
                 	contact_id = "";
                 	if(technicalEmail == null || technicalEmail == "")
                 	{
                 		return contact_id;
                 	}
                 	search_contact_url = "https://desk.zoho.com/api/v1/contacts/search?customField1=cf_technical_email:" + technicalEmail;
                 	search_contact_response = invokeurl
                 	[
                 		url :search_contact_url
                 		type :GET
                 		connection:"zdesk"
                 	];
                 	if(search_contact_response.get("data") != null && search_contact_response.get("data").size() > 0)
                 	{
                 		for each  contactRec in search_contact_response.get("data")
                 		{
                 			if(ifnull(deskAccountId,"") == "" || contactRec.get("accountId") == deskAccountId)
                 			{
                 				contact_id = contactRec.get("id");
                 				break;
                 			}
                 		}
                 	}
                 	return contact_id;
                 }
				 string tenancy.generate_tenancy_no(string prefix)
                 {
                 	tenancyInfo = Tenancy[Account_Number.containsIgnoreCase(prefix) && Account_Number != ""] sort by Account_Number desc;
                 	if(tenancyInfo.ID == null)
                 	{
                 		count = 0;
                 	}
                 	else
                 	{
                 		count = tenancyInfo.Account_Number.removeAllAlpha().toLong();
                 	}
                 	count = count + 1;
                 	if(count < 10)
                 	{
                 		pad = "000";
                 	}
                 	else if(count < 100)
                 	{
                 		pad = "00";
                 	}
                 	else if(count < 1000)
                 	{
                 		pad = "0";
                 	}
                 	else
                 	{
                 		pad = "";
                 	}
                 	accNumber = prefix + pad + count;
                 	return accNumber;
                 }
				 string tenancy.get_desk_account_id_for_tenancy(int tenancyId, string customerCodeDisplay, string deskRecordId)
                 {
                 	desk_account_id = ifnull(deskRecordId,"");
                 	if(desk_account_id != "")
                 	{
                 		return desk_account_id;
                 	}
                 	if(customerCodeDisplay == null || customerCodeDisplay == "")
                 	{
                 		return "";
                 	}
                 	search_account_url = "https://desk.zoho.com/api/v1/accounts/search?customField1=cf_single_line_1:" + customerCodeDisplay;
                 	search_account_response = invokeurl
                 	[
                 		url :search_account_url
                 		type :GET
                 		connection:"zdesk"
                 	];
                 	if(search_account_response.get("data") != null && search_account_response.get("data").size() > 0)
                 	{
                 		return search_account_response.get("data").get(0).get("id");
                 	}
                 	return "";
                 }
				 date tenancy.get_monthly_billing_date_from_actual(string billEvery, date actualBillingDate)
                 {
                 	if(billEvery.toLong() == 1)
                 	{
                 		return actualBillingDate.toStartOfMonth();
                 	}
                 	if(billEvery == "Last Day Of Month")
                 	{
                 		return toDate("01-" + actualBillingDate.getMonth() + "-" + actualBillingDate.getYear(),"dd-MM-yyyy").eomonth(0);
                 	}
                 	return toDate(billEvery + "-" + actualBillingDate.getMonth() + "-" + actualBillingDate.getYear(),"dd-MM-yyyy");
                 }
				 date tenancy.normalize_billing_date_for_bill_every(date billingDate, string billEvery)
                 {
                 	if(billEvery == "Last Day Of Month" && billingDate.getDay() != billingDate.eomonth(0).getDay() && billingDate.getMonth() != 2)
                 	{
                 		return toDate(billingDate.eomonth(0).getDay() + "-" + billingDate.getMonth() + "-" + billingDate.getYear(),"dd-MM-yyyy");
                 	}
                 	else if(billEvery == "29" && billingDate.getDay() != 29 && billingDate.getMonth() != 2)
                 	{
                 		return toDate("29" + "-" + billingDate.getMonth() + "-" + billingDate.getYear(),"dd-MM-yyyy");
                 	}
                 	return billingDate;
                 }
				 void tenancy.sync_desk_technical_contact_on_edit(int tenancyId, string technicalEmail, string oldTechnicalEmail, string contactName, string phoneNumber, string customerCodeDisplay, string deskRecordId)
                 {
                 	if(technicalEmail == null || technicalEmail == "")
                 	{
                 		return;
                 	}
                 	desk_account_id = thisapp.tenancy.get_desk_account_id_for_tenancy(tenancyId,customerCodeDisplay,deskRecordId);
                 	if(desk_account_id == "")
                 	{
                 		return;
                 	}
                 	contact_id = thisapp.tenancy.find_desk_contact_for_account(technicalEmail,desk_account_id);
                 	email_changed = technicalEmail != oldTechnicalEmail;
                 	if(email_changed && contact_id == "")
                 	{
                 		search_contact_url = "https://desk.zoho.com/api/v1/contacts/search?customField1=cf_technical_email:" + technicalEmail;
                 		search_contact_response = invokeurl
                 		[
                 			url :search_contact_url
                 			type :GET
                 			connection:"zdesk"
                 		];
                 		if(search_contact_response.get("data") != null && search_contact_response.get("data").size() > 0)
                 		{
                 			for each  contactRec in search_contact_response.get("data")
                 			{
                 				if(contactRec.get("accountId") != desk_account_id)
                 				{
                 					return;
                 				}
                 			}
                 		}
                 		create_contact_cf = Map();
                 		create_contact_cf.put("cf_technical_contact_name",contactName);
                 		create_contact_cf.put("cf_technical_email",technicalEmail);
                 		create_contact_cf.put("cf_technical_phone_number",phoneNumber);
                 		create_contact_data = Map();
                 		create_contact_data.put("email",technicalEmail);
                 		create_contact_data.put("lastName",contactName);
                 		create_contact_data.put("accountId",desk_account_id.toLong());
                 		create_contact_data.put("cf",create_contact_cf);
                 		create_contact_response = invokeurl
                 		[
                 			url :"https://desk.zoho.com/api/v1/contacts"
                 			type :POST
                 			parameters:create_contact_data.toString()
                 			connection:"zdesk"
                 		];
                 		if(create_contact_response.get("id") != null)
                 		{
                 			contact_id = create_contact_response.get("id");
                 		}
                 	}
                 	update_account_cf = Map();
                 	update_account_cf.put("cf_technical_contact",contactName);
                 	update_account_cf.put("cf_technical_email",technicalEmail);
                 	update_account_cf.put("cf_technical_phone_number",phoneNumber);
                 	update_account_data = Map();
                 	update_account_data.put("cf",update_account_cf);
                 	invokeurl
                 	[
                 		url :"https://desk.zoho.com/api/v1/accounts/" + desk_account_id
                 		type :PATCH
                 		parameters:update_account_data.toString()
                 		connection:"zdesk"
                 	]
                 	if(contact_id != "")
                 	{
                 		update_contact_cf = Map();
                 		update_contact_cf.put("cf_technical_contact_name",contactName);
                 		update_contact_cf.put("cf_technical_email",technicalEmail);
                 		update_contact_cf.put("cf_technical_phone_number",phoneNumber);
                 		update_contact_data = Map();
                 		update_contact_data.put("lastName",contactName);
                 		if(email_changed)
                 		{
                 			update_contact_data.put("email",technicalEmail);
                 		}
                 		update_contact_data.put("cf",update_contact_cf);
                 		invokeurl
                 		[
                 			url :"https://desk.zoho.com/api/v1/contacts/" + contact_id
                 			type :PATCH
                 			parameters:update_contact_data.toString()
                 			connection:"zdesk"
                 		]
                 	}
                 }
				 map work_order_creation.update_ticket_number(int recId, string ticketType)
                 {
                 	mess = Map();
                 	mess.put("code",403);
                 	if(ticketType == null || ticketType == "")
                 	{
                 		mess.put("message","No ticket created. Must choose a Ticket Type.");
                 		return mess;
                 	}
                 	subRec = Subscription[ID == recId];
                 	if(subRec == null)
                 	{
                 		mess.put("message","Subscription record not found.");
                 		return mess;
                 	}
                 	try 
                 	{
                 		createWo = insert into Work_Order_Creation
                 		[
                 			Added_User=zoho.loginuser
                 			Subscription=recId
                 			Customer_Name=subRec.Customer_Name
                 			Customer_Code=subRec.Customer_Code
                 			Work_Order_Type=ticketType
                 		];
                 		workOrderId = createWo;
                 		woUrl = thisapp.subscription.build_work_order_perma_url(workOrderId);
                 		createTicket = thisapp.subscription.createTicketUpdateWo(recId,workOrderId,ticketType,woUrl);
                 		if(createTicket.get("code") == 200)
                 		{
                 			mess.put("code",200);
                 			mess.put("message",createTicket.get("message"));
                 			mess.put("ticketId",createTicket.get("ticketId"));
                 			mess.put("ticketNumber",createTicket.get("ticketNumber"));
                 			mess.put("workOrderId",workOrderId);
                 		}
                 		else
                 		{
                 			mess.put("message",createTicket.get("message"));
                 		}
                 	}	catch (e)
                 	{
                 		mess.put("code",500);
                 		mess.put("message","An error occurred: " + e.toString());
                 	}
                 	return mess;
                 }
