		}
		form Project_Location_Telco_Provider
		{
			displayname = "Project/Location/Telco Provider"
			success message = "Project/location/telco Provider Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Project_Location_Telco_Provider
			(
    			type = text
				displayname = "Project/Location/Telco Provider"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Refund_Note
		{
			displayname = "Refund Note"
			success message = "Invoice Added Successfully"
			Supplier_From_Section
			(
				type = section
				displayname = "Supplier (From)"
				visibility = true
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Supplier
			(
				type = picklist	
				values  = Organization_Settings.ID
    			displayformat = [Organization_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Business_Activity_Description
			(
    			type = text
				displayname = "Business Activity Description"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_TIN
			(
    			type = text
				displayname = "Tax Identification Number(TIN)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_ID_Type
			(
    			type = text
				displayname = "ID Type"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Registration_Identification_Passport_Number
			(
    			type = text
				displayname = "Registration / Identification / Passport Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_SST_Registration_Number
			(
    			type = text
				displayname = "SST Registration Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Telephone_Number
			(
    			type = phonenumber
				displayname = "Telephone Number"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Supplier_E_mail
			(
    			type = email
				displayname = "E-mail"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Supplier_Name
			(
    			type = text
				displayname = "Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Street
			(
    			type = textarea
				displayname = "Street"
				height = 100px
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Postcode
			(
    			type = text
				displayname = "Postcode"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_City
			(
    			type = text
				displayname = "City"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_State
			(
    			type = text
				displayname = "State"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Country
			(
    			type = text
				displayname = "Country"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Buyer_To_Section
			(
				type = section
				displayname = "Buyer (To)"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Customer
			(
