			Hide_Fields21 as "Hide Fields"
			{
				type =  form
				form = Refund_Note

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											// Handle Miscellaneous Charges, Fixed Charges and Call Charges
										if(input.Charge_Category == "Miscellaneous Charges")
										{
											hide Call_Charges;
											clear Call_Charges;
										}
										else if(input.Charge_Category == "Fixed Charges")
										{
											hide Call_Charges;
											clear Call_Charges;
										}
										else
										{
											show Call_Charges;
										}
										// Hide fields
										hide Customer_Name_Trigger;
										hide User_Input_Trigger;
										hide Is_Refund_Note_Created_from_Credit_Note;
						)
					}
				}

			}
			Handle_Validation_Submiss3 as "Handle Validation Submission"
			{
				type =  form
				form = Refund_Note

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// Count Total Line Items
										count_item = 0;
										for each  curr_monthly_rental in input.Monthly_Rental
										{
											count_item = count_item + 1;
										}
										for each  curr_internet_charge in input.Internet_Charges
										{
											count_item = count_item + 1;
										}
										for each  curr_call_charge in input.Call_Charges
										{
											count_item = count_item + 1;
										}
										if(count_item == 0)
										{
											alert "Add at least one item need to be added.";
											cancel submit;
										}
										// Validate Call Charges for Telephone Category
										charges_categories = input.Charge_Category;
										if(charges_categories.containsIgnoreCase("Telephone Charges"))
										{
											row_number = 0;
											for each  call_charges in input.Call_Charges
											{
												row_number = row_number + 1;
											}
											if(row_number == 0)
											{
												alert "Please fill Call Charges";
												cancel submit;
											}
										}
										// Validate Monthly Rental Quantity & Unit Price
										for each  curr_monthly_rental in input.Monthly_Rental
										{
											if(ifnull(curr_monthly_rental.Quantity_Monthly_Rental,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_monthly_rental.Unit_Price_Monthly_Rental,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Internet Charges Quantity & Unit Price
										for each  curr_internet_charges in input.Internet_Charges
										{
											if(ifnull(curr_internet_charges.Quantity_Internet_Charges,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_internet_charges.Unit_Price_Internet_Charges,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Call Charges Quantity & Unit Price
										for each  curr_call_charges in input.Call_Charges
										{
											if(ifnull(curr_call_charges.Quantity_Call_Charges,0) <= 0)
											{
												alert "Please enter a quantity more than 0";
												cancel submit;
											}
											if(ifnull(curr_call_charges.Unit_Price_Call_Charges,0) <= 0)
											{
												alert "Please enter a unit price more than 0";
												cancel submit;
											}
										}
										// Validate Refund Amount Does Not Exceed Credit Remaining
										// Fetch explicitly — dot-notation on lookup can return null/0 on validate
										get_ref_cn = Credit_Note[ID == input.Reference_Credit_Note];
										credits_remaining = ifnull(get_ref_cn.Grand_Total,0) - ifnull(get_ref_cn.Credits_Used,0) - ifnull(get_ref_cn.Refund,0);
										if(credits_remaining < input.Grand_Total)
										{
											alert "The refund amount cannot exceed the credit remaining of " + credits_remaining;
											cancel submit;
										}
										// Validate Refund Note Created from Credit Note
										if(Is_Refund_Note_Created_from_Credit_Note == false)
										{
											alert "Please create refund note from credit note.";
											cancel submit;
										}
						)
					}
				}

			}
			Handle_Customer_Name_Chan4 as "Handle Customer Name Changes"
			{
				type =  form
				form = Refund_Note

				record event = on add or edit

				on user input of Customer
				{
					actions 
					{
						custom deluge script
						(
											input.Customer_Name_Trigger = !input.Customer_Name_Trigger;
						)
					}
					actions 
					{
						custom deluge script
						(
											credit_note_id_list = Credit_Note[Customer == input.Customer && Credits_Remaining > 0].ID.getAll();
										if(credit_note_id_list.size() == 0)
										{
											input.Reference_Credit_Note:ui.add({});
											alert "No credit notes found for this customer. Refund note must have an credit note reference.";
										}
										else
										{
											input.Reference_Credit_Note:ui.add(credit_note_id_list);
										}
						)
					}
				}

			}
			Handle_Customer_Code_Chan5 as "Handle Customer Code Changes"
			{
				type =  form
				form = Refund_Note

				record event = on add or edit

				on user input of Customer_Code
				{
					actions 
					{
						custom deluge script
						(
											tenancyInfo = Tenancy[ID == input.Customer_Code];
										input.Enable_Reminder = ifnull(tenancyInfo.Enable_Reminder,null);
										input.Payment_Term = ifnull(tenancyInfo.Payment_Term,null);
										if(input.Invoice_Date != null && input.Customer_Code != null && input.Payment_Term != null)
										{
											input.Due_Date = input.Invoice_Date.addDay(input.Payment_Term.Days);
										}
										if(input.Customer_Code == null)
										{
											input.Due_Date = null;
											input.Enable_Reminder = "";
										}
						)
					}
				}

			}
			Successful_form_submissio1 as "Successful form submission of Refund Note"
			{
				type =  form
				form = Refund_Note

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											input_credit_note = Credit_Note[ID = input.Reference_Credit_Note];
										// Refund Calculation
										input_credit_note.Refund_History=null;
										refund_note_list = Refund_Note[Reference_Credit_Note = input.Reference_Credit_Note];
										refund_total = 0;
										for each  curr_refund_note in refund_note_list
										{
											curr_new_refund_history_row = Credit_Note.Refund_History();
											curr_new_refund_history_row.Refund_History_Refund_Note=curr_refund_note.ID;
											curr_new_refund_history_row.Refund_History_Amount_Refunded=curr_refund_note.Grand_Total;
											curr_new_refund_history_row.Refund_History_Date=curr_refund_note.Invoice_Date;
											refund_total = refund_total + curr_refund_note.Grand_Total;
											input_credit_note.Refund_History.insert(curr_new_refund_history_row);
										}
										// Apply Credit To Invoices Calculation (Credit note form)
										input_credit_note.Credit_Applied_Invoices=null;
										apply_credit_to_invoice_line_list = Apply_Credit_To_Invoice_Line[Credit_Note = input.Reference_Credit_Note];
										credits_used_total = 0;
										for each  curr_apply_credit_to_invoice_line in apply_credit_to_invoice_line_list
										{
											curr_new_credit_applied_invoices_row = Credit_Note.Credit_Applied_Invoices();
											curr_new_credit_applied_invoices_row.CAI_Apply_Credit_To_Invoice_Line_ID=curr_apply_credit_to_invoice_line.ID;
											curr_new_credit_applied_invoices_row.CAI_Date=curr_apply_credit_to_invoice_line.Amount_Applied_Date;
											curr_new_credit_applied_invoices_row.CAI_Invoice_No=curr_apply_credit_to_invoice_line.Invoice;
											curr_new_credit_applied_invoices_row.CAI_Amount_Credited=curr_apply_credit_to_invoice_line.Amount_Applied;
											credits_used_total = credits_used_total + curr_apply_credit_to_invoice_line.Amount_Applied;
											input_credit_note.Credit_Applied_Invoices.insert(curr_new_credit_applied_invoices_row);
										}
										// All calculation
										input_credit_note.Refund=refund_total;
										input_credit_note.Credits_Used=credits_used_total;
										input_credit_note.Credits_Remaining=input_credit_note.Grand_Total - refund_total - credits_used_total;
										current_stage = input_credit_note.Blueprint.Current_Stage;
										if(current_stage == "Approved" || current_stage == "Open")
										{
											if(input_credit_note.Credits_Remaining > 0 && current_stage != "Open")
											{
												thisapp.blueprint.changeStage("Credit_Note","Credit_Note_Blueprint","Open",input_credit_note.ID);
											}
											else if(input_credit_note.Credits_Remaining == 0 && current_stage != "Closed")
											{
												thisapp.blueprint.changeStage("Credit_Note","Credit_Note_Blueprint","Closed",input_credit_note.ID);
											}
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											openUrl("#Report:Refund_Notes","same window");
						)
					}
				}

			}
