				displayname = "Payable To"
				values  = Chart_Of_Account[Account_Type == "Bank"].ID
    			displayformat = [Account + " - " + Bank_Account_Number]
				sortorder = ascending
				height = 60px
	 			row = 9
	 			column = 2   
				width = medium
			)
			must have Reference_Invoice
			(
				type = picklist	
				displayname = "Reference Invoice"
				values  = Invoice.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 9
	 			column = 2   
				width = medium
			)
			Rejection_Section
			(
				type = section
				displayname = "Rejection Section"
				visibility = true
	 			row = 10
	 			column = 0   
				width = medium
			)
			Rejection_Reason
			(
    			type = textarea
				displayname = "Rejection Reason"
				height = 100px
	 			row = 10
	 			column = 1   
				width = medium
			)
			Invoice_Related_List
			(
				type = grid
				displayname = "Invoice Related List"
				USERNAME
				(
    				type = text
					width = medium
				)
				INVOICE_NUMBER
				(
    				type = text
					width = medium
				)
				Related_List_Date
				(
    				type = date
					displayname = "DATE"
					alloweddays = 0,1,2,3,4,5,6
					width = medium
				)
				Related_List_Time
				(
    				type = time
					displayname = "TIME"
					timedisplayoptions = "hh:mm:ss" 
					width = medium
				)
				SUBMISSION_ID
				(
    				type = text
					displayname = "SUBMISSION ID"
					width = medium
				)
				UUID
				(
    				type = url
					enable  linkname
					width = medium
				)
				PUBLIC_LINK
				(
    				type = url
					enable  linkname
					width = medium
				)
				STATUS
				(
    				type = text
					width = medium
				)
				MESSAGE
				(
    				type = textarea
					height = 100px
					width = medium
				)
	 			row = 11
	 			column = 1   
				width = medium
			)
			Decision_Section
			(
				type = section
				displayname = "Decision Section"
	 			row = 12
	 			column = 0   
				width = medium
			)
			Customer_Name_Trigger
			(
    			type = checkbox
				displayname = "Customer Name Trigger"
				initial value = false
	 			row = 12
	 			column = 1   
				width = medium
			)
			User_Input_Trigger
			(
    			type = checkbox
				initial value = false
	 			row = 12
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Draft","Pending Approval","Rejected","Approved","Closed","Sent","Paid","Partially Paid","Overdue"}
			}
