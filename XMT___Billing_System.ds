				Customer_Registration_Identification_Passport_Number as "Registration / Identification / Passport Number"
				Customer_SST_Registration_Number as "SST Registration Number"
				Customer_Telephone_Number as "Telephone Number"
				(
					displayformat = plainnumber 
				)
				Customer_E_mail as "E-mail"
				Customer_Name as "Name"
				Customer_Street as "Street"
				Customer_Postcode as "Postcode"
				Customer_City as "City"
				Customer_State as "State"
				Customer_Country as "Country"
				Delivery_Street as "Delivery Street"
				Delivery_Postcode as "Delivery Postcode"
				Delivery_City as "Delivery City"
				Delivery_State as "Delivery State"
				Delivery_Country as "Delivery Country"
				Invoice_No as "Invoice No."
				Invoice_UUID as "Invoice UUID"
				Invoice_UUID_Link as "Invoice UUID Link"
				Invoice_Public_Link as "Invoice Public Link"
				QR_Invoice_Public_Link as "QR Invoice Public Link"
				Invoice_Date as "Invoice Date"
				Payment_Term as "Payment Term"
				Due_Date as "Due Date"
				Charge_Category as "Charge Category"
				Attachment
				Base_Currency as "Base Currency"
				Invoice_Currency as "Invoice Currency"
				Exchange_Rate as "Exchange Rate"
				Sub_Total_Monthly_Rental as "Sub Total Monthly Rental"
				Total_Tax_Monthly_Rental as "Total Tax Monthly Rental"
				Grand_Total_Monthly_Rental as "Grand Total Monthly Rental"
				Sub_Total_Internet_Charges as "Sub Total Internet Charges"
				Total_Tax_Internet_Charges as "Total Tax Internet Charges"
				Grand_Total_Internet_Charges as "Grand Total Internet Charges"
				Sub_Total_Call_Charges as "Sub Total Call Charges (Analog, Domestic & Overseas)"
				Total_Tax_Call_Charges as "Total Tax Call Charges (Analog, Domestic & Overseas)"
				Grand_Total_Call_Charges as "Grand Total Call Charges (Analog, Domestic & Overseas)"
				Sub_Total as "Sub Total"
				Total_Tax as "Total Tax"
				Grand_Total as "Grand Total"
				Grand_Total_Base_Currency as "Grand Total (Base Currency)"
				Amount_Paid as "Amount Paid"
				Amount_Due as "Amount Due"
				Payable_To as "Payable To"
				Reference_Invoice as "Reference Invoice"
				Rejection_Reason as "Rejection Reason"
				Customer_Name_Trigger as "Customer Name Trigger"
				User_Input_Trigger
			)
			custom actions
			(
				"Send Proforma Invoice"
				(
	  			workflow = Send_Proforma_Invoice1
				show action in view header = true
				condition = (Blueprint.Current_Stage != "Draft" && Blueprint.Current_Stage != "Pending Approval" && Blueprint.Current_Stage != "Rejected")
				confirmation before execution
				(
					message for individual record = "Are you sure you want to \"Send Proforma Invoice\" for ${Invoice_No}?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Mark As Sent"
				(
	  			workflow = Mark_As_Sent_Invoice1
				show action in view header = true
				condition = (Blueprint.Current_Stage == "Approved")
				confirmation before execution
				(
					message for individual record = "Are you sure you want to \"Mark As Sent\" this Pro Forma Invoice ${Invoice_No}?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Refund"
				(
	  			workflow = Refund1
				show action in view header = true
				condition = (Blueprint.Current_Stage == "Paid")
				confirmation before execution
				(
					message for individual record = "Are you sure you want to \"Refund\" this Pro Forma Invoice ${Invoice_No}?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Record Payment Deposit"
				(
	  			workflow = Record_Payment_Deposit1
				show action in view header = true
				condition = (Blueprint.Current_Stage == "Sent" || Blueprint.Current_Stage == "Partially Paid" || Blueprint.Current_Stage == "Overdue")
				confirmation before execution
				(
					message for individual record = "Open Payment Received for Pro Forma Invoice ${Invoice_No}?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Send Email"
				(
	  			workflow = Send_Email
				show action in view header = true
				condition = (Blueprint.Current_Stage != "Draft" && Blueprint.Current_Stage != "Pending Approval" && Blueprint.Current_Stage != "Rejected" && Blueprint.Current_Stage != "Approved")
				confirmation before execution
				(
					message for individual record = "Execute the Send Email action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
			)
		}
		list All_Tenancies
		{
			displayName = "All Tenancies"
			show all rows from Tenancy    
			(
				Customer_Code as "Customer Code"
				Customer_Name as "Customer Name"
				(
					view = All_Customers_Profile
				)
				Project_Location_Telco_Provider as "Project/Location/Telco Provider"
				Building
				Account_Type as "Account Type"
				Account_Number as "Account Number"
				Tenant_Name as "Tenant Name"
				Payable_To as "Payable To"
				Technical_Email as "Technical Email"
				Phone_Number as "Technical Phone Number"
				(
					displayformat = plainnumber 
				)
				Customer_Name.Email_Address as "Email Address"
				Customer_Name.Customer_Name as "Customer Name"
				Opening_Balance as "Opening Balance"
			)
			sort by
			(
				Customer_Code ascending
			)
			custom actions
			(
				"Create Account"
				(
	  			workflow = Create_Account_in_Desk
				show action in view header = true
				confirmation before execution
				(
					message for individual record = "Execute the Create Account action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
			)
		}
	}
