11745616723925010","content":"<div style=\"\">\n   <table cellspacing=\"0\"\n          style=\"margin: 0px auto; width: 100%; border-collapse: collapse\">\n    <tbody>\n     <tr>\n      <td\n          width=\"20%\"\n            style=\"text-align: right; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51); border-left: none; border-right: none\"><font\n            color=\"#000000\" style=\"font-size: 10px\"\n            face=\"arimo\">T<\/font><font color=\"#000000\" style=\"\"\n              face=\"arimo\"><font style=\"font-size: 10px\"\n              face=\"arimo\">otal&nbsp; <\/font><span\n              style=\"font-size: 10px\">${Customer_Name.Currency}<\/span> <span\n          style=\"font-size: 10px; color: rgb(0, 0, 0); font-weight: 400; font-style: normal\">&nbsp;<\/span> <\/font><\/td>\n      <td\n          style=\"text-align: left; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51); border-left: none; border-right: none\"\n            width=\"20%\"><font style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n          style=\"text-align: left; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51); border-left: none; border-right: none\"\n            width=\"20%\"><font style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td width=\"20%\"\n            style=\"text-align: right; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51); border-left: none; border-right: none\"><font\n            style=\"font-size: 10px\" face=\"arimo\"><font style=\"\"\n                color=\"#000000\"> ${Amount_Received} <span\n          style=\"font-weight: 400; font-style: normal\">&nbsp;<\/span> <\/font> <br /><\/font><\/td>\n      <td\n          width=\"20%\"\n            style=\"text-align: right; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51); border-left: none\"><font\n            style=\"font-size: 10px\" face=\"arimo\"><font style=\"\"\n                color=\"#000000\"> ${Total_Still_Owing} <span style=\"font-weight: 400; font-style: normal\">&nbsp;<\/span> <\/font> <br /><\/font><\/td>\n     <\/tr>\n    <\/tbody>\n   <\/table>\n  <\/div>"}}],"style":""},{"colElements":[{"type":"spacer","element":{"id":"u_elem_3723911600000143","height":"25"}}],"style":""}]}}],"style":""},{"colElements":[{"type":"spacer","element":{"id":"u_elem_15793740000009537","height":"25"}}],"style":""}]}},{"type":"columns","element":{"split":"100","id":"u_elem_3579294","elemStyle":"","collayouts":[{"colElements":[{"type":"spacer","element":{"id":"u_elem_3582872899999976","height":"25"}},{"type":"text","element":{"id":"u_elem_35792926999999285","fields":[],"content":"<div style=\"background: rgba(0, 0, 0, 0); padding: 0px\">\n   <h1\n      style=\"text-align: center; color: rgb(0, 0, 0); font-style: normal\"><font\n        style=\"\"><font style=\"font-size: 10px\" face=\"arimo\"> <font\n            style=\"font-weight: 400\"> <font\n          style=\"font-size: 10px\">\u200b<\/font>\u200b<\/font> <font style=\"\">This is a computer generated document and therefore no signature is required<\/font><\/font> <\/font><\/h1>\n  <\/div>"}}],"style":""}]}}],"id":1}],"resize":"a4","themeFont":"lato","isHeaderEnabled":false}
				}
			}
		}
		form Payment_Received_Line_Item
		{
			displayname = "Payment Received Line Item"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Document_Date
			(
    			type = date
				displayname = "Document Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Reference_No
			(
    			type = text
				displayname = "Reference No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Description
			(
    			type = textarea
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice_No
			(
				type = picklist	
				displayname = "Invoice No."
				values  = Invoice.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Debit_Note_No
			(
				type = picklist	
				displayname = "Debit Note No."
				values  = Debit_Note.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Pro_Forma_Invoice_No
			(
				type = picklist	
				displayname = "Pro Forma Invoice No."
				values  = Pro_Forma_Invoices.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Amount
			(
				type = decimal
				format = commadotwestern
	 			row = 1
	 			column = 1   
				width = medium
			)
			Outstanding_Balance
			(
				type = decimal
				displayname = "Outstanding Balance"
				format = commadotwestern
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Allocation
			(
				type = decimal
				format = commadotwestern
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Allocation_MYR
			(
				type = decimal
				displayname = "Allocation (MYR)"
				format = commadotwestern
	 			row = 1
	 			column = 1   
				width = medium
			)
			Still_Owing
			(
				type = decimal
				displayname = "Still Owing"
				format = commadotwestern
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Payment_Received
			(
				type = picklist	
				displayname = "Payment Received"
				values  = Payment_Received.ID
    			bidirectional = Payment_Received_Line_Item
    			displayformat = [Payment_Received_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Payment_Term
		{
			displayname = "Payment Term"
			success message = "Payment Term Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Days
			(
				type = number
				displayname = "Payment Term"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Pro_Forma_Invoices
		{
			displayname = "Pro Forma Invoices"
			success message = "Invoice Added Successfully"
			Supplier_From_Section
			(
				type = section
				displayname = "Supplier (From)"
				visibility = true
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Supplier
			(
				type = picklist	
				values  = Organization_Settings.ID
    			displayformat = [Organization_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Business_Activity_Description
			(
    			type = text
				displayname = "Business Activity Description"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_TIN
			(
    			type = text
				displayname = "Tax Identification Number(TIN)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_ID_Type
			(
    			type = text
				displayname = "ID Type"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Registration_Identification_Passport_Number
			(
    			type = text
				displayname = "Registration / Identification / Passport Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_SST_Registration_Number
			(
    			type = text
				displayname = "SST Registration Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supplier_Telephone_Number
			(
    			type = phonenumber
				displayname = "Telephone Number"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Supplier_E_mail
			(
    			type = email
				displayname = "E-mail"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Supplier_Name
			(
    			type = text
				displayname = "Name"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Street
			(
    			type = textarea
				displayname = "Street"
				height = 100px
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Postcode
			(
    			type = text
				displayname = "Postcode"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_City
			(
    			type = text
				displayname = "City"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_State
			(
    			type = text
				displayname = "State"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Supplier_Country
			(
    			type = text
				displayname = "Country"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Buyer_To_Section
			(
				type = section
				displayname = "Buyer (To)"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Customer
			(
				type = picklist	
				values  = Customer_Profile.ID
    			displayformat = [Customer_Name]
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_Code
			(
				type = picklist	
				displayname = "Customer Code"
				values  = Tenancy[Customer_Name.ID == input.Customer].ID
    			displayformat = [Customer_Code]
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_TIN
			(
    			type = text
				displayname = "Tax Identification Number(TIN)"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_ID_Type
			(
    			type = text
				displayname = "ID Type"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_Registration_Identification_Passport_Number
			(
    			type = text
				displayname = "Registration / Identification / Passport Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_SST_Registration_Number
			(
    			type = text
				displayname = "SST Registration Number"
	 			row = 2
	 			column = 1   
				width = medium
			)
			must have Customer_Telephone_Number
			(
    			type = phonenumber
				displayname = "Telephone Number"
	 			row = 2
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Customer_E_mail
			(
    			type = email
				displayname = "E-mail"
				maxchar = 80
	 			row = 2
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Customer_Name
			(
    			type = text
				displayname = "Name"
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_Street
			(
    			type = textarea
				displayname = "Street"
				height = 100px
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_Postcode
			(
    			type = text
				displayname = "Postcode"
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_City
			(
    			type = text
				displayname = "City"
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_State
			(
    			type = text
				displayname = "State"
	 			row = 2
	 			column = 2   
				width = medium
			)
			must have Customer_Country
			(
    			type = text
				displayname = "Country"
	 			row = 2
	 			column = 2   
				width = medium
			)
			Shipping_Information_Section
			(
				type = section
				displayname = "Shipping Information"
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			Delivery_Street
			(
    			type = textarea
				displayname = "Delivery Street"
				height = 100px
	 			row = 3
	 			column = 1   
				width = medium
			)
			Delivery_Postcode
			(
    			type = text
				displayname = "Delivery Postcode"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Delivery_City
			(
    			type = text
				displayname = "Delivery City"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Delivery_State
			(
    			type = text
				displayname = "Delivery State"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Delivery_Country
			(
    			type = text
				displayname = "Delivery Country"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Invoice_Info
			(
				type = section
				displayname = "Invoice Info"
				visibility = true
	 			row = 4
	 			column = 0   
				width = medium
			)
			unique Invoice_No
			(
    			type = text
				displayname = "Invoice No."
    			description
    			[
    				type = tooltip
    			 	message = "Doc. No. will be generated after record is created"
    			]
	 			row = 4
	 			column = 1   
				width = medium
			)
			Invoice_UUID
			(
    			type = text
				displayname = "Invoice UUID"
	 			row = 4
	 			column = 1   
				width = medium
