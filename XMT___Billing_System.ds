												}
											}
											downloadPRTempUrl = "https://creatorapp.zohopublic.com/xmttechnologiessdnbhd1/xmt-billing-system/record-pdf/Invoice_Payment_Received_Report1/" + recId + "/" + input.Payment_Received_No + "/vDe9MDTbK1MW8qRyRCh6s6FkBqpYA38qauwGzspMFVVTsgE1NxyzguuuyVFs2zYmtaFF7a0suRx8jFXXFZabMJSpT18DQJKDGy9R";
											prFile = invokeurl
											[
												url :downloadPRTempUrl
												type :GET
											];
											prFile.setparamname("file");
											sendmail
											[
												from :zoho.adminuserid
												to :toAddresses
												subject :emailSubject
												message :emailBody
												Attachments :file:prFile
											]
										}
					)
					}
					actions  (Receipt_Sent == false)
					{
					on click
					(
						input.Receipt_Sent = true;
					)
					}
				}
			}
			Convert_To_Credit_Note as "Convert To Credit Note"
			{
				type =  functions
				form = Invoice
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
										errorMessage = "";
										source_stage = input.Blueprint.Current_Stage;
										if(source_stage == "Sent" || source_stage == "Overdue" || source_stage == "Partially Paid" || source_stage == "Paid")
										{
											// eligible stage
										}
										else
										{
											errorMessage = "Invoice stage '" + source_stage + "' is not eligible for a credit note.";
										}
										if(errorMessage == "")
										{
											ref_invoice_id = input.ID;
											original_total = input.Grand_Total;
											crediting_cn_list = Credit_Note[Reference_Invoice == ref_invoice_id && (Blueprint.Current_Stage == "Approved" || Blueprint.Current_Stage == "Closed" || Blueprint.Current_Stage == "Open" || Blueprint.Current_Stage == "Pending Approval")];
											crediting_cn_total = 0;
											for each  cn in crediting_cn_list
											{
												crediting_cn_total = crediting_cn_total + cn.Grand_Total;
											}
											remaining_creditable = original_total - crediting_cn_total;
											if(remaining_creditable <= 0)
											{
												errorMessage = "Cannot convert to credit note: no remaining creditable amount for this invoice. Already credited: RM " + crediting_cn_total + " of RM " + original_total + ".";
											}
										}
										if(errorMessage == "")
										{
											ref_uuid = input.Invoice_UUID;
											if(ref_uuid == null || ref_uuid == "")
											{
												errorMessage = "Reference Invoice does not have a valid LHDN UUID. Submit the invoice to LHDN first, then create the credit note.";
											}
										}
										if(errorMessage == "")
										{
											openURL("#Form:Credit_Note?viewLinkName=Credit_Notes&Reference_Invoice=" + input.ID + "&Customer=" + input.Customer,"popup window");
										}
										else
										{
											openUrl("#Form:Alert_Message?Error_Message=" + errorMessage,"popup window","height=auto,width=auto");
										}
					)
					}
				}
			}
