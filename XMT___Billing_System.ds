			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Customer_Statement
		{
			displayname = "Customer Statement"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Customer_Name
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customer_Profile.ID
    			displayformat = [Customer_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_Code
			(
				type = list	
				displayname = "Customer Code"
				values  = Tenancy[Customer_Name.ID == input.Customer_Name].ID
    			displayformat = [Customer_Code]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Statement_Type
			(
				type = picklist
				displayname = "Statement Type"
				maxchar = 100
				values = {"Statement Of Account","Statement Of Outstanding"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Start_Date
			(
    			type = date
				displayname = "Start Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have End_Date
			(
    			type = date
				displayname = "End Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			Transactions
			(
				type = grid
				Tenant_Name
				(
    				type = text
					displayname = "Tenant Name"
					width = medium
				)
				Customer_Code
				(
    				type = text
					displayname = "Customer Code"
					width = medium
				)
				Date_field
				(
    				type = date
					displayname = "Date"
					alloweddays = 0,1,2,3,4,5,6
					width = 100px
				)
				Transaction
				(
					type = picklist
					maxchar = 100
					values = {"Invoice","Debit Note","Pro Forma Invoice","Credit Note","Payment Received","Opening Balance"}
					width = 100px
				)
				Details
				(
    				type = textarea
					height = 100px
					width = 200px
				)
				Amount
				(
					type = decimal
					format = commadotwestern
					width = 100px
				)
				Payments
				(
					type = decimal
					format = commadotwestern
					width = 100px
				)
				Balance
				(
					type = decimal
					format = commadotwestern
					width = 100px
				)
	 			row = 2
	 			column = 1   
				width = medium
			)
			Account_Summary
			(
				type = section
				displayname = "Account Summary"
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			Opening_Balance
			(
				type = decimal
				displayname = "Opening Balance"
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Invoiced_Amount
			(
				type = decimal
				displayname = "Invoiced Amount"
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Amount_Paid
			(
				type = decimal
				displayname = "Amount Paid"
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Balance_Due
			(
				type = decimal
				displayname = "Balance Due"
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Section2
			(
				type = section
				displayname = "Section"
	 			row = 4
	 			column = 0   
				width = medium
			)
			Organization
			(
				type = picklist	
				values  = Organization_Settings.ID
    			displayformat = [Organization_Name]
				sortorder = ascending
	 			row = 4
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					Generate
					(
   						type = submit
   						displayname = "Generate"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
