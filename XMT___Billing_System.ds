					width = medium
				)
				CAI_Invoice_No
				(
					type = picklist	
					displayname = "Invoice No"
					values  = Invoice.ID
    				displayformat = [Invoice_No]
					sortorder = ascending
					width = medium
				)
				CAI_Amount_Credited
				(
					type = decimal
					displayname = "Amount Credited"
					width = medium
				)
	 			row = 11
	 			column = 1   
				width = medium
			)
			Refund_History
			(
				type = grid
				displayname = "Refund History"
				Refund_History_Date
				(
    				type = date
					displayname = "Date"
					alloweddays = 0,1,2,3,4,5,6
					width = medium
				)
				Refund_History_Refund_Note
				(
					type = picklist	
					displayname = "Refund Note"
					values  = Refund_Note.ID
    				displayformat = [Invoice_No]
					sortorder = ascending
					width = medium
				)
				Refund_History_Amount_Refunded
				(
					type = decimal
					displayname = "Amount Refunded"
					width = medium
				)
	 			row = 12
	 			column = 1   
				width = medium
			)
			System_Section
			(
				type = section
				displayname = "System Section"
	 			row = 13
	 			column = 0   
				width = medium
			)
			Invoice_Related_List
			(
				type = grid
				displayname = "Invoice Related List"
				USERNAME
				(
    				type = text
					width = medium
				)
				INVOICE_NUMBER
				(
    				type = text
					width = medium
				)
				Related_List_Date
				(
    				type = date
					displayname = "DATE"
					alloweddays = 0,1,2,3,4,5,6
					width = medium
				)
				Related_List_Time
				(
    				type = time
					displayname = "TIME"
					timedisplayoptions = "hh:mm:ss" 
					width = medium
				)
				SUBMISSION_ID
				(
    				type = text
					displayname = "SUBMISSION ID"
					width = medium
				)
				UUID
				(
    				type = url
					enable  linkname
					width = medium
				)
				PUBLIC_LINK
				(
    				type = url
					enable  linkname
					width = medium
				)
				STATUS
				(
    				type = text
					width = medium
				)
				MESSAGE
				(
    				type = textarea
					height = 100px
					width = medium
				)
	 			row = 14
	 			column = 1   
				width = medium
			)
			Decision_Section
			(
				type = section
				displayname = "Decision Section"
	 			row = 15
	 			column = 0   
				width = medium
			)
			Customer_Name_Trigger
			(
    			type = checkbox
				displayname = "Customer Name Trigger"
				initial value = false
	 			row = 15
	 			column = 1   
				width = medium
			)
			User_Input_Trigger
			(
    			type = checkbox
				initial value = false
	 			row = 15
	 			column = 1   
				width = medium
			)
			Is_Initialization
			(
    			type = checkbox
				initial value = false
	 			row = 15
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Draft","Pending Approval","Rejected","Approved","Open","Closed"}
			}
