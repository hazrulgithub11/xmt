					displayname = "Circuit ID Type"
					values  = Circuit_ID_Type.ID
    				displayformat = [Circuit_ID_Type]
					sortorder = ascending
					width = 200px
				)
				must have Work_Order_Internet_Charges
				(
    				type = upload file
					displayname = "Work Order"
				browse = local_drive
    				description
    				[
    					type = tooltip
    				 	message = "Upload Work Order And Supporting Docs"
    				]
					width = 200px
				)
	 			row = 2
	 			column = 1   
				width = medium
			)
			Call_Charges
			(
				type = grid
				displayname = "Call Charges"
				must have Item_Call_Charges
				(
					type = picklist	
					displayname = "Item"
					values  = Transaction_Type.ID
    				displayformat = [Item_Name]
					sortorder = ascending
					width = medium
				)
				must have Item_Code_Call_Charges
				(
    				type = text
					displayname = "Item Code"
					width = medium
				)
				must have Description_Call_Charges
				(
    				type = textarea
					displayname = "Description"
					height = 100px
					width = medium
				)
				must have Business_Segment_Call_Charges
				(
					type = picklist	
					displayname = "Business Segment"
					values  = Business_Segment.ID
    				displayformat = [Business]
					sortorder = ascending
					width = medium
				)
				must have Business_Unit_Call_Charges
				(
					type = picklist	
					displayname = "Business Unit"
					values  = Business_Unit.ID
    				displayformat = [Business_Unit]
					sortorder = ascending
					width = medium
				)
				must have Circuit_ID_Call_Charges
				(
    				type = text
					displayname = "Circuit ID"
    				description
    				[
    					type = tooltip
    				 	message = "EG: BBXXX, GBBXXX, FRXXX, IPTXXX"
    				]
					width = 200px
