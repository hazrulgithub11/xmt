		workflow
		{
		form
		{
			Handle_Delivery_Address_S as "Handle Delivery Address Same as Business Address"
			{
				type =  form
				form = Customer_Profile

				record event = on add or edit

				on user input of Delivery_Address_same_as_Business_Address
				{
					actions 
					{
						custom deluge script
						(
											if(input.Delivery_Address_same_as_Business_Address == true)
										{
											input.Delivery_Street = input.Business_Street;
											input.Delivery_Postcode = input.Postcode;
											input.Delivery_City = input.City;
											input.Delivery_State = input.State;
											input.Delivery_Country = input.Country;
											input.Delivery_Email_Address = input.Email_Address;
											input.Delivery_Phone_Number = input.Phone_Number;
										}
										else
										{
											input.Delivery_Street = "";
											input.Delivery_Postcode = "";
											input.Delivery_City = "";
											input.Delivery_State = null;
											input.Delivery_Country = null;
											input.Delivery_Email_Address = "";
											input.Delivery_Phone_Number = "";
										}
						)
					}
				}

			}
			Hide_Fields_During_Create as "Hide Fields During Create"
			{
				type =  form
				form = Tenancy

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Account_Number;
						)
					}
				}

			}
			Disable_Fields1 as "Disable Fields"
			{
				type =  form
				form = Tenancy

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Account_Number;
										disable Display_Name;
										disable Record_ID;
										disable Opening_Balance;
						)
					}
					actions 
					{
						custom deluge script
						(
											if(!thisapp.permissions.isUserInProfile("Administrator"))
										{
											disable Customer_Name;
											disable Auto_Fill_with_Customer_Details;
											disable Tenant_Name;
											disable Customer_Code;
											disable Project_Location_Telco_Provider;
											disable Building;
											disable Account_Type;
											disable Payable_To;
											disable Payment_Term;
											disable Enable_Reminder;
											disable Contact;
											disable Technical_Email;
											disable Phone_Number;
											disable Street;
											disable Postcode;
											disable City;
											disable State;
											disable Country;
										}
						)
					}
				}

			}
			Load_of_the_form_created as "Load of the form created"
			{
				type =  form
				form = Subscription

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											/* Hide fields */
										hide Next_Billing_Date;
										hide Latest_Billing_Date;
										hide Final_Billing_Date;
										hide Prorate;
										hide Prorate_Note;
										hide User_Input_Trigger;
										/* Subscription initialization */
