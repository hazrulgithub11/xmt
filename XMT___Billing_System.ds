										new_invoice_uuid_link = invoice_submit_lhdn_output.get("UUID_LINK");
										new_public_link = invoice_submit_lhdn_output.get("PUBLIC_LINK");
										if(new_invoice_uuid != null && new_invoice_uuid != "")
