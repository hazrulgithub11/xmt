  style=\"margin: 0px auto; width: 100%\">\n    <tbody>\n     <tr>\n      <td\n          style=\"text-align: center\" width=\"33%\"><font face=\"arimo\"\n                style=\"font-size: 10px\"> <span> <font style=\"\"\n              color=\"#000000\">&nbsp;${Total_Tax_Call_Charges}&nbsp;<\/font> <\/span> <span style=\"color: rgb(68, 68, 68); font-weight: 400; font-style: normal\">&nbsp;<\/span> <br /><\/font><\/td>\n     <\/tr>\n    <\/tbody>\n   <\/table>\n  <\/div>"}}],"style":""},{"colElements":[{"type":"text","element":{"Fields":[{"Label_Name":"Grand_Total_Call_Charges"}],"id":"u_elem_3286597","content":"<div style=\"\">\n   <table cellspacing=\"0\"\n          style=\"margin: 0px auto; width: 100%\">\n    <tbody>\n     <tr>\n      <td\n          style=\"text-align: center\" width=\"33%\"><font face=\"arimo\"\n                style=\"font-size: 10px\"> <span> <font style=\"\"\n              color=\"#000000\">&nbsp; ${Grand_Total_Call_Charges}<\/font> <\/span> <span style=\"color: rgb(68, 68, 68); font-weight: 400; font-style: normal\">&nbsp;<\/span> <br /><\/font><\/td>\n     <\/tr>\n    <\/tbody>\n   <\/table>\n  <\/div>"}}],"style":""}]}},{"type":"text","element":{"Fields":[{"Label_Name":"Sub_Total"},{"Label_Name":"Sub_Total_Call_Charges"},{"Label_Name":"Sub_Total_Internet_Charges"},{"Label_Name":"Sub_Total_Monthly_Rental"},{"Label_Name":"Total_Tax"},{"Label_Name":"Total_Tax_Call_Charges"},{"Label_Name":"Total_Tax_Internet_Charges"},{"Label_Name":"Total_Tax_Monthly_Rental"}],"id":"u_elem_11370093479201812","content":"<div style=\"background-color: rgba(0, 0, 0, 0)\">\n   <table\n    style=\"margin: 0px auto; width: 100%\"\n          cellspacing=\"0\">\n    <tbody>\n     <tr>\n      <td\n          style=\"text-align: left\" width=\"16%\"><b><font\n              style=\"font-size: 10px\" face=\"arimo\"><font\n                style=\"font-size: 10px\"\n          color=\"#000000\">Tax Summary<\/font> <\/font><\/b><\/td>\n      <td\n          width=\"16%\"><br /><\/td>\n      <td\n          width=\"16%\"><br /><\/td>\n      <td\n          width=\"16%\"><br /><\/td>\n      <td\n        width=\"16%\"><br /><\/td>\n     <\/tr>\n     <tr\n          style=\"background-color: rgb(29, 80, 142)\">\n      <td\n              style=\"text-align: left\"><b><font color=\"#ffffff\"\n              style=\"font-size: 10px\" face=\"arimo\"><font\n            style=\"font-size: 10px\">Description<\/font> <\/font><\/b><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n            face=\"arimo\"><br /><\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n              style=\"text-align: right\"><b><font color=\"#ffffff\"\n              style=\"font-size: 10px\" face=\"arimo\"><font\n          style=\"\"> Amount&nbsp;<br /><\/font> <\/font><\/b><\/td>\n      <td\n              style=\"text-align: right\"><b><font color=\"#ffffff\"\n              style=\"font-size: 10px\" face=\"arimo\"><font\n          style=\"\"> Tax Amount<\/font><br /><\/font><\/b><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n            face=\"arimo\">Monthly Rental<\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n            face=\"arimo\"><br /><\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"> <span>${Sub_Total_Monthly_Rental}<\/span> <br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"> <span>${Total_Tax_Monthly_Rental}<\/span> <br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n            face=\"arimo\">Internet Charges<\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n            face=\"arimo\"><br /><\/font><\/td>\n      <td><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"> <span>${Sub_Total_Internet_Charges}<\/span> <br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\"><span>${Total_Tax_Internet_Charges}<\/span><br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n            color=\"#000000\"\n          face=\"arimo\">Call Charges<\/font><\/td>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: left\"><font style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n                face=\"arimo\"><span><font style=\"\"\n          color=\"#000000\">${Sub_Total_Call_Charges}<\/font><\/span><br /><\/font><\/td>\n      <td\n            style=\"text-align: right\"><font style=\"font-size: 10px\"\n                face=\"arimo\"><span><font style=\"\"\n          color=\"#000000\">${Total_Tax_Call_Charges}<\/font><\/span><br /><\/font><\/td>\n     <\/tr>\n     <tr>\n      <td\n            style=\"text-align: left; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\" color=\"#000000\"\n          face=\"arimo\"><b>Total<\/b><\/font><\/td>\n      <td\n            style=\"border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\"\n          face=\"arimo\"><br /><\/font><\/td>\n      <td\n            style=\"text-align: right; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\" color=\"#000000\" face=\"arimo\"><b\n          style=\"\"> ${Sub_Total} <br /><\/b><\/font><\/td>\n      <td\n            style=\"text-align: right; border-top: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51)\"><font\n            style=\"font-size: 10px\" face=\"arimo\"><span><font\n                    color=\"#000000\"><b> <font style=\"\">${Total_Tax}<\/font><\/b><\/font> <\/span> <br /><\/font><\/td>\n     <\/tr>\n    <\/tbody>\n   <\/table>\n  <\/div>"}},{"type":"text","element":{"id":"u_elem_161517163","fields":[],"content":"<div style=\"background: rgba(0, 0, 0, 0); padding: 0px\">\n   <h1\n      style=\"text-align: center; color: rgb(0, 0, 0); font-style: normal\"><font\n        style=\"\"> <font face=\"arimo\" style=\"font-size: 10px\"> <font\n            style=\"font-weight: 400\"> <font\n          style=\"\">\u200b<\/font>\u200b<\/font> <font style=\"\"><b style=\"\">This is a computer generated document and therefore no signature is required<\/b><\/font> <\/font> <\/font><\/h1>\n  <\/div>"}}],"style":""},{"colElements":[{"type":"spacer","element":{"id":"u_elem_1701381780000019","height":"25"}}],"style":""}]}},{"type":"columns","element":{"split":"4,46,50","id":"u_elem_3318264100000009","elemStyle":"","collayouts":[{"colElements":[{"type":"spacer","element":{"id":"u_elem_3321236400000006","height":"35"}}],"style":""},{"colElements":[{"id":"u_elem_13636976298193678","type":"fields","element":{"valueStyle":"","valueTextStyle":"width: 60%","fieldLayoutType":"2","labelText":"QR Invoice Public Link","wrapperStyle":"","labelStyle":"background-color: rgb(29, 80, 142)","Label_Name":"QR_Invoice_Public_Link","labelTextStyle":"color: rgb(255, 255, 255); font-size: 14px"}}],"style":""},{"colElements":[{"type":"spacer","element":{"id":"u_elem_3330628200000003","height":"35"}}],"style":""}]}},{"type":"columns","element":{"split":"100","id":"u_elem_118566535","elemStyle":"","collayouts":[{"colElements":[{"type":"spacer","element":{"id":"u_elem_3326824400000006","height":"25"}},{"type":"spacer","element":{"id":"u_elem_1983686600000009","height":"25"}}],"style":""}]}},{"type":"columns","element":{"split":"100","id":"u_elem_17849664699999988","elemStyle":"","collayouts":[{"colElements":[{"type":"spacer","element":{"id":"u_elem_17849664600000024","height":"25"}}],"style":""}]}}],"id":1}],"resize":"a4","themeFont":"lato","isHeaderEnabled":false}
				}
			}
		}
		form Journal_Entry
		{
			displayname = "Journal Entry"
			success message = "Journal Entry Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			unique Journal_Entry_No
			(
    			type = text
				displayname = "Journal Entry No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Document_No
			(
    			type = text
				displayname = "Document No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice
			(
				type = picklist	
				values  = Invoice.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Debit_Note
			(
				type = picklist	
				displayname = "Debit Note"
				values  = Debit_Note.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Credit_Note
			(
				type = picklist	
				displayname = "Credit Note"
				values  = Credit_Note.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Refund_Note
			(
				type = picklist	
				displayname = "Refund Note"
				values  = Refund_Note.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Payment_Received
			(
				type = picklist	
				displayname = "Payment Received"
				values  = Payment_Received.ID
    			displayformat = [Payment_Received_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Deposits
			(
				type = picklist	
				values  = Pro_Forma_Invoices.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Journal_Entry_Line_Item
			(
				type = grid
				displayname = "Journal Entry Line Item"
				Account
				(
					type = picklist	
					values  = Chart_Of_Account.ID
    				displayformat = [Account]
					sortorder = ascending
					width = medium
				)
				Description
				(
    				type = textarea
					height = 100px
					width = medium
				)
				Debit
				(
					type = MYR
					format = commadotwestern
					width = medium
				)
				Credit
				(
					type = MYR
					format = commadotwestern
					width = medium
				)
	 			row = 2
	 			column = 1   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Sub_Total_Debit
			(
				type = decimal
				displayname = "Sub Total Debit"
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Total_Debit
			(
				type = decimal
				displayname = "Total Debit"
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Difference
			(
				type = decimal
				format = commadotwestern
	 			row = 3
	 			column = 1   
				width = medium
			)
			Sub_Total_Credit
			(
				type = decimal
				displayname = "Sub Total Credit"
				format = commadotwestern
	 			row = 3
	 			column = 2   
				width = medium
			)
			Total_Credit
			(
				type = decimal
				displayname = "Total Credit"
				format = commadotwestern
	 			row = 3
	 			column = 2   
				width = medium
			)
			Section2
			(
				type = section
				displayname = "Section"
	 			row = 4
	 			column = 0   
				width = medium
			)
			Created_By_The_System
			(
    			type = checkbox
				displayname = "Created By The System"
				initial value = false
	 			row = 4
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Notify_Credits_Available
		{
			displayname = "Notify Credits Available"
			store data in zc = false
			success message = ""
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			message
			(
    			type = plaintext
				value = "Add your Note here ..."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Type_Of_Action
			(
				type = picklist
				displayname = "Type Of Action"
				maxchar = 100
				values = {"Mark As Sent","Send Invoice"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice
			(
				type = picklist	
				values  = Invoice.ID
    			displayformat = [Invoice_No]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Invoice_No
			(
    			type = text
				displayname = "Invoice No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_Name
			(
				type = picklist	
				displayname = "Customer Name"
				values  = Customer_Profile.ID
    			displayformat = [Customer_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_Code
			(
				type = picklist	
				displayname = "Customer Code"
				values  = Tenancy.ID
    			displayformat = [Tenant_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Customer_Email
			(
    			type = email
				displayname = "Customer Email"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				Yes
				(
   					type = submit
   					displayname = "Yes"
				)
				No
				(
   					type = button
   					displayname = "No"
				)
			}
		}
		form Organization_Settings
		{
			displayname = "Organization Settings"
			success message = "Organization Setting Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Organization_Name
			(
    			type = text
				displayname = "Organization Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Company_Email
			(
    			type = email
				displayname = "Company Email"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Finance_Email
			(
    			type = email
				displayname = "Finance Email"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Company_Registration_Number_Scheme
			(
				type = picklist
				displayname = "Company Registration Number Scheme"
				maxchar = 100
				values = {"NRIC","BRN","PASSPORT","ARMY"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Company_Registration_Number
			(
    			type = text
				displayname = "Company Registration Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have MSIC_Description
			(
				type = picklist
