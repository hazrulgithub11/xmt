										{
											get_organization = Organization_Settings[ID != null];
											input.Base_Currency = get_organization.Base_Currency;
											input.Subscription_Status = "Active";
											clear Work_Order_Type;
											input.Work_Order_Type:ui.append("WO - Service Activation");
											input.Work_Order_Type:ui.append("WO - Service Change Request");
										}
						)
					}
				}

			}
			Handle_Contract_Period_Ch as "Handle Contract Period Changes"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Contract_Period
				{
					actions  (Contract_Start_Date is not null && Contract_Period is not null)
					{
						custom deluge script
						(
											if(input.Customer_Code == null || input.Contract_Start_Date == null || input.Contract_Period == null || input.Billing_Cycle == null)
										{
											return;
										}
										new_end_date = input.Contract_Start_Date.addMonth(input.Contract_Period);
										if(input.Contract_End_Date != new_end_date)
										{
											input.Contract_End_Date = new_end_date;
										}
										input.Prorate_Note = thisapp.subscription.get_prorate_note(input.Contract_Start_Date,input.Contract_End_Date,input.Billing_Cycle,input.Bill_For,input.Bill_Every,input.Prorate);
						)
					}
				}

			}
			User_input_of_Customer_Co1 as "User input of Customer Code created/edited"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Customer_Code
				{
					actions 
					{
						custom deluge script
						(
											get_tenant = Tenancy[ID == input.Customer_Code];
										// Reset contract fields unconditionally
										input.Contract_Start_Date = null;
										input.Contract_Period = null;
										input.Contract_End_Date = null;
										input.Prorate = false;
										input.Prorate_Note = "";
										if(input.Customer_Code != null)
										{
											// Populate tenant-derived fields
											input.Payment_Term = ifnull(get_tenant.Payment_Term,null);
											input.Payable_To = ifnull(get_tenant.Payable_To,null);
											input.Contact = get_tenant.Contact;
											input.Technical_Email = get_tenant.Technical_Email;
											input.Phone_Number = get_tenant.Phone_Number;
											input.Billing_Cycle = ifnull(input.Billing_Cycle,null);
											input.Bill_Every = ifnull(input.Bill_Every,null);
											input.Bill_For = ifnull(input.Bill_For,null);
											quantity = thisapp.tenancy.convert_bill_cycle_to_int(input.Billing_Cycle);
											// Monthly Rental
											for each  curr_monthly_rental_line_item in input.Monthly_Rental
											{
												curr_monthly_rental_line_item.Quantity_Monthly_Rental=quantity;
												curr_monthly_rental_line_item.Business_Segment_Monthly_Rental=null;
												curr_monthly_rental_line_item.Business_Unit_Monthly_Rental=null;
											}
											// Internet Charges
											for each  curr_internet_charges_line_item in input.Internet_Charges
											{
												curr_internet_charges_line_item.Quantity_Internet_Charges=quantity;
												curr_internet_charges_line_item.Business_Segment_Internet_Charges=null;
												curr_internet_charges_line_item.Business_Unit_Internet_Charges=null;
											}
											// Call Charges
											for each  curr_call_charges_line_item in input.Call_Charges
											{
												curr_call_charges_line_item.Quantity_Call_Charges=quantity;
												curr_call_charges_line_item.Business_Segment_Call_Charges=null;
												curr_call_charges_line_item.Business_Unit_Call_Charges=null;
											}
											if(ifnull(input.Customer_PO_No,"") != "")
											{
												subscription_list = Subscription[Customer_Code == input.Customer_Code && Customer_PO_No == input.Customer_PO_No && ID != input.ID].ID.getAll();
												if(subscription_list.size() > 0)
												{
													alert "The Customer PO No. " + input.Customer_PO_No + " already exists for this tenant. Please enter a different PO No.";
													input.Customer_PO_No = "";
												}
											}
										}
										else
										{
											// Clear all tenant-derived fields
											input.Payment_Term = null;
											input.Payable_To = null;
											input.Customer_PO_No = "";
											input.Contact = null;
											input.Technical_Email = null;
											input.Phone_Number = null;
											input.Billing_Cycle = null;
											input.Bill_Every = null;
											input.Bill_For = null;
											// Monthly Rental
											for each  curr_monthly_rental_line_item in input.Monthly_Rental
											{
												curr_monthly_rental_line_item.Quantity_Monthly_Rental=0;
												curr_monthly_rental_line_item.Business_Segment_Monthly_Rental=null;
												curr_monthly_rental_line_item.Business_Unit_Monthly_Rental=null;
											}
											// Internet Charges
											for each  curr_internet_charges_line_item in input.Internet_Charges
											{
												curr_internet_charges_line_item.Quantity_Internet_Charges=0;
												curr_internet_charges_line_item.Business_Segment_Internet_Charges=null;
												curr_internet_charges_line_item.Business_Unit_Internet_Charges=null;
											}
											// Call Charges
											for each  curr_call_charges_line_item in input.Call_Charges
											{
												curr_call_charges_line_item.Quantity_Call_Charges=0;
												curr_call_charges_line_item.Business_Segment_Call_Charges=null;
												curr_call_charges_line_item.Business_Unit_Call_Charges=null;
											}
										}
										input.User_Input_Trigger = !input.User_Input_Trigger;
						)
					}
				}

			}
			Handle_Contract_Start_Dat as "Handle Contract Start Date"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Contract_Start_Date
				{
					actions  (Contract_Period is not null && Contract_Start_Date is not null)
					{
						custom deluge script
						(
											input.Contract_End_Date = input.Contract_Start_Date.addMonth(input.Contract_Period);
										input.Prorate_Note = thisapp.subscription.get_prorate_note(input.Contract_Start_Date,input.Contract_End_Date,input.Billing_Cycle,input.Bill_For,input.Bill_Every,input.Prorate);
						)
					}
					actions 
					{
						custom deluge script
						(
											if((input.Billing_Cycle == "Monthly" && input.Bill_For == "Current Duration" && input.Contract_Start_Date > today.toStartOfMonth() && input.Contract_Start_Date.getDay() != 1 && input.Contract_Start_Date <= today.eomonth(0)) || (input.Billing_Cycle == "Monthly" && input.Bill_For == "Previous Duration" && input.Contract_Start_Date > today.subMonth(1).toStartOfMonth() && input.Contract_Start_Date <= today.eomonth(0) && input.Contract_Start_Date.getDay() != 1) || (input.Billing_Cycle != null && input.Contract_Start_Date < today.toStartOfMonth()))
										{
											show Prorate_Note;
											show Prorate;
										}
										else
										{
											hide Prorate_Note;
											hide Prorate;
											input.Prorate = false;
											input.Prorate_Note = "";
										}
						)
					}
				}

			}
			Handle_Customer_Changes as "Handle Customer Changes"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Customer_Name
				{
					actions 
					{
						custom deluge script
						(
											customer_info = Customer_Profile[ID == input.Customer_Name];
										base_currency = ifnull(input.Base_Currency,ifnull(Organization_Settings[ID != null].Base_Currency,"MYR"));
										subscription_currency = ifnull(customer_info.Currency,base_currency);
										input.Subscription_Currency = subscription_currency;
										if(subscription_currency == base_currency)
										{
											input.Exchange_Rate = 1;
										}
										else
										{
											try 
											{
												exchange_rate_get_response = invokeurl
												[
													url :"https://api.frankfurter.app/latest?from=" + subscription_currency + "&to=" + base_currency
													type :GET
												];
												exchange_rate = exchange_rate_get_response.get("rates").get(base_currency);
												input.Exchange_Rate = exchange_rate;
											}	catch (e)
											{
												input.Exchange_Rate = "";
											}
										}
										input.Payment_Term = null;
										input.Payable_To = null;
										input.Contract_Start_Date = null;
										input.Contract_Period = null;
										input.Contract_End_Date = null;
										input.Prorate = false;
										input.Prorate_Note = "";
										input.Billing_Cycle = null;
										input.Bill_Every = null;
										input.Bill_For = null;
										// Monthly Rental
										for each  curr_monthly_rental_line_item in input.Monthly_Rental
										{
											// Exchange_Rate = MYR per 1 subscription-currency unit.
											// Unit_Price (Transaction_Type) is stored in MYR (base currency).
											// Divide by exchange_rate to convert to subscription currency price.
											unit_price = curr_monthly_rental_line_item.Item_Monthly_Rental.Unit_Price;
											unit_price_currency = unit_price / ifnull(input.Exchange_Rate,1);
											curr_monthly_rental_line_item.Unit_Price_Monthly_Rental=unit_price_currency;
											curr_monthly_rental_line_item.Item_Code_Monthly_Rental=curr_monthly_rental_line_item.Item_Monthly_Rental.Item_Code;
											curr_monthly_rental_line_item.Description_Monthly_Rental=curr_monthly_rental_line_item.Item_Monthly_Rental.Description;
											curr_monthly_rental_line_item.Quantity_Monthly_Rental=0;
											curr_monthly_rental_line_item.Tax_Monthly_Rental=null;
											curr_monthly_rental_line_item.Tax_Type_Monthly_Rental=null;
											curr_monthly_rental_line_item.Tax_Pct_Monthly_Rental=0;
											if(customer_info.ID != null && customer_info.Business_Segment.size() > 0)
											{
												curr_monthly_rental_line_item.Business_Segment_Monthly_Rental:ui.add(customer_info.Business_Segment);
											}
											else
											{
												clear curr_monthly_rental_line_item.Business_Segment_Monthly_Rental;
											}
											clear curr_monthly_rental_line_item.Business_Unit_Monthly_Rental;
											curr_monthly_rental_line_item.Business_Unit_Monthly_Rental=null;
										}
										// Internet Charges
										for each  curr_internet_charges_line_item in input.Internet_Charges
										{
											unit_price = curr_internet_charges_line_item.Item_Internet_Charges.Unit_Price;
											unit_price_currency = unit_price / ifnull(input.Exchange_Rate,1);
											curr_internet_charges_line_item.Unit_Price_Internet_Charges=unit_price_currency;
											curr_internet_charges_line_item.Item_Code_Internet_Charges=curr_internet_charges_line_item.Item_Internet_Charges.Item_Code;
											curr_internet_charges_line_item.Description_Internet_Charges=curr_internet_charges_line_item.Item_Internet_Charges.Description;
											curr_internet_charges_line_item.Quantity_Internet_Charges=0;
											curr_internet_charges_line_item.Tax_Internet_Charges=null;
											curr_internet_charges_line_item.Tax_Type_Internet_Charges=null;
											curr_internet_charges_line_item.Tax_Pct_Internet_Charges=0;
											if(customer_info.ID != null && customer_info.Business_Segment.size() > 0)
											{
												curr_internet_charges_line_item.Business_Segment_Internet_Charges:ui.add(customer_info.Business_Segment);
											}
											else
											{
												clear curr_internet_charges_line_item.Business_Segment_Internet_Charges;
											}
											clear curr_internet_charges_line_item.Business_Unit_Internet_Charges;
											curr_internet_charges_line_item.Business_Unit_Internet_Charges=null;
										}
										// Call Charges
										for each  curr_call_charges_line_item in input.Call_Charges
										{
											unit_price = curr_call_charges_line_item.Item_Call_Charges.Unit_Price;
											unit_price_currency = unit_price / ifnull(input.Exchange_Rate,1);
											curr_call_charges_line_item.Unit_Price_Call_Charges=unit_price_currency;
											curr_call_charges_line_item.Item_Code_Call_Charges=curr_call_charges_line_item.Item_Call_Charges.Item_Code;
											curr_call_charges_line_item.Description_Call_Charges=curr_call_charges_line_item.Item_Call_Charges.Description;
											curr_call_charges_line_item.Quantity_Call_Charges=0;
											curr_call_charges_line_item.Tax_Call_Charges=null;
											curr_call_charges_line_item.Tax_Type_Call_Charges=null;
											curr_call_charges_line_item.Tax_Pct_Call_Charges=0;
											if(customer_info.ID != null && customer_info.Business_Segment.size() > 0)
											{
												curr_call_charges_line_item.Business_Segment_Call_Charges:ui.add(customer_info.Business_Segment);
											}
											else
											{
												clear curr_call_charges_line_item.Business_Segment_Call_Charges;
											}
											clear curr_call_charges_line_item.Business_Unit_Call_Charges;
											curr_call_charges_line_item.Business_Unit_Call_Charges=null;
										}
										input.User_Input_Trigger = !input.User_Input_Trigger;
						)
					}
				}

			}
			Handle_Contract_End_Date_ as "Handle Contract End Date Fields"
			{
				type =  form
				form = Subscription

				record event = on add or edit

				on user input of Contract_End_Date
				{
					actions 
